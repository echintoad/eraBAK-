;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_XXX(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 
; 길이에 따라 변경 필요하면
; IF iLen > 0 && iLen < 13
; 	RESULTS = 기관총
; ELSE 		;123456789 123456789 123456789
; 	RESULTS = 양산형 기관총
; ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_XXX(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3 ; 필요한 만큼 증가 / 감소
; 고유 캐릭터 확인
IF 대상 >= 0 && NO:대상 == 99
	스탯증가:0 = 10 ; 무투
	스탯증가:1 = 10 ; 방위
	스탯증가:2 = 10 ; 지략
ELSE
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 5 ; 방위
	스탯증가:2 = 5 ; 지략
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착
ABL:대상:지략 += 스탯증가:2 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = XXX
	CALL SKILL_LEARN(대상, 스킬_장르, XXXX, 0) ; XXXX = 무기 번호 + 1000
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르, "스킬이름")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_XXX(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
; 고유 캐릭터 확인
IF 대상 >= 0 && NO:대상 == 99
	RESULT:총력전_무기_최대체력 = 200
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_방어력 = 10
	RESULT:총력전_무기_명중률 = 10
ELSE
	RESULT:총력전_무기_최대체력 = 100
	RESULT:총력전_무기_공격력 = 5
	RESULT:총력전_무기_방어력 = 5
	RESULT:총력전_무기_명중률 = 5
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_XXX(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid ; 총력전 스탯
	CALL ICPRINT(@"고유캐릭터: 최대체력: <200> 공격력: <10> 방어력: <10> 명중률: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <100> 공격력: <5> 방어력: <5> 명중률: <5>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"고유캐릭터: 무투: <10> 방위: <10> 지략: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <5> 방위: <5> 지략: <5>", "L", 칼라_주의)
ENDIF

@무기_설명_XXX
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_XXXX_장르_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_XXXX_장르_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN