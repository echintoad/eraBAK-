[IF_DEBUG]
;-------------------------------------------------
; 총력전 밸런스용
;-------------------------------------------------
@RAIDDEBUG
#DIM DYNAMIC FIRST_LINE

FIRST_LINE = LINECOUNT

$STARTDEBUG_RAID
; CLEARLINE LINECOUNT - FIRST_LINE
CALL SINGLE_DRAWLINE
PRINTL 총력전 밸런스 조정 도구
CALL SINGLE_DRAWLINE
PRINTL
PRINTBUTTON "0[돌아간다]", 0
PRINTL
PRINTBUTTON "1[자가 버프 딜러 스킬]", 1
PRINTL
CALL SINGLE_DRAWLINE
INPUT
CLEARLINE LINECOUNT - FIRST_LINE
SELECTCASE RESULT
	CASE 0
		RETURN
	CASE 1
		CALL RAIDDEBUG_selfbuff_0
ENDSELECT
GOTO STARTDEBUG_RAID

; #region Self Buff 0
@RAIDDEBUG_selfbuff_0
#DIM DYNAMIC FIRST_LINE
#DIM DYNAMIC isFirstRun = 1
#DIM DYNAMIC iSkillStart = -1
#DIM DYNAMIC iSkillRepeat = -1
#DIM iRunNumber = 400
#DIM DYNAMIC iTurnNumber = 1

#DIM DYNAMIC iDmgTurn, 3 ; 턴당 대미지
#DIM DYNAMIC iDmgCast, 3 ; 스킬 시전당 대미지
#DIM DYNAMIC iDmgCast_Cnt ; 스킬 시전 턴 카운터
#DIM DYNAMIC iDmgCost, 3 ; 코스트 당 대미지

#DIM DYNAMIC iBoss
#DIM DYNAMIC iChara, 2
#LOCALSIZE 4
#LOCALSSIZE 1

FIRST_LINE = LINECOUNT

CALL 총력전_해제
; 보스 설정
CALL RAIDDEBUG_boss(10)
; 기본 캐릭터 설정
CALL RAIDDEBUG_chara
iChara = RESULT
iChara:1 = CHARANUM
ADDVOIDCHARA
COPYCHARA iChara, iChara:1

; 고정 설정
CALL 총력전_초기화_범위
총력전_ID:0 = iChara
총력전_ID:1 = iChara:1
총력전_상태:0 = 총력전_상태_보통
총력전_상태:1 = 총력전_상태_행동불능 ; 기존 스탯 기록용

$SETCHARA
IF !isFirstRun
	; 캐릭터 설정
	CALL RAIDDEBUG_chara(iChara)
	; 무기 설정
	PRINTL 무기 번호 설정
	PRINTBUTTON "[ 유지 ] ", -1
	PRINTFORM 지금 무기번호:{TALENT:iChara:웨폰}(-1 이면 기존 무기 유지)
	INPUT
	CLEARLINE 2
	IF RESULT != -1
		LOCAL = RESULT
		TRYCALLFORM 무기_착용_{TALENT:iChara:웨폰}(iChara,-1)
		TRYCALLFORM 무기_착용_{LOCAL}(iChara,1)
		TALENT:iChara:웨폰 = LOCAL
	ENDIF
ENDIF

; CALL DEBUG_총력전_스탯(0)
; CALL DEBUG_총력전_스탯(10)
; WAIT

$SETRUNNUMBER
iRunNumber = MAX(iRunNumber, 1)
IF iSkillStart >= 0
	CALL WEAPON_NAME(TALENT:iChara:웨폰)
	PRINTFORM 턴 {iSkillStart}에 스킬 ({TALENT:iChara:웨폰 + 1000}/%RESULTS%) 시전
	IF iSkillRepeat >= 0
		PRINTFORML 후 {iSkillRepeat}턴 마다 추가 시전
	ELSE
		PRINTL
	ENDIF
ENDIF
PRINTFORML {iTurnNumber}턴 테스트
PRINTFORML {iRunNumber}번 반복
PRINTBUTTON "[ 시작 ] ", 0
IF !isFirstRun
	PRINTBUTTON " [ 무기 + 캐릭터 설정 ] ", 1
	PRINTBUTTON " [ 스킬 시작 턴 ] ", 2
	PRINTBUTTON " [ 스킬 재시전 턴 ] ", 3
	PRINTBUTTON " [ 턴 회수 변경 ] ", 4
ENDIF
PRINTBUTTON " [ 반복 회수 변경 ]", 5
INPUT
CLEARLINE 1
SELECTCASE RESULT
	CASE 0
		GOTO STARTRUN
	CASE 1
		CLEARLINE LINECOUNT - FIRST_LINE
		GOTO SETCHARA
	CASE 2
		PRINTL 스킬 시작 턴
		PRINTL -1 이면 스킬 시전 없음
		INPUT
		iSkillStart = RESULT
	CASE 3
		PRINTL 스킬 재시전 턴 (시작 + n)
		PRINTL  -1 이면 재시전 없음
		INPUT
		iSkillRepeat = RESULT
	CASE 4
		PRINTL 테스트당 턴수
		INPUT
		iTurnNumber = MAX(RESULT, 1)
	CASE 5
		PRINTL 테스트 반복 회수
		INPUT
		iRunNumber = MAX(RESULT, 1)
ENDSELECT
GOTO SETRUNNUMBER
$STARTRUN
SKIPDISP 1

; 무기 평균
iDmgTurn = 0
; 전 테스트 효과 제거
FOR LOCAL, 0, 총력전_상태효과수
	CALL 총력전_상태효과_제거(0, 0)
NEXT
FOR LOCAL, 0, 총력전_카운터수
	CALL 총력전_카운터_제거(0, 0)
NEXT
총력전_공격잔여:0 = 0
총력전_스킬_가변:0 = 0
CALL 총력전_초기화_스탯_전
FOR LOCAL:2, 0, iRunNumber
	총력전_전투단계 = 총력전_전투단계_기본공격
	CALL 총력전_시퀀스_기본공격(0, 0)
	; 대미지 기록
	iDmgTurn += 총력전_최대체력:10 - 총력전_체력:10
	총력전_체력:10 = 총력전_최대체력:10
NEXT
iDmgTurn:1 = iDmgTurn:0 / iRunNumber
iDmgTurn = 0
VARSET iDmgCast, 0
iDmgCast_Cnt = 0

; 스킬 평균
SIF 총력전_ID:0 >= 0
	CALL 총력전_초기화_캐릭터정보(0)
SIF isFirstRun || 총력전_스킬_번호:0 == -1
	GOTO ENDTEST
FOR LOCAL:2, 0, iRunNumber
	; 전 테스트 효과 제거
	FOR LOCAL, 0, 총력전_상태효과수
		CALL 총력전_상태효과_제거(0, 0)
	NEXT
	FOR LOCAL, 0, 총력전_카운터수
		CALL 총력전_카운터_제거(0, 0)
	NEXT
	총력전_공격잔여:0 = 0
	총력전_스킬_가변:0 = 0
	; 스탯 계산
	CALL 총력전_초기화_스탯_전
	TRYCCALLFORM DEBUG_총력전_스킬_{총력전_스킬_번호:0}_초기(0)
	CATCH
		TRYCALLFORM 총력전_스킬_{총력전_스킬_번호:0}_초기(0)
	ENDCATCH
	FOR LOCAL:1, 0, iTurnNumber
		; 총력전_시퀀스
		; 적군 군중제어 감소
		; CALL 총력전_처리_군중제어_감소(iTmp)
		; CALL 총력전_시퀀스_스킬시전_엄폐물
		총력전_전투단계 = 총력전_전투단계_플레이어
		; CALL 총력전_시퀀스_플레이어
		총력전_전투단계 = 총력전_전투단계_스킬
		; CALL 총력전_시퀀스_스킬시전(총력전_상태_보통)
		IF iSkillStart >= 0
			IF LOCAL:2 == 0
				DEBUGPRINTFORML Turn = {LOCAL:1}, SkillStart = {iSkillStart}, SkillRepeat = {iSkillRepeat}
				DEBUGPRINTFORML {(LOCAL:1 - iSkillStart) % iSkillRepeat}
			ENDIF
			LOCAL:3 = (LOCAL:1 - iSkillStart) % iSkillRepeat
			IF (iSkillRepeat == -1 && iSkillStart == LOCAL:1) || (iSkillRepeat >= 0 && iSkillStart <= LOCAL:1 && LOCAL:3 == 0)
				IF LOCAL:2 == 0
					iDmgCast_Cnt += 1
					DEBUGPRINTFORML 스킬 처리:%총력전_스킬_이름:0%, 코스트:{총력전_스킬_코스트:0}
				ENDIF
				CALL RAIDDEBUG_처리_스킬(0)
			ENDIF
		ENDIF
		; trycall 디버그 스킬
		총력전_전투단계 = 총력전_전투단계_기본공격
		CALL 총력전_시퀀스_기본공격(0, 0)
		; 아군 군중제어 감소
		; CALL 총력전_처리_군중제어_감소(iTmp)
		총력전_전투단계 = 총력전_전투단계_보스스킬
		; CALL 총력전_시퀀스_스킬시전(총력전_상태_보스)
		총력전_전투단계 = 총력전_전투단계_보스공격
		; CALL 총력전_시퀀스_기본공격(1, 10)
		; 상태효과 적용: 턴
		FOR LOCAL, 0, 총력전_캐릭터수
			CALL 총력전_상태효과_적용_기타(LOCAL, 총력전_방식_턴)
		NEXT
		; 상태이상/카운터 소비: 턴
		FOR LOCAL, 0, 총력전_캐릭터수
			CALL 총력전_카운터_증가(LOCAL, -1, 총력전_방식_턴)
			CALL 총력전_카운터_소비(LOCAL, 총력전_방식_턴)
			CALL 총력전_상태효과_소비(LOCAL, 총력전_방식_턴)
			CALL 총력전_엄폐물_소비(LOCAL, 총력전_방식_턴, 1)
		NEXT
		FOR LOCAL, 0, 총력전_캐릭터수
			총력전_스탯상태:LOCAL = 0
			CALL 총력전_초기화_스탯_상효(LOCAL)
		NEXT
		; 대미지 기록
		IF LOCAL:2 == 0
			DEBUGPRINTFORML 턴 대미지:{총력전_최대체력:10 - 총력전_체력:10}
		ENDIF
		iDmgTurn += 총력전_최대체력:10 - 총력전_체력:10
		IF iSkillStart >= 0 || iSkillStart >= LOCAL:1
			iDmgCast += 총력전_최대체력:10 - 총력전_체력:10
		ENDIF
		총력전_체력:10 = 총력전_최대체력:10
	NEXT
NEXT
$ENDTEST
; 계산
DEBUGPRINTFORML total dmg:{iDmgTurn}
DEBUGPRINTFORML total dmg/turn(auto):{iDmgTurn:1}
DEBUGPRINTFORML total cast dmg:{iDmgCast}
DEBUGPRINTFORML cast cnt:{iDmgCast_Cnt}
iDmgTurn = iDmgTurn / (iRunNumber * iTurnNumber)
iDmgCast_Cnt = MAX(1, iDmgCast_Cnt)
IF iSkillRepeat == -1
	LOCAL = MAX(1, iTurnNumber)
ELSE
	LOCAL = iSkillRepeat
ENDIF
iDmgCast:0 = iDmgCast / (iRunNumber * iDmgCast_Cnt)
iDmgCast:1 = iDmgCast - iDmgTurn:1 * LOCAL
iDmgCast:2 = iDmgCast - iDmgTurn:2 * LOCAL
IF 총력전_스킬_코스트:0 > 0
	iDmgCost:0 = iDmgCast:0 / 총력전_스킬_코스트:0
	iDmgCost:1 = iDmgCast:1 / 총력전_스킬_코스트:0
	iDmgCost:2 = iDmgCast:2 / 총력전_스킬_코스트:0
ENDIF
IF isFirstRun
	iDmgTurn:2 = iDmgTurn:1
	isFirstRun = 0
	iSkillStart = 0
ENDIF
SKIPDISP 0
; 리포트
CLEARLINE LINECOUNT - FIRST_LINE
; 보스 스탯
CALL SINGLE_DRAWLINE
PRINTL 보스 스탯
PRINTFORML 방어력:{총력전_방어력_최초:10}, 회피율:{총력전_회피율_최초:10}, 치명 저항:{총력전_치명타_저항_최초:10}, 치명 대미지 저항:{총력전_치명타_대미지_저항_최초:10}
; 비교 대상
CALL SINGLE_DRAWLINE
; 기존 스탯?
PRINTL 기존 스탯
PRINTFORML 공격력:{총력전_공격력_최초:1}, 명중률:{총력전_명중률_최초:1}, 치명타:{총력전_치명타_최초:1}, 치명타 대미지:{총력전_치명타_대미지_최초:1}, 
PRINTL 기존 결과
PRINTFORML 턴당 대미지{iDmgTurn:2}
CALL SINGLE_DRAWLINE
; 이번 런 스탯
SIF STRLENS(총력전_이름:0)
	PRINTFORML 런:%총력전_이름:0%
PRINTFORM 공격력:{총력전_공격력_최초:0}(
SIF 총력전_공격력_최초:0 > 총력전_공격력_최초:1
	PRINT +
PRINTFORM {총력전_공격력_최초:0 - 총력전_공격력_최초:1}), 
PRINTFORM 명중률:{총력전_명중률_최초:0}(
SIF 총력전_명중률_최초:0 > 총력전_명중률_최초:1
	PRINT +
PRINTFORM {총력전_명중률_최초:0 - 총력전_명중률_최초:1}), 
PRINTFORM 치명타:{총력전_치명타_최초:0}(
SIF 총력전_치명타_최초:0 > 총력전_치명타_최초:1
	PRINT +
PRINTFORM {총력전_치명타_최초:0 - 총력전_치명타_최초:1}), 
PRINTFORM 치명타 대미지:{총력전_치명타_대미지_최초:0}(
SIF 총력전_치명타_대미지_최초:0 > 총력전_치명타_대미지_최초:1
	PRINT +
PRINTFORML {총력전_치명타_대미지_최초:0 - 총력전_치명타_대미지_최초:1})

PRINTFORML 턴당 대미지:{iDmgTurn:0}, 턴당 대미지(기본 공격만):{iDmgTurn:1}
PRINTFORML 시전 대미지:{iDmgCast:0}, 시전 대미지(기존 비교):{iDmgCast:2}, 시전 대미지(+무기 기본 공격 비교):{iDmgCast:1}
PRINTFORML 코스트 대미지:{iDmgCost:0}, 코스트 대미지(기존 비교):{iDmgCost:2}, 코스트 대미지(+무기 기본 공격 비교):{iDmgCost:1}
CALL SINGLE_DRAWLINE
PRINTBUTTON "[ 종료 ] ", 0
PRINTBUTTON " [ 다음 테스트 ]", 1
INPUT
CLEARLINE 1
IF RESULT == 1
	GOTO SETCHARA
ENDIF
CALL 총력전_해제
DELALLCHARA
; #endregion

; #region Cast Skill
@RAIDDEBUG_처리_스킬(시전자)
#DIM 시전자

; 스킬 상태효과 적용
SETBIT 총력전_스탯상태:시전자, 총력전_방식_스킬
CALL 총력전_상태효과_스탯처리(시전자)
; 스킬 시전
TRYCCALLFORM DEBUG_총력전_스킬_{총력전_스킬_번호:시전자}_발동(시전자)
CATCH
	TRYCALLFORM 총력전_스킬_{총력전_스킬_번호:시전자}_발동(시전자)
ENDCATCH
; 스킬 카운터 처리
CALL 총력전_카운터_증가(시전자, -1, 총력전_방식_스킬)
CALL 총력전_카운터_소비(시전자, 총력전_방식_스킬)
; 스킬 상태효과 종료
CLEARBIT 총력전_스탯상태:시전자, 총력전_방식_스킬
CALL 총력전_상태효과_스탯처리(시전자)
; 스킬 상태효과 소비
CALL 총력전_상태효과_소비(시전자, 총력전_방식_스킬)

; #region Set Boss
@RAIDDEBUG_boss(보스번호)
#DIM DYNAMIC 보스번호

#DIM DYNAMIC FIRST_LINE
#DIM 보스체력 = 999999
#DIM 보스공 = 0
#DIM 보스방 = 150
#DIM 보스명중 = 0
#DIM 보스회피 = 20
#DIM 보스치유 = 0
#DIM 보스치명 = 0
#DIM 보스치명저항 = 100
#DIM 보스치명대미지 = 0
#DIM 보스치명대미지저항 = 20
; #DIM 보스군중제어 = 2000
; #DIM 보스군중강화 = 0
; #DIM 보스군중저항 = 40

총력전_팀:보스번호 = 1
총력전_군중제어_한계_최초:보스번호 = 9000
총력전_군중제어_강화_최초:보스번호 = 0
총력전_군중제어_저항_최초:보스번호 = 0

FIRST_LINE = LINECOUNT
$INPUTLOOP
CLEARLINE LINECOUNT - FIRST_LINE

CALL SINGLE_DRAWLINE
PRINTL 보스 총력전 스탯
PRINTL
PRINTBUTTON "[ 수정 ]",1
PRINTFORM  체력: {보스체력}
PRINTL
PRINTBUTTON "[ 수정 ]",2
PRINTFORM 공격력: {보스공, 15, LEFT}
PRINTBUTTON " [ 수정 ]",3
PRINTFORM 방어력: {보스방, 15, LEFT}
PRINTL
PRINTBUTTON "[ 수정 ]",4
PRINTFORM 명중률: {보스명중, 15, LEFT}
PRINTBUTTON " [ 수정 ]",5
PRINTFORM 회피율: {보스회피, 15, LEFT}
PRINTBUTTON " [ 수정 ]",6
PRINTFORM 치유력: {보스치유, 15, LEFT}
PRINTL
PRINTBUTTON "[ 수정 ]",7
PRINTFORM 치명타: {보스치명, 15, LEFT}
PRINTBUTTON " [ 수정 ]",8
PRINTFORM 치명 저항: {보스치명저항, 12, LEFT}
PRINTL
PRINTBUTTON "[ 수정 ]",9
PRINTFORM 치명 대미지: {보스치명대미지, 10, LEFT}
PRINTBUTTON " [ 수정 ]",10
PRINTFORM 치명 대미지 저항: {보스치명대미지저항, 5, LEFT}
PRINTL
CALL SINGLE_DRAWLINE
PRINTL
PRINTBUTTON " [ 결정 ]", 0
PRINTL

INPUT
CLEARLINE 1
DRAWLINE

SELECTCASE RESULT
	CASE 0 ; 실행
		GOTO ENDSET
	CASE 1
		PRINTL 보스 체력 설정 (0 ~ 999,999)
		INPUT
		보스체력 = MIN(RESULT, 999999)
	CASE 2
		PRINTL 보스 공격력 설정 (0 ~ 1000)
		INPUT
		보스공 = MIN(RESULT, 1000)
	CASE 3
		PRINTL 보스 방어력 설정 (0 ~ 1000)
		INPUT
		보스방 = MIN(RESULT, 1000)
	CASE 4
		PRINTL 보스 명중률 설정 (0 ~ 1000)
		INPUT
		보스명중 = MIN(RESULT, 1000)
	CASE 5
		PRINTL 보스 회피율 설정 (0 ~ 1000)
		INPUT
		보스회피 = MIN(RESULT, 1000)
	CASE 6
		PRINTL 보스 치유력 설정 (0 ~ 1000)
		INPUT
		보스치유 = MIN(RESULT, 1000)
	CASE 7
		PRINTL 보스 치명타 설정 (0 ~ 1000)
		INPUT
		보스치명 = MIN(RESULT, 1000)
	CASE 8
		PRINTL 보스 치명타 저항 설정 (0 ~ 1000)
		INPUT
		보스치명저항 = MIN(RESULT, 1000)
	CASE 9
		PRINTL 보스 치명타 대미지 설정 (0 ~ 1000)
		INPUT
		보스치명대미지 = MIN(RESULT, 1000)
	CASE 10
		PRINTL 보스 치명타 대미지 저항 설정 (0 ~ 1000)
		INPUT
		보스치명대미지저항 = MIN(RESULT, 1000)
ENDSELECT
GOTO INPUTLOOP
$ENDSET
CLEARLINE LINECOUNT - FIRST_LINE

총력전_상태:보스번호 = 총력전_상태_보스
; 스탯 설정
총력전_최대체력_최초:보스번호 = 보스체력
총력전_공격력_최초:보스번호 = 보스공
총력전_방어력_최초:보스번호 = 보스방
총력전_명중률_최초:보스번호 = 보스명중
총력전_회피율_최초:보스번호 = 보스회피
총력전_치유력_최초:보스번호 = 보스치유
총력전_치명타_최초:보스번호 = 보스치명
총력전_치명타_저항_최초:보스번호 = 보스치명저항
총력전_치명타_대미지_최초:보스번호 = 보스치명대미지
총력전_치명타_대미지_저항_최초:보스번호 = 보스치명대미지저항
; #endregion

; #region Set Chara
; RETURN = 캐릭터번호
@RAIDDEBUG_chara(iChara = -1)
#DIM iChara

#DIM DYNAMIC FIRST_LINE
#DIM 총체력 = 2000
#DIM 총기력 = 2000
#DIM 총무투 = 50
#DIM 총방위 = 50
#DIM 총지략 = 50
#DIM 총정치 = 50
#DIM 총신비 = 0
#DIM 총요리 = 50
#DIM 총가창 = 50
; #DIM 총야심 = 50

IF iChara == -1
	iChara = CHARANUM
	ADDVOIDCHARA
ELSE
	총체력 = MAXBASE:iChara:체력
	총기력 = MAXBASE:iChara:기력
	총무투 = ABL:iChara:무투
	총방위 = ABL:iChara:방위
	총지략 = ABL:iChara:지략
	총정치 = ABL:iChara:정치
	총신비 = ABL:iChara:신비
	총요리 = ABL:iChara:요리
	총가창 = ABL:iChara:가창
	; 총야심 = ABL:iChara:야심
ENDIF
;작성한 캐릭터를 타겟으로 한다
TARGET = iChara

FIRST_LINE = LINECOUNT
$INPUTLOOP
CLEARLINE LINECOUNT - FIRST_LINE
CALL SINGLE_DRAWLINE
; 필요하지 않음, 테스트 중 헷갈림 방지용으로
PRINTFORML 캐릭터({iChara}) 스탯 설정
PRINTBUTTON "[ 이름 ] ", 1
PRINTFORM %NAME:iChara%
PRINTBUTTON "[ NO ] ", 2
PRINTFORM {NO:iChara}
PRINTL
CALL SINGLE_DRAWLINE
PRINTL
PRINTBUTTON "[ 4합 수정 ] ", 3
PRINTBUTTON "[ 7합 수정 ] ", 4
PRINTBUTTON "[ 요리,가창 수정 ]", 5
PRINTL
CALL SINGLE_DRAWLINE
PRINTL
PRINTBUTTON "[ 수정 ]", 10
PRINTFORM 체력: {총체력, 15, LEFT}
PRINTBUTTON "[ 수정 ]", 11
PRINTFORM 기력: {총기력, 15, LEFT}
PRINTL
CALL SINGLE_DRAWLINE
PRINTL
PRINTBUTTON "[ 수정 ]", 20
PRINTFORM 무투: {총무투, 10, LEFT}
PRINTBUTTON "[ 수정 ]", 21
PRINTFORM 방위: {총방위, 10, LEFT}
PRINTBUTTON "[ 수정 ]", 22
PRINTFORM 지략: {총지략, 10, LEFT}
PRINTBUTTON "[ 수정 ]", 23
PRINTFORM 정치: {총정치, 10, LEFT}
PRINTL
PRINTBUTTON "[ 수정 ]", 24
PRINTFORM 신비: {총신비, 10, LEFT}
PRINTBUTTON "[ 수정 ]", 25
PRINTFORM 요리: {총요리, 10, LEFT}
PRINTBUTTON "[ 수정 ]", 26
PRINTFORM 가창: {총가창, 10, LEFT}
PRINTL
CALL SINGLE_DRAWLINE
PRINTL
PRINTBUTTON " [ 결정 ]", 0
PRINTL

INPUT
CLEARLINE 1
SELECTCASE RESULT
	CASE 0
		GOTO ENDSET
	CASE 1
		PRINTL 이름 설정
		INPUTS
		NAME:iChara = %RESULTS%
	CASE 2
		PRINTL 캐릭터 번호 설정
		INPUT
		NO:iChara = RESULT
	CASE 3
		PRINTL 무투, 방위, 지략, 정치 수정
		INPUT
		총무투 = RESULT
		총방위 = RESULT
		총지략 = RESULT
		총정치 = RESULT
	CASE 4
		PRINTL 무투, 방위, 지략, 정치, 신비, 요리, 가창 수정
		INPUT
		총무투 = RESULT
		총방위 = RESULT
		총지략 = RESULT
		총정치 = RESULT
		총신비 = RESULT
		총요리 = RESULT
		총가창 = RESULT
	CASE 5
		PRINTL 요리, 가창 수정
		INPUT
		총요리 = RESULT
		총가창 = RESULT
	CASE 10
		PRINTFORML 체력 설정 (기존:{총체력})
		INPUT
		총체력 = RESULT
	CASE 11
		PRINTFORML 기력 설정 (기존:{총기력})
		INPUT
		총기력 = RESULT
	CASE 20
		PRINTFORML 무투 설정 (기존:{총무투})
		INPUT
		총무투 = RESULT
	CASE 21
		PRINTFORML 방위 설정 (기존:{총방위})
		INPUT
		총방위 = RESULT
	CASE 22
		PRINTFORML 지략 설정 (기존:{총지략})
		INPUT
		총지략 = RESULT
	CASE 23
		PRINTFORML 정치 설정 (기존:{총정치})
		INPUT
		총정치 = RESULT
	CASE 24
		PRINTFORML 신비 설정 (기존:{총신비})
		INPUT
		총신비 = RESULT
	CASE 25
		PRINTFORML 요리 설정 (기존:{총요리})
		INPUT
		총요리 = RESULT
	CASE 26
		PRINTFORML 가창 설정 (기존:{총가창})
		INPUT
		총가창 = RESULT
ENDSELECT
GOTO INPUTLOOP
$ENDSET

; (필요한) 스탯(만) 설정
MAXBASE:체력 = 총체력
BASE:체력 = MAXBASE:체력
MAXBASE:기력 = 총기력
BASE:기력 = MAXBASE:기력
ABL:무투 = 총무투
ABL:방위 = 총방위
ABL:지략 = 총지략
ABL:정치 = 총정치
ABL:신비 = 총신비
ABL:요리 = 총요리
ABL:가창 = 총가창
; ABL:야심 = 총야심

RETURN iChara
; #endregion
[ENDIF]