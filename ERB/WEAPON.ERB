@WEAPON_EQUIP(대상, 무기)
#DIM 대상
#DIM 무기
TRYCCALLFORM 무기_착용_{무기}(대상,1)
CATCH
	TALENT:대상:웨폰 = 무기
ENDCATCH

;-------------------------------------------------
;캐릭터가 사용 가능한 무기 추가 / 제거
;-------------------------------------------------
@WEAPON_ADD(대상, 무기)
#DIM 대상
#DIM 무기

; 양산형 이면 무시?
; 501 ~ 700 에 빈 공간 확인
FOR LOCAL, 501, 701
	SIF TALENT:대상:LOCAL == 무기
		BREAK
	IF TALENT:대상:LOCAL == 0
		TALENT:대상:LOCAL = 무기
		BREAK
	ENDIF
NEXT

@WEAPON_REMOVE(대상, 무기)
#DIM 대상
#DIM 무기
#DIM DYNAMIC 변경 ; bool

; 무기 번호 확인후 다음 번호로 변경
FOR LOCAL, 501, 701
	SIF TALENT:대상:LOCAL <= 0
		BREAK 
	SIF TALENT:대상:LOCAL == 무기
		변경 = 1
	IF 변경
		IF LOCAL == 700
			TALENT:대상:LOCAL = 0
		ELSE
			TALENT:대상:LOCAL = TALENT:대상:(LOCAL + 1)
		ENDIF
	ENDIF
NEXT
