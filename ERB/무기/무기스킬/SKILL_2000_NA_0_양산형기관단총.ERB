;-----------------------------------
; 양산형 무기는 총력전 스킬만?
;-----------------------------------
; 이름만, SP, BASE 상관 없음
@SKILL_2000_SP_0_NAME
RESULTS = 구급상자 팩 배포

; #region == 총력전 ==
@총력전_스킬_2000_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
; #DIM 가변
RETURN 2

@총력전_스킬_2000_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 아군 치유 (치유력 200％)

@총력전_스킬_2000_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 치유량
#DIM DYNAMIC 치유대상
; #DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 발동 텍스트
CALL SKILL_2000_SP_0_NAME
sTmp = %총력전_이름:시전자% 스킬 시전:『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; 목표 처리
sTmp = 치유 대상 선택
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
CALL 총력전_시퀀스_목표선택(치유대상, 총력전_선택_캐릭터, 0)
; 목표 없으면 스킬 해재
IF 치유대상 < 0
	CALL 총력전_스킬_공통_스킬취소(시전자)
	RETURN
ENDIF
; 치유
치유량 = GETVAR_RAIDSTAT_SUM(시전자, "치유력") * 200
치유량 = DIVIDE_ROUND(치유량, 100)
CALL 총력전_처리_치유(치유량, 치유대상, 시전자)