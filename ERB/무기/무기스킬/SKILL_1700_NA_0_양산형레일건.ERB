;-----------------------------------
; 양산형 무기는 총력전 스킬만?
;-----------------------------------
; 이름만, SP, BASE 상관 없음
@SKILL_1700_SP_0_NAME
RESULTS = 전력 급증

; #region == 총력전 ==
@총력전_스킬_1700_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
; #DIM 가변
RETURN 4

@총력전_스킬_1700_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 2범위내 아군에게 2턴간 보호막 부여 (방어력 250％)

@총력전_스킬_1700_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 대상, 총력전_캐릭터수
#DIM DYNAMIC 보호막양
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 발동 텍스트
CALL SKILL_1700_SP_0_NAME
sTmp = %총력전_이름:시전자% 스킬 시전:『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; 범위 대상, 적팀 1 이상이 되면 수정 필요
CALL 총력전_목표_범위(대상, 시전자, 0, 2)
; 보호막
보호막양 = GETVAR_RAIDSTAT_SUM(시전자, "방어력") * 250
보호막양 = DIVIDE_ROUND(보호막양, 100)
FOR iTmp, 0, 총력전_캐릭터수
	SIF 대상:iTmp < 0
		BREAK
	CALL 총력전_상태효과_추가_텍스트(대상:iTmp, 시전자, 상효_종류_보호막, 보호막양, 1, 총력전_방식_지속, 총력전_방식_턴, 2, 1700)
NEXT