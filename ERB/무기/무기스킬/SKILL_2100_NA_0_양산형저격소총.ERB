;-----------------------------------
; 양산형 무기는 총력전 스킬만?
;-----------------------------------
; 이름만, SP, BASE 상관 없음
@SKILL_2100_SP_0_NAME
RESULTS = 저격

; #region == 총력전 ==
@총력전_스킬_2100_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
; #DIM 가변
RETURN 3

@총력전_스킬_2100_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 적에게 대미지 (공격력 400％)

@총력전_스킬_2100_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 목표
#DIM DYNAMIC 대미지
; #DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 발동 텍스트
CALL SKILL_2100_SP_0_NAME
sTmp = %총력전_이름:시전자% 스킬 시전:『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; 목표 처리
CALL 총력전_시퀀스_목표선택(목표, 0, 총력전_선택_캐릭터)
; 목표 없으면 스킬 해제
IF 목표 < 0
	CALL 총력전_스킬_공통_스킬취소(시전자)
	RETURN
ENDIF
; 대미지
대미지 = GETVAR_RAIDSTAT_SUM(시전자, "공격력") * 400
대미지 = DIVIDE_ROUND(대미지, 100)
CALL 총력전_처리_피격(대미지, 목표, 시전자)