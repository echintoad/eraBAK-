대상측 = !발동측
LOCAL:1 = RAND(3, 12)
FOR LOCAL, 0, LOCAL:1
	IF RAND:100 > 10
		CALL DECREASE_SOLDIER(대상세력, 대상부대, RAND(60, 140), 1)
	ELSE ; 아군 부대 대미지
		PRINTL 아군 데미지!
		CALL DECREASE_SOLDIER(발동세력, 발동부대, RAND(20, 50), 1)
		BATTLE_RATE_GRD:발동측 += 5
	ENDIF
NEXT

