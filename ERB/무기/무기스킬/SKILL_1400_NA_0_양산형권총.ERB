;-----------------------------------
; 양산형 무기는 총력전 스킬만?
;-----------------------------------
; 이름만, SP, BASE 상관 없음
@SKILL_1400_SP_0_NAME
RESULTS = 전진 기동

; #region == 총력전 ==
; 전진 기동
; 1인 버프 + 이동
@총력전_스킬_1400_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
; #DIM 가변
RETURN 2

; 2명?
@총력전_스킬_1400_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 대상을 이동후 명중률 (+20％) 공격속도 (+60％) 증가, 회피율 감소 (-10％)

@총력전_스킬_1400_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 대상
#DIM CONST 명중증가백분 = 20
#DIM CONST 공속증가 = 60
#DIM CONST 회피감소 = -10
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 발동 텍스트
CALL SKILL_1400_SP_0_NAME
sTmp = %총력전_이름:시전자% 스킬 시전:『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; 이동 + 버프 대상 처리
sTmp = 버프 + 이동 대상 선택
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
sTmp = 버프만 원하면 캐릭터 선택후 선택 종료
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
CALL 총력전_시퀀스_이동(0)
대상 = RESULT
; 목표 없으면 스킬 해재
; 대상 0 이면 이동 하지 않았다 가정
IF 대상 < 0
	CALL 총력전_스킬_공통_스킬취소(시전자)
	RETURN
ENDIF
; 버프
CALL 총력전_상태효과_추가(대상, 시전자, 상효_종류_명중률백분율, 명중증가백분, 1, 총력전_방식_지속, 총력전_방식_턴, 2, 1400, 0)
CALL 총력전_상태효과_추가(대상, 시전자, 상효_종류_공격속도, 공속증가, 1, 총력전_방식_지속, 총력전_방식_턴, 2, 1400, 1)
CALL 총력전_상태효과_추가(대상, 시전자, 상효_종류_회피율백분율, 회피감소, 0, 총력전_방식_지속, 총력전_방식_턴, 2, 1400, 2)
; 텍스트 추가
sTmp = 2턴간 %조사처리(총력전_이름:대상, "의")% 명중률 ({명중증가백분}％) 공격 속도 ({공속증가}％) 증가, 회피율 감소 ({회피감소}％)
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY
