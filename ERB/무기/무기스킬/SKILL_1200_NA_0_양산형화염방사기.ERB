;-----------------------------------
; 양산형 무기는 총력전 스킬만?
;-----------------------------------
; 이름만, SP, BASE 상관 없음
@SKILL_1200_SP_0_NAME
RESULTS = Control Burn

; #region == 총력전 ==
; Control Burn
; 유탄일발 + 아플지도몰라
@총력전_스킬_1200_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
; #DIM 가변
RETURN 4

@총력전_스킬_1200_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 1범위 적에게 대미지 (공격력 100％ x2) 3턴간 지속 대미지 부여 (공격력 40％)

@총력전_스킬_1200_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 주목표
#DIM DYNAMIC 범위목표, 총력전_캐릭터수
#DIM DYNAMIC 대미지
#DIM DYNAMIC 지속대미지
#DIM DYNAMIC 공격명중
#DIM DYNAMIC iTmp, 2
#DIMS DYNAMIC sTmp

; 발동 텍스트
CALL SKILL_1200_SP_0_NAME
sTmp = %총력전_이름:시전자% 스킬 시전:『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; 목표 처리
CALL 총력전_시퀀스_목표선택(주목표, 0, 총력전_선택_캐릭터)
; 목표 없으면 스킬 해재
IF 주목표 < 0
	CALL 총력전_스킬_공통_스킬취소(시전자)
	RETURN
ENDIF
; 범위로 변경, 적팀 1 이상이 되면 수정 필요
CALL 총력전_목표_범위(범위목표, 주목표, 1)
; 대미지
대미지 = GETVAR_RAIDSTAT_SUM(시전자, "공격력") * 100
대미지 = DIVIDE_ROUND(대미지, 100)
지속대미지 = GETVAR_RAIDSTAT_SUM(시전자, "공격력") * 40
지속대미지 = DIVIDE_ROUND(지속대미지, 100)
FOR iTmp, 0, 총력전_캐릭터수
	SIF 범위목표:iTmp < 0
		BREAK
	공격명중 = 0
	FOR iTmp:1, 0, 2
		CALL 총력전_처리_피격(대미지, 범위목표:iTmp, 시전자)
		공격명중 = MAX(공격명중, RESULT)
	NEXT
	; 명중시? 지속 대미지?
	IF 공격명중 == 1
		CALL 총력전_상태효과_추가_텍스트(범위목표:iTmp, 시전자, 상효_종류_대미지, 지속대미지, 0, 총력전_방식_턴, 총력전_방식_턴, 3, 1200)
	ENDIF
NEXT
