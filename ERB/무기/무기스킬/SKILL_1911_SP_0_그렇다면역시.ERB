;발동 텍스트를 오바라이드 하고 싶을 때에.
;「아무개의 스킬 발동!   00했다!」의 「00했다!」의 부분을 실장하고 싶은 경우는,
;이것이 아니고 INVOKE로 쓰면 좋습니다.
;@SKILL_1911_SP_0_INVOKE_TEXT(발동자, 스킬, 장르)
;#DIM 발동자
;#DIM 스킬
;#DIMS 장르

;효과를 여기에 기술
@SKILL_1911_SP_0_INVOKE(발동자, 발동번호, 발동측, 발동세력, 발동부대, 대상세력, 대상부대)
#DIM 발동자
#DIM 발동번호
#DIM 스킬
#DIMS 장르
#DIM 발동측
#DIM 발동세력
#DIM 발동부대
#DIM 대상측
#DIM 대상세력
#DIM 대상부대

#DIMS DYNAMIC mobName
#DIM DYNAMIC iTmp, 7
대상측 = !발동측


mobName = "헬멧단"
iTmp:0 = ABL:발동자:무투 ; 무투
TIMES iTmp:0, 0.8
iTmp:1 = ABL:발동자:방위 ; 방위
TIMES iTmp:1, 0.8
iTmp:2 = MIN(ABL:발동자:지략 / 2, 80) ; 지략
SELECTCASE RAND:3
	CASE 0 ; SG
		mobName = %mobName% (SG)
		TIMES iTmp:0, 0.5
		TIMES iTmp:1, 1.5
	CASE 1 ; AR
		mobName = %mobName% (AR)
	CASEELSE ; SR
		mobName = %mobName% (SR)
		TIMES iTmp:0, 1.5
		TIMES iTmp:1, 0.5
ENDSELECT
PRINTFORML %조사처리(ANAME(발동자), "는")% %mobName%을 호출했다!
CALL BATTLE_ADD_MOB(발동측, 발동부대 >= 0, mobName, iTmp:0, iTmp:1, iTmp:2, 10, 0, 10, 10)

