; #region == 총력전 ==
@총력전_스킬_1427_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
RETURN 4

@총력전_스킬_1427_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 모든 적에게 대미지 (3명 이하 공격력 32％ x2 + 51％) (4~6명 공격력 38％ x2 + 62％) (7명 이상 공격력 45％ x2 + 74％), 명중시 3턴간 적의 방어력 감소 (-15％)

@총력전_스킬_1427_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 목표, 총력전_캐릭터수
#DIM DYNAMIC 적수
#DIM DYNAMIC 대미지, 2
#DIM DYNAMIC 공격명중
#DIM CONST 방감수치 = -15
#DIM DYNAMIC iTmp, 2
#DIMS DYNAMIC sTmp, 3

; 발동 텍스트
sTmp:0 = 「우후후. 아~무것도 하지 않았답니다? 저는요.」
sTmp:1 = 「절경~ 절경이로세~」
sTmp:2 = 「그럼, 균형을 맞춰볼까요?」
CALL SKILL_1427_SP_0_NAME
CALL 총력전_스킬_공통_발동텍스트(시전자, 75, RESULTS, sTmp)
; 목표 처리
CALL 총력전_목표_전체(목표, 1)
; 목표 없으면 스킬 해재
IF 목표 < 0
	CALL 총력전_스킬_공통_스킬취소(시전자)
	RETURN
ENDIF
; 적 수 카운팅
FOR iTmp, 0, 총력전_캐릭터수
	SIF 목표:iTmp < 0
		BREAK
	적수 ++
NEXT
; 대미지
SELECTCASE 적수
	CASE IS <= 3
		iTmp:0 = 32
		iTmp:1 = 51
	CASE IS <= 6
		iTmp:0 = 38
		iTmp:1 = 62
	CASEELSE
		iTmp:0 = 45
		iTmp:1 = 74
ENDSELECT
대미지:0 = GETVAR_RAIDSTAT_SUM(시전자, "공격력") * iTmp:0
대미지:0 = DIVIDE_ROUND(대미지:0, 100)
대미지:1 = GETVAR_RAIDSTAT_SUM(시전자, "공격력") * iTmp:1
대미지:1 = DIVIDE_ROUND(대미지:1, 100)
FOR iTmp, 0, 총력전_캐릭터수
	SIF 목표:iTmp < 0
		BREAK
	공격명중 = 0
	FOR iTmp:1, 0, 2
		CALL 총력전_처리_피격(대미지:0, 목표:iTmp, 시전자)
		공격명중 = MAX(공격명중, RESULT)
	NEXT
	CALL 총력전_처리_피격(대미지:1, 목표:iTmp, 시전자)
	공격명중 = MAX(공격명중, RESULT)
	; 명중시 방어 감소
	IF 공격명중 >= 1
		CALL 총력전_상태효과_추가_텍스트(목표:iTmp, 시전자, 상효_종류_방어력백분율, 방감수치, 0, 총력전_방식_지속, 총력전_방식_턴, 3, 1427)
	ENDIF
NEXT
