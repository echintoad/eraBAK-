;-----------------------------------
; 양산형 무기는 총력전 스킬만?
;-----------------------------------
; 이름만, SP, BASE 상관 없음
@SKILL_1900_SP_0_NAME
RESULTS = BREACH

; #region == 총력전 ==
@총력전_스킬_1900_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
; #DIM 가변
RETURN 3

@총력전_스킬_1900_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 이동후 3턴간 자신에게 보호막 부여 (최대체력 20％)

@총력전_스킬_1900_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 보호막양
; #DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 발동 텍스트
CALL SKILL_1900_SP_0_NAME
sTmp = %총력전_이름:시전자% 스킬 시전:『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; 이동
CALL 총력전_시퀀스_이동_시전자(시전자)
; 보호막
보호막양 = GETVAR_RAIDSTAT_SUM(시전자, "최대체력") * 20
보호막양 = DIVIDE_ROUND(보호막양, 100)
CALL 총력전_상태효과_추가_텍스트(시전자, 시전자, 상효_종류_보호막, 보호막양, 1, 총력전_방식_지속, 총력전_방식_턴, 3, 1900)
