;-----------------------------------
; 양산형 무기는 총력전 스킬만?
;-----------------------------------
; 이름만, SP, BASE 상관 없음
@SKILL_1500_SP_0_NAME
RESULTS = 제압 사격

; #region == 총력전 ==
; 전진 기동
; 1인 버프 + 이동
@총력전_스킬_1500_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
; #DIM 가변
RETURN 5

@총력전_스킬_1500_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 위치 지정, 2턴 동안 턴 종료시 1범위 대미지 (공격력 90％x2), 명중시 2턴 동안 명중률 감소 (-15％)

@총력전_스킬_1500_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 위치
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 발동 텍스트
CALL SKILL_1500_SP_0_NAME
sTmp = %총력전_이름:시전자% 스킬 시전:『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; 목표 처리
CALL 총력전_시퀀스_목표선택(위치, 0, 총력전_선택_전체)
; 추가 텍스트
sTmp = 사격 준비 완료
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY
; 사격 카운터
CALL 총력전_카운터_추가(시전자, 시전자, 총력전_방식_턴, 총력전_방식_턴, 2, 1500, 0)
; 위치 기록
총력전_스킬_위치:시전자:iTmp = 위치
총력전_스킬_범위:시전자:iTmp = 1


; #region == 카운터 ==
@총력전_스킬_1500_0_카운터_증가(캐릭터, 대상, 카운터번호, 증가양)
#DIM 캐릭터
#DIM 대상
#DIM 카운터번호
#DIM 증가양

#DIM DYNAMIC 위치
#DIM DYNAMIC 범위목표, 총력전_캐릭터수
#DIM DYNAMIC 대미지
#DIM DYNAMIC 공격명중
#DIM DYNAMIC iTmp, 2
#DIMS DYNAMIC sTmp

; 군중제어 확인?
; 발동 텍스트
CALL SKILL_1500_SP_0_NAME
sTmp = %총력전_이름:캐릭터%『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY
; 카운터 1번 양에 위치 기록 가져오기
CALL 총력전_카운터_검색_스킬번호(캐릭터, 1500, 1)
위치 = 총력전_카운터_증가양:캐릭터:RESULT
; 범위로 변경, 적팀 1 이상이 되면 수정 필요
CALL 총력전_목표_범위(범위목표, 위치, 1)
; 대미지
대미지 = GETVAR_RAIDSTAT_SUM(캐릭터, "공격력") * 90
대미지 = DIVIDE_ROUND(대미지, 100)
FOR iTmp, 0, 총력전_캐릭터수
	SIF 범위목표:iTmp < 0
		BREAK
	공격명중 = 0
	FOR iTmp:1, 0, 2
		CALL 총력전_처리_피격(대미지, 범위목표:iTmp, 캐릭터)
		공격명중 = MAX(공격명중, RESULT)
	NEXT
	IF 공격명중
		CALL 총력전_상태효과_추가_텍스트(범위목표:iTmp, 캐릭터, 상효_종류_명중률백분율, -15, 0, 총력전_방식_지속, 총력전_방식_턴, 2, 1500)
	ENDIF
NEXT

@총력전_스킬_1500_0_카운터_종료(대상, 카운터번호)
#DIM 대상
#DIM 카운터번호
; 조준 제거
CALL 총력전_목표_조준_취소(대상)