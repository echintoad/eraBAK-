#DIM 스킬
#DIMS 장르
#DIM 발동측
#DIM 발동세력
#DIM 발동부대
#DIM 대상측
#DIM 대상세력
#DIM 대상부대
대상측 = !발동측
; 2인 이상
; DEBUGPRINTL 2016 시전
LOCAL = BATTLE_COMMANDER_NUM:발동측
IF LOCAL > 1
	; DEBUGPRINTFORML 발동측 지휘수 {LOCAL}
	COMBAT_SKILL_TARGET = RAND:(LOCAL - 1)
	; DEBUGPRINTFORML RAND RESULT = {COMBAT_SKILL_TARGET}
	; 시전자 제외
	IF BATTLE_COMMANDER:발동측:COMBAT_SKILL_TARGET == 발동자
		COMBAT_SKILL_TARGET = (COMBAT_SKILL_TARGET + 1) % (LOCAL - 1)
	ENDIF
	; DEBUGPRINTFORML 목표 {COMBAT_SKILL_TARGET}, {BATTLE_COMMANDER:발동측:COMBAT_SKILL_TARGET}
	RETURN 1
ENDIF
; 없으면 시전 취소
RETURN 0

