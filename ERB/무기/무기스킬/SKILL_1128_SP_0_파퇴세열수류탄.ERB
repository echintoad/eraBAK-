#DIM 대상부대
대상측 = !발동측
RETURN 1

;발동 텍스트를 오바라이드 하고 싶을 때에.
;「아무개의 스킬 발동!   00했다!」의 「00했다!」의 부분을 실장하고 싶은 경우는,
;이것이 아니고 INVOKE로 쓰면 좋습니다.
;@SKILL_1128_SP_0_INVOKE_TEXT(발동자, 스킬, 장르)
;#DIM 발동자
;#DIM 스킬
;#DIMS 장르

;효과를 여기에 기술
@SKILL_1128_SP_0_INVOKE(발동자, 발동번호, 발동측, 발동세력, 발동부대, 대상세력, 대상부대)
#DIM 발동자
#DIM 발동번호
#DIM 스킬
#DIMS 장르
#DIM 발동측
#DIM 발동세력
#DIM 발동부대
#DIM 대상측
#DIM 대상세력
#DIM 대상부대
대상측 = !발동측
PRINTFORML %ANAME(BATTLE_COMMANDER:대상측:COMBAT_SKILL_TARGET)%의 무투와 방위가 저하했다!
; 캐릭터 수 비례, 적을수록 효과 증가
; 0.97 ~ 0.90
LOCAL = MAX(BATTLE_COMMANDER_NUM:발동측, 1) + MAX(BATTLE_COMMANDER_NUM:대상측, 1)
; DEBUGPRINTFORML 세열수류탄 LOCAL={LOCAL}
SELECTCASE LOCAL
	CASE 2
		LOCAL:1 = 87
	CASE 3
		LOCAL:1 = 91
	CASE 4
		LOCAL:1 = 94
	CASE 5
		LOCAL:1 = 96
	CASE 6
		LOCAL:1 = 98
	CASEELSE
		DEBUGPRINTL 파퇴:세열수류탄 SKILL_1128_SP_0_INVOKE 확인
		DEBUGPRINTFORML LOCAL:{LOCAL}
		LOCAL:1 = 98
ENDSELECT
BATTLE_무투:대상측:COMBAT_SKILL_TARGET = DIVIDE_ROUND(BATTLE_무투:대상측:COMBAT_SKILL_TARGET * LOCAL:1, 100)
BATTLE_방위:대상측:COMBAT_SKILL_TARGET = DIVIDE_ROUND(BATTLE_방위:대상측:COMBAT_SKILL_TARGET * LOCAL:1, 100)

@SKILL_1128_SP_0_EXPLANATION
RESULTS = 적한사람 무투와 방위를 저하시킨다. 캐릭터 수가 적을 때 효과 증가.

@SKILL_1128_SP_0_CANT_TELL

