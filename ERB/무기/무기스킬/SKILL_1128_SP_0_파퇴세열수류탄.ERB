; RETURN 1000
RETURN 125


; #region == 총력전 ==
@총력전_스킬_1128_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
; #DIM 가변
RETURN 3

; 적에게 대미지, 지속 대미지 수만큼 추가 대미지 (최대 3), 지속 대미지 효과 증가.
; alt.opt.1 추가 코스트 회복?
@총력전_스킬_1128_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 적에게 대미지 (공격력 348％), 지속 대미지 수만큼 추가 대미지 (공격력 77％) (최대 3), 지속 대미지 효과 증가 (+10％).

@총력전_스킬_1128_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 목표
#DIM DYNAMIC 대미지
#DIM DYNAMIC 지속대미지수
#DIM DYNAMIC 공격명중
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp, 3

; 발동 텍스트
sTmp:0 = 「하앗! 일격필살!」
sTmp:1 = 「에잇! 일점필중!」
sTmp:2 = 「발본색원!」
CALL SKILL_1128_SP_0_NAME
CALL 총력전_스킬_공통_발동텍스트(시전자, 94, RESULTS, sTmp)
; 목표 처리
CALL 총력전_시퀀스_목표선택(목표, 0, 총력전_선택_캐릭터)
; 목표 없으면 스킬 해제
IF 목표 < 0
	CALL 총력전_스킬_공통_스킬취소(시전자)
	RETURN
ENDIF
; 대미지
대미지 = GETVAR_RAIDSTAT_SUM(시전자, "공격력") * 348
대미지 = DIVIDE_ROUND(대미지, 100)
CALL 총력전_처리_피격(대미지, 목표, 시전자)
공격명중 = RESULT
; 목표 지속 대미지 수 확인
FOR iTmp, 0, 총력전_상태효과수
	SIF 총력전_상효_종류:목표:iTmp == 0
		BREAK
	; 총력전_상효_긍부정 확인 추가?
	IF 총력전_상효_종류:목표:iTmp == 상효_종류_대미지 && 총력전_상효_소비방식_0:목표:iTmp == 총력전_방식_턴
		; 카운트 증가
		지속대미지수 ++
	ENDIF
NEXT
; 지속 대미지 있으면
IF 지속대미지수 >= 1
	; 추가 텍스트
	sTmp = 『파퇴:세열수류탄』추가 공격!
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	; 최대 3회
	지속대미지수 = MIN(지속대미지수, 3)
	대미지 = GETVAR_RAIDSTAT_SUM(시전자, "공격력") * 77
	대미지 = DIVIDE_ROUND(대미지, 100)
	FOR LOCAL, 0, 지속대미지수
		CALL 총력전_처리_피격(대미지, 목표, 시전자)
		공격명중 = MAX(공격명중, RESULT)
	NEXT
ENDIF
; 명중시 지속 대미지 증가
IF 공격명중 == 1
	FOR iTmp, 0, 총력전_상태효과수
		SIF 총력전_상효_종류:목표:iTmp == 0
			BREAK
		IF 총력전_상효_종류:목표:iTmp == 상효_종류_대미지 && 총력전_상효_소비방식_0:목표:iTmp == 총력전_방식_턴
			; 지속 대미지 증가
			; DEBUGPRINTFORML 지속 대미지 {총력전_상효_양:목표:iTmp} ->
			총력전_상효_양:목표:iTmp += DIVIDE_ROUND(총력전_상효_양:목표:iTmp * 10, 100)
			; DEBUGPRINTFORM {총력전_상효_양:목표:iTmp}
		ENDIF
	NEXT
ENDIF

