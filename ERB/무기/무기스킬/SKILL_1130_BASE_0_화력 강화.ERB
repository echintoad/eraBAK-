; #region == 총력전 ==
@총력전_스킬_1130_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
; #DIM 가변
RETURN 3

@총력전_스킬_1130_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 5턴간 공격력 (+15％) 치명타 (+40) 치명 대미지 (+30) 증가, 시전자에게 최대 체력의 10％ 만큼 대미지. 2턴간 『드론소환:교차사격』시전, 무작위 적에게 대미지 (공격력 53％ x3). 전투 당 1회 체력이 20％ 이하 시 불사 (3턴)
; RESULTS = 적에게 치명 불가 대미지 (공격력 420％x2 + 560％)

; 총력전 시작시 시전
; 침착한 호흡
; 퇴각 유에는 나중에 추가?
@총력전_스킬_1130_초기(시전자)
#DIM 시전자

#DIMS DYNAMIC sTmp

; 카운터(무적용) 추가
CALL 총력전_카운터_추가(시전자, 시전자, 총력전_방식_피격양, 총력전_방식_지속, 1, 1130, 0)
; 텍스트 추가
sTmp = %총력전_이름:시전자%『침착한 호흡』추가
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
sTmp = 1회 체력 20％ 이하 시 3턴동안 불사 발동.
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY

@총력전_스킬_1130_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 피해
#DIM CONST 공격증가 = 15
#DIM CONST 치명증가 = 40
#DIM CONST 치댐증가 = 30
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 발동 텍스트
CALL SKILL_1130_BASE_0_NAME
sTmp = %총력전_이름:시전자% 스킬 시전:『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
iTmp = 총력전_ID:시전자
IF iTmp >= 0 && NO:iTmp == 142
	; 쿠로코일 경우
	SELECTCASE RAND:3
		CASE 0
			sTmp = 「나한테…?」
			CALL 총력전_UI_텍스트_추가(sTmp)
			sTmp = 「좋아, 맡겨둬.」
		CASE 1
			sTmp = 「목표는 전방.」
		CASEELSE
			sTmp = 「화력 지원, 시작한다.」
	ENDSELECT
	CALL 총력전_UI_텍스트_추가(sTmp)
ENDIF
; CALL 총력전_스킬_공통_발동텍스트(시전자, 137, "화력 강화", sTmp)
; 버프
CALL 총력전_상태효과_추가(시전자, 시전자, 상효_종류_공격력백분율, 공격증가, 1, 총력전_방식_지속, 총력전_방식_턴, 5, 1130, 0)
CALL 총력전_상태효과_추가(시전자, 시전자, 상효_종류_치명타, 치명증가, 1, 총력전_방식_지속, 총력전_방식_턴, 5, 1130, 1)
CALL 총력전_상태효과_추가(시전자, 시전자, 상효_종류_치명타대미지, 치댐증가, 1, 총력전_방식_지속, 총력전_방식_턴, 5, 1130, 2)
; 텍스트 추가
sTmp = 3턴간 %조사처리(총력전_이름:시전자, "의")% 공격력 (+{공격증가}％), 치명타 (+{치명증가}) 치명 대미지 (+{치댐증가}) 증가.
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY
; 시전자 피해
피해 = GETVAR_RAIDSTAT_SUM(시전자, "최대체력") * 10
피해 = DIVIDE_ROUND(피해, 100)
CALL 총력전_처리_피격(피해, 시전자, -1, 0, 0, 0)
; 드론소환: 교차사격 카운터 추가
CALL 총력전_카운터_추가(시전자, 시전자, 총력전_방식_턴, 총력전_방식_턴, 2, 1130, 1)


; #region == 카운터 ==
; 무적
@총력전_스킬_1130_0_카운터_증가(캐릭터, 대상, 카운터번호, 증가양)
#DIM 캐릭터
#DIM 대상
#DIM 카운터번호
#DIM 증가양

#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 캐릭터 체력 20% 이상 OR 0 이면 무시
iTmp = GETVAR_RAIDSTAT_SUM(캐릭터, "최대체력") * 20
iTmp = DIVIDE_ROUND(iTmp, 100)
IF 총력전_체력:캐릭터 <= 0 || 총력전_체력:캐릭터 > iTmp
	RETURN
ENDIF

; 발동 텍스트
sTmp = 『침착한 호흡』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
CALL 총력전_상태효과_추가_텍스트(캐릭터, 캐릭터, 상효_종류_불사, 1, 1, 총력전_방식_지속, 총력전_방식_턴, 3, 1113, 3)
; 카운터 제거
CALL 총력전_카운터_제거(캐릭터, 카운터번호)

; 드론소환: 교차사격
@총력전_스킬_1130_1_카운터_증가(캐릭터, 대상, 카운터번호, 증가양)
#DIM 캐릭터
#DIM 대상
#DIM 카운터번호
#DIM 증가양

#DIM DYNAMIC 목표
#DIM DYNAMIC 대미지
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 발동 텍스트
sTmp = 『드론소환:교차사격』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY
; 목표 처리
CALL 총력전_목표_무작위(1)
목표 = RESULT
IF 목표 == -1
	RETURN
ENDIF
; 대미지
대미지 = GETVAR_RAIDSTAT_SUM(캐릭터, "공격력") * 53
대미지 = DIVIDE_ROUND(대미지, 100)
FOR iTmp, 0, 3
	CALL 총력전_처리_피격(대미지, 목표, 캐릭터)
NEXT

@총력전_스킬_1130_1_카운터_종료(대상, 카운터번호)
#DIM 대상
#DIM 카운터번호

#DIMS DYNAMIC sTmp

CALL 총력전_카운터_제거(대상, 카운터번호)
sTmp = 『드론소환: 교차사격』종료
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY