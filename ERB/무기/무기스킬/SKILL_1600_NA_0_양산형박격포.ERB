;-----------------------------------
; 양산형 무기는 총력전 스킬만?
;-----------------------------------
; 이름만, SP, BASE 상관 없음
@SKILL_1600_SP_0_NAME
RESULTS = 진지폭격

; #region == 총력전 ==
@총력전_스킬_1600_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
; #DIM 가변
RETURN 4

; 없으면 기본, 2 로
@총력전_스킬_1600_쿨다운(가변)
#DIM 가변
RETURN 3

@총력전_스킬_1600_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 1턴 준비 후 (공격 속도 -100) 모든 적에게 대미지 (공격력 90％ x2)

@총력전_스킬_1600_발동(시전자)
#DIM 시전자

#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 발동 텍스트
CALL SKILL_1600_SP_0_NAME
sTmp = %총력전_이름:시전자% 스킬 시전:『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; 디버프 추가
CALL 총력전_상태효과_추가_텍스트(시전자, 시전자, 상효_종류_공격속도, -100, 0, 총력전_방식_지속, 총력전_방식_턴, 2, 1600)
; 카운터 추가
CALL 총력전_카운터_추가(시전자, 시전자, 총력전_방식_지속, 총력전_방식_턴, 2, 1600)

; #region == 카운터 ==
@총력전_스킬_1600_0_카운터_종료(캐릭터, 카운터번호)
#DIM 캐릭터
#DIM 카운터번호

#DIM DYNAMIC 목표, 총력전_캐릭터수
#DIM DYNAMIC 대미지
#DIM DYNAMIC iTmp, 2
#DIMS DYNAMIC sTmp

; 군중제어 확인
; 발동 텍스트
CALL SKILL_1600_SP_0_NAME
sTmp = %총력전_이름:캐릭터%『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY
; 목표 처리
CALL 총력전_목표_전체(목표, 1)
; 대미지
대미지 = GETVAR_RAIDSTAT_SUM(캐릭터, "공격력") * 90
대미지 = DIVIDE_ROUND(대미지, 100)
FOR iTmp, 0, 총력전_캐릭터수
	SIF 목표:iTmp < 0
		BREAK
	FOR iTmp:1, 0, 2
		CALL 총력전_처리_피격(대미지, 목표:iTmp, 캐릭터)
	NEXT
NEXT
; 카운터 제거
CALL 총력전_카운터_제거(캐릭터, 카운터번호)