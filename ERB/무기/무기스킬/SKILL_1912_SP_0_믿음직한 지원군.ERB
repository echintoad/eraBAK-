; #region == 총력전 ==
@총력전_스킬_1912_코스트(시전자)
#DIM 시전자 ; 코스트 당 대미지 스킬 카운터 위해서
; #DIM 가변
RETURN 4

; @총력전_스킬_1912_쿨다운(가변)
; #DIM 가변
; RETURN 2

@총력전_스킬_1912_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 2범위 아군에게 3턴간 보호막 (치유력 240％), 2명 이동. 5턴 마다 2범위 아군 2턴간 공격속도 증가 (+20％)

@총력전_스킬_1912_초기(시전자)
#DIM 시전자
; 턴 카운터
CALL 총력전_카운터_추가(시전자, 시전자, 총력전_방식_턴, 총력전_방식_지속, 1, 1912, 0)

@총력전_스킬_1912_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 버프대상, 총력전_캐릭터수
#DIM DYNAMIC 보호막양
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp, 3

; 발동 텍스트
sTmp:0 = 「나도 해보고 싶네, 유빙 다이브.」
sTmp:1 = 「이리로 와.」
sTmp:2 = 「부딪히지 않게 조심해.」
CALL SKILL_1912_SP_0_NAME
CALL 총력전_스킬_공통_발동텍스트(시전자, 49, RESULTS, sTmp)
; 목표 처리
CALL 총력전_목표_범위(버프대상, 시전자, 0, 2)
; 보호막
보호막양 = GETVAR_RAIDSTAT_SUM(시전자, "치유력") * 240
보호막양 = DIVIDE_ROUND(보호막양, 100)
FOR iTmp, 0, 총력전_캐릭터수
	SIF 버프대상:iTmp < 0
		BREAK
	CALL 총력전_상태효과_추가_텍스트(버프대상:iTmp, 시전자, 상효_종류_보호막, 보호막양, 1, 총력전_방식_지속, 총력전_방식_턴, 3, 1912, 0)
NEXT
; 이동
FOR iTmp, 0, 2
	sTmp = 이동회수 ({iTmp} / 2)
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑) ; 칼라_파파랑?
	CALL 총력전_시퀀스_이동(0)
NEXT

; #region == 카운터 ==
@총력전_스킬_1912_0_카운터_증가(캐릭터, 대상, 카운터번호, 증가양)
#DIM 캐릭터
#DIM 대상
#DIM 카운터번호
#DIM 증가양

#DIM DYNAMIC 버프대상, 총력전_캐릭터수
#DIM DYNAMIC iTmp

총력전_카운터_증가양:캐릭터:카운터번호 += 증가양
; 5턴 마다 2범위 아군 2턴간 공격속도 증가 (+20％)
IF 총력전_카운터_증가양:캐릭터:카운터번호 >= 5
	총력전_카운터_증가양:캐릭터:카운터번호 = 0
	; 목표 처리
	CALL 총력전_목표_범위(버프대상, 캐릭터, 0, 2)
	; 공속 증가
	FOR iTmp, 0, 총력전_캐릭터수
		SIF 버프대상:iTmp < 0
			BREAK
		CALL 총력전_상태효과_추가_텍스트(버프대상:iTmp, 캐릭터, 상효_종류_공격속도, 20, 1, 총력전_방식_지속, 총력전_방식_턴, 2, 1912, 1)
	NEXT
ENDIF