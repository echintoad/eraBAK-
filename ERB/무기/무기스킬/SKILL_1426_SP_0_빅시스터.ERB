#DIM 대상세력
#DIM 대상부대
대상측 = !발동측
; 원호 행동
; BATTLE_SKILL_RATE:발동측:COMBAT_SKILL_TARGET += 10 ~ 20
; eraK 골드 탐지기
; LOCAL = RAND(1000, 3000)
; MONEY:(CFLAG:(발동자):소속) += LOCAL
; X ~ 2500
; 자금 확인
LOCAL:1 = MIN(MONEY:(CFLAG:(발동자):소속), 2500)
LOCAL:0 = LOCAL:1 / 6
; 소비 자금
LOCAL = RAND(LOCAL:0, LOCAL:1)
; 텍스트
LOCALS = %ANAME(BATTLE_COMMANDER:발동측:COMBAT_SKILL_TARGET)%
PRINTFORML {LOCAL}크레딧을 소비하여, %조사처리(LOCALS, "의")% 스킬 발동 확률을 올렸다!
; 소비 자금 비례 발동확률 증가
LOCAL = REMAP_CLAMP(LOCAL, 0, 2500, 10, 40)
BATTLE_SKILL_RATE:발동측:COMBAT_SKILL_TARGET += LOCAL


