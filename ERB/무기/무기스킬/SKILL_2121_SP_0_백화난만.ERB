RETURN 4

@총력전_스킬_2121_설명(시전자)
#DIM 시전자 ; 가변스킬 설명 위해서
RESULTS = 스킬 발동중 치명타 (+30) 증가, 적에게 대미지 (공격력 120％ x3), 대상의 현재 체력 비율에 비례하여 (많을수록 증가) 최대 3배까지 대미지 상승.

; 카운터 추가
; @총력전_스킬_2121_초기(시전자)
; #DIM 시전자
; CALL 총력전_카운터_추가(시전자, 시전자, 총력전_방식_턴, 총력전_방식_지속, 1, 2121)

@총력전_스킬_2121_발동(시전자)
#DIM 시전자

#DIM DYNAMIC 목표
#DIM DYNAMIC 대미지
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 발동 텍스트
CALL SKILL_2121_SP_0_NAME
sTmp = %총력전_이름:시전자% 스킬 시전:『%RESULTS%』
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
iTmp = 총력전_ID:시전자
IF iTmp >= 0
	; 쿠즈노하
	IF NO:iTmp == 88
	ENDIF
	; 나구사
	IF NO:iTmp == 131
		SELECTCASE RAND:3
			CASE 0
				sTmp = 「그것이 모두를 지킬 수 있는 방법이라면…!」
			CASE 1
				sTmp = 「이것이 내가 할 수 있는 최선이니까.」
			CASEELSE
				sTmp = 「물러서지 않겠어!」
		ENDSELECT
		CALL 총력전_UI_텍스트_추가(sTmp)
	ENDIF
ENDIF
; 목표 처리
CALL 총력전_시퀀스_목표선택(목표, 0, 총력전_선택_캐릭터)
; 목표 없으면 스킬 해재
IF 목표 < 0
	CALL 총력전_스킬_공통_스킬취소(시전자)
	RETURN
ENDIF
; 버프
CALL 총력전_상태효과_추가_텍스트(시전자, 시전자, 상효_종류_치명타, 30, 1, 총력전_방식_스킬, 총력전_방식_스킬, 1, 2121, 0)
; 체력 비례 대미지 증가
iTmp = REMAP_CLAMP(총력전_체력:목표, 0, GETVAR_RAIDSTAT_SUM(목표, "최대체력"), 100, 300)
대미지 = GETVAR_RAIDSTAT_SUM(시전자, "공격력") * 120 * iTmp
대미지 = DIVIDE_ROUND(대미지:0, 10000)
FOR iTmp, 0, 3
	CALL 총력전_처리_피격(대미지, 목표, 시전자)
NEXT