;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_1104(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 비에르나시치
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1104(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 97
	스탯증가:0 = 15 ; 무투
	스탯증가:1 = 10 ; 방위
ELSE
	스탯증가:0 = 7 ; 무투
	스탯증가:1 = 5 ; 방위
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1104
	CALL SKILL_LEARN(대상, 스킬_장르_BASE, 2104, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_BASE, "여러분, 제 말에 귀 기울여 주세요!")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1104(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 97
	RESULT:총력전_무기_최대체력 = 200
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_명중률 = 15
	RESULT:총력전_무기_회피율 = 5
	RESULT:총력전_무기_치명타 = 5
ELSE
	RESULT:총력전_무기_최대체력 = 100
	RESULT:총력전_무기_공격력 = 5
	RESULT:총력전_무기_명중률 = 7
	RESULT:총력전_무기_회피율 = 2
	RESULT:총력전_무기_치명타 = 2
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1104(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"토모에: 최대체력: <200> 공격력: <10> 명중률: <15> 회피율: <5> 치명타: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <100> 공격력: <5> 명중률: <7> 회피율: <2> 치명타: <2>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"토모에: 무투: <15> 방위: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <7> 방위: <5>", "L", 칼라_주의)
ENDIF

@무기_설명_1104
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2104_BASE_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2104_BASE_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN