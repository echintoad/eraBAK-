;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_132(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 23
	RESULTS = 메)유니크 아이디어
ELSE 		 ;123456789 123456789 123456789
	RESULTS = 유니크 아이디어(메이드)
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_132(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 4
IF 대상 >= 0 && NO:대상 == 33
	스탯증가:0 = 20 ; 무투
	스탯증가:1 = 10 ; 요리
	스탯증가:2 = 5 ; 가창
ELSE
	스탯증가:0 = 10 ; 무투
	스탯증가:1 = 5 ; 요리
	스탯증가:2 = 2 ; 가창
ENDIF
스탯증가:3 = -5 ; 지략
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:요리 += 스탯증가:1 * 탈착
ABL:대상:가창 += 스탯증가:2 * 탈착
ABL:대상:지략 += 스탯증가:3 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 132
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1132, 0)
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "버추얼 메이드 웨폰!")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_132(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 33
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_치명대미지 = 15
ELSE
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_치명대미지 = 7
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_132(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"모모이: 공격력: <20> 치명대미지: <15>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <10> 치명대미지: <7>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"모모이: 무투: <20> 요리: <10> 가창: <5> 지략: <-5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <10> 요리: <5> 가창: <2> 지략: <-5>", "L", 칼라_주의)
ENDIF

@무기_설명_132
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1132_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1132_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN