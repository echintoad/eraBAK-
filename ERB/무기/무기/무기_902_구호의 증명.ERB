;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_902(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 구호의 증명
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_902(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 65
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 25 ; 방위
ELSE
	스탯증가:0 = 2 ; 무투
	스탯증가:1 = 12 ; 방위
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 902
	CALL SKILL_LEARN(대상, 스킬_장르_BASE, 1902, 0)
	; 무기사용가능:902 = 0
ELSEIF 탈착 == -1
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_BASE, "신념과 긍지")
	; 무기사용가능:902 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_902(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 65
	RESULT:총력전_무기_최대체력 = 700
	RESULT:총력전_무기_방어력 = 25
	RESULT:총력전_무기_치유력 = 40
ELSE
	RESULT:총력전_무기_최대체력 = 350
	RESULT:총력전_무기_방어력 = 12
	RESULT:총력전_무기_치유력 = 20
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_902(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"미네: 최대체력: <700> 방어력: <25> 치유력: <40>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <350> 방어력: <12> 치유력: <20>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"미네: 무투: <5> 방위: <25>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <2> 방위: <12>", "L", 칼라_주의)
ENDIF

@무기_설명_902
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1902_BASE_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1902_BASE_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <방위>", "L", 칼라_주의)
PRINTL 
RETURN