;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_131(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 9
	RESULTS = 바)S.타임
ELSEIF iLen > 0 && iLen < 16
	RESULTS = 바니)시크릿 타임
ELSE 		 ;123456789012345678901234567890
	RESULTS = 시크릿 타임(바니걸)
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_131(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 45
	스탯증가:0 = 20 ; 무투
	스탯증가:1 = 10 ; 가창
ELSE
	스탯증가:0 = 10 ; 무투
	스탯증가:1 = 5 ; 가창
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:가창 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 131
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1131, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "특수무장: 암기어")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_131(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 45
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_명중률 = 10
	RESULT:총력전_무기_회피율 = 10
	RESULT:총력전_무기_치명타 = 15
ELSE
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_명중률 = 5
	RESULT:총력전_무기_회피율 = 5
	RESULT:총력전_무기_치명타 = 7
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_131(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"토키: 공격력: <20> 명중률: <10> 회피율: <10> 치명타: <15>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <10> 명중률: <5> 회피율: <5> 치명타: <7>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"토키: 무투: <20> 가창: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <10> 가창: <5>", "L", 칼라_주의)
ENDIF

@무기_설명_131
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1131_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1131_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN