;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_101(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = Et Omnia Vanitas
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_101(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
; 아즈사
IF 대상 >= 0 && NO:대상 == 55
	스탯증가:0 = 25 ; 무투
ELSE
	스탯증가:0 = 12 ; 무투
ENDIF
; 공통 정치
스탯증가:1 = -5
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:정치 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 101
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1101, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "intulit mortem")
ENDIF

RETURN 탈착
;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_101(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
; 아즈사
IF 대상 >= 0 && NO:대상 == 55
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_치명타 = 8
	RESULT:총력전_무기_치명대미지 = 12
ELSE
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_치명타 = 4
	RESULT:총력전_무기_치명대미지 = 6
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_101(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"아즈사: 공격력: <20> 치명타 <8> 치명대미지: <12>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <10> 치명타 <4> 치명대미지: <6>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"아즈사: 무투: <25> 정치: <-5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <12> 정치: <-5>", "L", 칼라_주의)
ENDIF

@무기_설명_101
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1101_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1101_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <무투>", "L", 칼라_주의)
PRINTL 
RETURN