;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_127(iLen = 0)
#DIM DYNAMIC iLen
; 🙴|
; aa|
; ﹠|
IF iLen > 0 && iLen < 19
	RESULTS = 초콜릿N스트로베리
ELSE 		 ;123456789012345678901234567890
	RESULTS = 초콜릿 N 스트로베리
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_127(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 27
	스탯증가:0 = 10 ; 방위
	스탯증가:1 = 20 ; 가창
ELSE
	스탯증가:0 = 5 ; 방위
	스탯증가:1 = 10 ; 가창
ENDIF
; 스탯
ABL:대상:방위 += 스탯증가:0 * 탈착
ABL:대상:가창 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 127
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1127, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "게헨나의 셀러브리티!")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_127(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 27
	RESULT:총력전_무기_공격력 = 15
	RESULT:총력전_무기_명중률 = 10
	RESULT:총력전_무기_치명타 = 10
	RESULT:총력전_무기_치명대미지 = 5
ELSE
	RESULT:총력전_무기_공격력 = 7
	RESULT:총력전_무기_명중률 = 5
	RESULT:총력전_무기_치명타 = 5
	RESULT:총력전_무기_치명대미지 = 2
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_127(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"키라라: 공격력: <15> 명중률: <10> 치명타: <10> 치명대미지: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <7> 명중률: <5> 치명타: <5> 치명대미지: <2>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"키라라: 방위: <10> 가창: <20>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 방위: <5> 가창: <10>", "L", 칼라_주의)
ENDIF

@무기_설명_127
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1127_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1127_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN