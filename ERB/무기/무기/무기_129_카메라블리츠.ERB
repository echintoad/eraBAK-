;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_129(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 카메라블리츠

;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_129(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 137
	스탯증가:0 = 5 ; 지략
	스탯증가:1 = 10 ; 정치
	스탯증가:2 = 5 ; 가창
ELSE
	스탯증가:0 = 2 ; 지략
	스탯증가:1 = 5 ; 정치
	스탯증가:2 = 2 ; 가창
ENDIF
; 스탯
ABL:대상:지략 += 스탯증가:0 * 탈착
ABL:대상:정치 += 스탯증가:1 * 탈착
ABL:대상:가창 += 스탯증가:2 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 129
	CALL SKILL_LEARN(대상, 스킬_장르_BASE, 1129, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_BASE, "그게 정말 사실인가요?")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_129(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 137
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_명중률 = 20
ELSE
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_명중률 = 10
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_129(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"치아키: 공격력: <20> 명중률: <20>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <10> 명중률: <10>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"치아키: 지략: <5> 정치: <10> 가창: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 지략: <2> 정치: <5> 가창: <2>", "L", 칼라_주의)
ENDIF

@무기_설명_129
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1129_BASE_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1129_BASE_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
; 가창 비례?
CALL ICPRINT(@"영향 받는 능력치 : <정치>", "L", 칼라_주의)
PRINTL 
RETURN