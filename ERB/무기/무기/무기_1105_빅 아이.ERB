;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_1105(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 빅 아이
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1105(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 43
	스탯증가:0 = 35 ; 무투
ELSE
	스탯증가:0 = 17 ; 무투
ENDIF
스탯증가:1 = -10 ; 정치
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:정치 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1105
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 2105, 0)
	; 무기사용가능:1105 = 0
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 100
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "대상, 삭제")
	; 무기사용가능:1105 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1105(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 43
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_명중률 = 5
	RESULT:총력전_무기_치명타 = 10
	RESULT:총력전_무기_치명대미지 = 30
ELSE
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_명중률 = 2
	RESULT:총력전_무기_치명타 = 5
	RESULT:총력전_무기_치명대미지 = 15
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1105(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"카린: 공격력: <20> 명중률: <5> 치명타: <10> 치명대미지: <30>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <10> 명중률: <2> 치명타: <5> 치명대미지: <15>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"카린: 무투: <35> 정치: <-10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <17> 정치: <-10>", "L", 칼라_주의)
ENDIF

@무기_설명_1105
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2105_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2105_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <무투>", "L", 칼라_주의)
PRINTL 
RETURN