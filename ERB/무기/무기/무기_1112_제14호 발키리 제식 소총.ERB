;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_1112(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 18
	RESULTS = 제14호 소총
ELSEIF iLen > 0 && iLen < 23
	RESULTS = 제14호 발키리 소총
ELSE		 ;123456789012345678901234567890
	RESULTS = 제14호 발키리 제식 소총
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1112(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 106
	스탯증가:0 = 5 ; 방위
	스탯증가:1 = 15 ; 지략
ELSE
	스탯증가:0 = 2 ; 방위
	스탯증가:1 = 7 ; 지략
ENDIF
스탯증가:2 = -10 ; 야심
; 스탯
ABL:대상:방위 += 스탯증가:0 * 탈착
ABL:대상:지략 += 스탯증가:1 * 탈착
ABL:대상:야심 += 스탯증가:2 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1112
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 2112, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "일단은 달콤한 휴식부터")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1112(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 106
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_명중률 = 15
ELSE
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_명중률 = 7
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1112(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"후부키: 공격력: <20> 명중률: <15>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <10> 명중률: <7>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"후부키: 방위: <5> 지략: <15> 야심: <-10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 방위: <2> 지략: <7> 야심: <-10>", "L", 칼라_주의)
ENDIF

@무기_설명_1112
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2112_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2112_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN