;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_1002(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 16
	RESULTS = 급식부 type A
ELSEIF iLen > 0 && iLen < 23
	RESULTS = 급식부 총 type A
ELSE 		 ;123456789012345678901234567890
	RESULTS = 급식부 호신용 총 type A
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1002(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 21
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 10 ; 방위
	스탯증가:2 = 20 ; 요리
ELSE
	스탯증가:0 = 2 ; 무투
	스탯증가:1 = 5 ; 방위
	스탯증가:2 = 10 ; 요리
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착
ABL:대상:요리 += 스탯증가:2 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1002
	CALL SKILL_LEARN(대상, 스킬_장르_BASE, 2002, 0)
	; 무기사용가능:1002 = 0
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 100
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_BASE, "급식 시간!")
	; 무기사용가능:1002 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1002(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 21
	RESULT:총력전_무기_최대체력 = 200
	RESULT:총력전_무기_치유력 = 72
	RESULT:총력전_무기_치명대미지저항 = 10
ELSE
	RESULT:총력전_무기_최대체력 = 100
	RESULT:총력전_무기_치유력 = 36
	RESULT:총력전_무기_치명대미지저항 = 5
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1002(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"후우카: 최대체력: <200> 치유력: <72> 치명대미지저항: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <100> 치유력: <36> 치명대미지저항: <5>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"후우카: 무투: <5> 방위: <10> 요리: <20>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <2> 방위: <5> 요리: <10>", "L", 칼라_주의)
ENDIF

@무기_설명_1002
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2002_BASE_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2002_BASE_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <요리>", "L", 칼라_주의)
PRINTL 
RETURN