;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_109(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 서프라이즈 파티
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_109(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 4
IF 대상 >= 0 && NO:대상 == 42
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 5 ; 방위
	스탯증가:2 = 5 ; 지략
	스탯증가:3 = 5 ; 정치
ELSE
	스탯증가:0 = 2 ; 무투
	스탯증가:1 = 2 ; 방위
	스탯증가:2 = 2 ; 지략
	스탯증가:3 = 2 ; 정치
ENDIF
IF TALENT:대상:행운 == 1
	스탯증가:0 += 5
	스탯증가:1 += 5
	스탯증가:2 += 5
	스탯증가:3 += 5
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착
ABL:대상:지략 += 스탯증가:2 * 탈착
ABL:대상:정치 += 스탯증가:3 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 109
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1109, 0)
	; ; 무기사용가능:109 = 0
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 100
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "갈게!")
	; ; 무기사용가능:109 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_109(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 42
	RESULT:총력전_무기_최대체력 = 100
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_명중률 = 5
	RESULT:총력전_무기_회피율 = 10
	RESULT:총력전_무기_치명타 = 5
ELSE
	RESULT:총력전_무기_최대체력 = 50
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_명중률 = 2
	RESULT:총력전_무기_회피율 = 5
	RESULT:총력전_무기_치명타 = 2
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_109(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"아스나: 최대체력: <100> 공격력: <20> 명중률: <5> 회피율: <10> 치명타: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <50> 공격력: <10> 명중률: <2> 회피율: <5> 치명타: <2>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"아스나: 무투: <5> 방위: <5> 지략: <5> 정치: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <2> 방위: <2> 지략: <2> 정치: <2>", "L", 칼라_주의)
ENDIF

@무기_설명_109
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1109_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1109_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <무투>", "L", 칼라_주의)
SETCOLOR 칼라_선택불가
PRINT   · '행운' 소질이 있다면 무기 능력치가 2배로 적용된다.
RESETCOLOR
PRINTL 
RETURN