;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_429(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 19
	RESULTS = 무)절벽 위의 꽃
ELSE 		;12345678901234567890
	RESULTS = 절벽 위의 꽃(무장)
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_429(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 36
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 10 ; 방위
	스탯증가:2 = 25 ; 지략
ELSE
	스탯증가:0 = 2 ; 무투
	스탯증가:1 = 5 ; 방위
	스탯증가:2 = 12 ; 지략
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착
ABL:대상:지략 += 스탯증가:2 * 탈착


IF 탈착 == 1
	TALENT:대상:웨폰 = 429
	CALL SKILL_LEARN(대상, 스킬_장르_ESCAPE, 1429, 0)
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_ESCAPE, "실외용 휠체어랍니다?")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_429(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 36
	RESULT:총력전_무기_최대체력 = 500
	RESULT:총력전_무기_명중률 = 5
	RESULT:총력전_무기_치유력 = 40
ELSE
	RESULT:총력전_무기_최대체력 = 250
	RESULT:총력전_무기_명중률 = 2
	RESULT:총력전_무기_치유력 = 20
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_429(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"히마리: 최대체력: <500> 명중률: <5> 치유력: <40>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <250> 명중률: <2> 치유력: <20>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"히마리: 무투: <5> 방위: <10> 지략: <25>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <2> 방위: <5> 지략: <12>", "L", 칼라_주의)
ENDIF

@무기_설명_429
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1429_ESCAPE_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1429_ESCAPE_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN