;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_700(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 13
	RESULTS = 레일건
ELSE 		;12345678901234567890
	RESULTS = 양산형 레일건
ENDIF

;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_700(대상, 탈착)
#DIM 대상
#DIM 탈착
; 스탯
ABL:대상:방위 += 10 * 탈착
ABL:대상:정치 += 10 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 700
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
ENDIF

RETURN 탈착
;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_700(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
RESULT:총력전_무기_방어력 = 10
RESULT:총력전_무기_치명타저항 = 10

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_700(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"방어력: <10> 치명타저항: <10>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"방위: <10> 정치: <10>", "L", 칼라_주의)
ENDIF

@무기_설명_700
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL COLOR_PRINT(" 없음 ", 칼라_선택불가)
PRINTL 
RETURN