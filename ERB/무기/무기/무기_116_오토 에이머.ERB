;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_116(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 오토 에이머
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_116(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 1
IF 대상 >= 0 && NO:대상 == 38
	스탯증가:0 = 30 ; 지략
ELSE
	스탯증가:0 = 15 ; 지략
ENDIF
; 스탯
ABL:대상:지략 += 스탯증가:0 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 116
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1116, 0)
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "EMP 드론 전개")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_116(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 38
	RESULT:총력전_무기_최대체력 = 200
	RESULT:총력전_무기_공격력 = 15
	RESULT:총력전_무기_명중률 = 15
	RESULT:총력전_무기_군중제어강화 = 20
ELSE
	RESULT:총력전_무기_최대체력 = 100
	RESULT:총력전_무기_공격력 = 7
	RESULT:총력전_무기_명중률 = 7
	RESULT:총력전_무기_군중제어강화 = 10
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_116(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"하레: 최대체력: <200> 공격력: <15> 명중률: <15> 군중강화: <20>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <100> 공격력: <7> 명중률: <7> 군중강화: <10>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"하레: 지략: <30>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 지략: <15>", "L", 칼라_주의)
ENDIF

@무기_설명_116
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1116_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1116_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <지략>", "L", 칼라_주의)
PRINTL 
RETURN