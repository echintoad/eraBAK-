;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_1015(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 온고지신
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1015(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 1
IF 대상 >= 0 && NO:대상 == 93
	스탯증가:0 = 30 ; 요리
ELSE
	스탯증가:0 = 15 ; 요리
ENDIF
; 스탯
ABL:대상:요리 += 스탯증가:0 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1015
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 2015, 0)
	; 무기사용가능:1015 = 0
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 100
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "천하일미!")
	; 무기사용가능:1015 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1015(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 93
	RESULT:총력전_무기_최대체력 = 200
	RESULT:총력전_무기_치유력 = 65
ELSE
	RESULT:총력전_무기_최대체력 = 100
	RESULT:총력전_무기_치유력 = 32
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1015(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"루미: 최대체력: <200> 치유력: <65>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <100> 치유력: <32>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"루미: 요리: <30>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 요리: <15>", "L", 칼라_주의)
ENDIF

@무기_설명_1015
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2015_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2015_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <요리>", "L", 칼라_주의)
PRINTL 
RETURN