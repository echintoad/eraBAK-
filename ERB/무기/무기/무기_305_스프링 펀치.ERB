;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_305(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 스프링 펀치
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_305(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 100
	스탯증가:0 = 15 ; 방위
	스탯증가:1 = 15 ; 요리
ELSE
	스탯증가:0 = 7 ; 방위
	스탯증가:1 = 7 ; 요리
ENDIF
; 스탯
ABL:대상:방위 += 스탯증가:0 * 탈착
ABL:대상:요리 += 스탯증가:1 * 탈착


IF 탈착 == 1
	TALENT:대상:웨폰 = 305
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1305, 0)
	; 무기사용가능:305 = 0
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 100
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "시구레 특제 보틀 그레네이드")
	; 무기사용가능:305 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_305(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 100
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_명중률 = 10
	RESULT:총력전_무기_치명타 = 10
ELSE
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_명중률 = 5
	RESULT:총력전_무기_치명타 = 5
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_305(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"시구레: 공격력: <20> 명중률: <10> 치명타: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <10> 명중률: <5> 치명타: <5>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"시구레: 방위: <5> 요리: <25>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 방위: <2> 요리: <12>", "L", 칼라_주의)
ENDIF

@무기_설명_305
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1305_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1305_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <요리>", "L", 칼라_주의)
SETCOLOR 칼라_선택불가
PRINT   · 요리에 비례해 최소 횟수가 늘어난다.
RESETCOLOR
PRINTL 
RETURN