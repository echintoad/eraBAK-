;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_903(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 16
	RESULTS = 급식부 type B
ELSEIF iLen > 0 && iLen < 23
	RESULTS = 급식부 총 type B
ELSE 		 ;123456789012345678901234567890
	RESULTS = 급식부 호신용 총 type B
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_903(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 22
	스탯증가:0 = 10 ; 무투
	스탯증가:1 = 15 ; 방위
ELSE
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 7 ; 방위
ENDIF
스탯증가:2 = -5 ; 요리
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착
ABL:대상:요리 += 스탯증가:2 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 903
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1903, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "주리의 요리 시간!")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_903(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 22
	RESULT:총력전_무기_최대체력 = 200
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_명중률 = 15
ELSE
	RESULT:총력전_무기_최대체력 = 100
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_명중률 = 7
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_903(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"주리: 최대체력: <200> 공격력: <20> 명중률: <15>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <100> 공격력: <10> 명중률: <7>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"주리: 무투: <10> 방위: <15> 요리: <-5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <5> 방위: <7> 요리: <-5>", "L", 칼라_주의)
ENDIF

@무기_설명_903
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1903_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1903_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <요리>", "L", 칼라_주의)
SETCOLOR 칼라_선택불가
PRINT   · 요리가 낮을수록 강해진다. 횟수 변동 폭이 크다
RESETCOLOR
PRINTL 
RETURN