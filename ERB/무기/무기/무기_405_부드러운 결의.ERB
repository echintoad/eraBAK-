;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_405(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 부드러운 결의
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_405(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 82
	스탯증가:0 = 10 ; 방위
	스탯증가:1 = 15 ; 지략
ELSE
	스탯증가:0 = 5 ; 방위
	스탯증가:1 = 7 ; 지략
ENDIF
; 스탯
ABL:대상:방위 += 스탯증가:0 * 탈착
ABL:대상:지략 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 405
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1405, 0)
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "따끈따끈 꽃구경이에요")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_405(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 82
	RESULT:총력전_무기_최대체력 = 200
	RESULT:총력전_무기_명중률 = 15
	RESULT:총력전_무기_회피율 = 10
	RESULT:총력전_무기_치명타저항 = 5
	RESULT:총력전_무기_치명대미지저항 = 5
ELSE
	RESULT:총력전_무기_최대체력 = 100
	RESULT:총력전_무기_명중률 = 7
	RESULT:총력전_무기_회피율 = 5
	RESULT:총력전_무기_치명타저항 = 2
	RESULT:총력전_무기_치명대미지저항 = 2
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_405(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"미모리: 최대체력: <200> 명중률: <15> 회피율: <10> 치명저항: <5> 치명대미지저항: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <100> 명중률: <7> 회피율: <5> 치명저항: <2> 치명대미지저항: <2>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"미모리: 방위: <10> 지략: <15>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 방위: <5> 지략: <7>", "L", 칼라_주의)
ENDIF

@무기_설명_405
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1405_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1405_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <지략>", "L", 칼라_주의)
SETCOLOR 칼라_선택불가
PRINT   · 지략이 높을수록 대상이 증가한다.
RESETCOLOR
PRINTL 
RETURN