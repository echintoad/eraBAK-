;------------------------------------------
;이름
;+ 무기 있는지 확인용
; 총력전에서 PRINT_HTML 써서 "&" 쓰기 불편함
; Ee 쓰는 동안은 HTML_STRINGLEN 못 써서...
;------------------------------------------
@무기_이름_907(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 17
	RESULTS = 블러드N건파우더
ELSE		 ;123456789012345678901234567890
	RESULTS = 블러드 N 건파우더
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_907(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 1
IF 대상 >= 0 && NO:대상 == 68
	스탯증가:0 = 35 ; 무투
ELSE
	스탯증가:0 = 17 ; 무투
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 907
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1907, 0)
	; 무기사용가능:907 = 0
ELSEIF 탈착 == -1
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "기괴멸렬")
	; 무기사용가능:907 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_907(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 68
	RESULT:총력전_무기_최대체력 = 400
	RESULT:총력전_무기_공격력 = 25
	RESULT:총력전_무기_방어력 = 15
	RESULT:총력전_무기_치유력 = 35
	RESULT:총력전_무기_치명타 = 10
	RESULT:총력전_무기_치명대미지 = 10
ELSE
	RESULT:총력전_무기_최대체력 = 200
	RESULT:총력전_무기_공격력 = 12
	RESULT:총력전_무기_방어력 = 7
	RESULT:총력전_무기_치유력 = 17
	RESULT:총력전_무기_치명타 = 5
	RESULT:총력전_무기_치명대미지 = 5
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_907(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"스미레: 최대체력: <400> 공격력: <25> 방어력: <15> 치유력: <35> 치명타: <10> 치명대미지: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <200> 공격력: <12> 방어력: <7> 치유력: <17> 치명타: <5> 치명대미지: <5>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"스미레: 무투: <35>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <17>", "L", 칼라_주의)
ENDIF

@무기_설명_907
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1907_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1907_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN