;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_1120(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 30
	RESULTS = 청춘의 불꽃
ELSE		 ;123456789012345678901234567890
	RESULTS = 백화요란 제식 소총-청춘의 불꽃
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1120(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 140
	스탯증가:0 = 10 ; 무투
	스탯증가:1 = 15 ; 방위
ELSE
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 7 ; 방위
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1120
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 2120, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "백화요란식 사격술")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1119(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 140
	RESULT:총력전_무기_공격력 = 25
	RESULT:총력전_무기_명중률 = 10
	RESULT:총력전_무기_치명타 = 5
ELSE
	RESULT:총력전_무기_공격력 = 12
	RESULT:총력전_무기_명중률 = 5
	RESULT:총력전_무기_치명타 = 2
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1119(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"렌게: 공격력: <25> 명중률: <10> 치명타: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <12> 명중률: <5> 치명타: <2>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"렌게: 무투: <10> 방위: <15>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <5> 방위: <7>", "L", 칼라_주의)
ENDIF

@무기_설명_1120
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2120_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2120_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <무투>", "L", 칼라_주의)
PRINTL 
RETURN