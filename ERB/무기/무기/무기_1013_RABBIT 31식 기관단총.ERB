;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_1013(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 20
	RESULTS = 31식 기관단총
ELSE		 ;123456789012345678901234567890
	RESULTS = RABBIT 31식 기관단총
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1013(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 107
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 10 ; 방위
	스탯증가:2 = 15 ; 지략
ELSE
	스탯증가:0 = 2 ; 무투
	스탯증가:1 = 5 ; 방위
	스탯증가:2 = 7 ; 지략
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착
ABL:대상:지략 += 스탯증가:2 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1013
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 2013, 0)
	; 무기사용가능:1013 = 0
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 100
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "섬광 드론 전개")
	; 무기사용가능:1013 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1013(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 107
	RESULT:총력전_무기_최대체력 = 1000
	RESULT:총력전_무기_방어력 = 15
	RESULT:총력전_무기_회피율 = 5
	RESULT:총력전_무기_치명대미지저항 = 10
	RESULT:총력전_무기_군중제어강화 = 20
	RESULT:총력전_무기_군중제어저항 = 20
ELSE
	RESULT:총력전_무기_최대체력 = 500
	RESULT:총력전_무기_방어력 = 7
	RESULT:총력전_무기_회피율 = 2
	RESULT:총력전_무기_치명대미지저항 = 5
	RESULT:총력전_무기_군중제어강화 = 10
	RESULT:총력전_무기_군중제어저항 = 10
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1013(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"미야코: 최대체력: <1000> 방어력: <15> 회피율: <5> 치명대미지저항: <10> 군중강화: <20> 군중저항: <20>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <500> 방어력: <7> 회피율: <2> 치명대미지저항: <5> 군중강화: <10> 군중저항: <10>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"미야코: 무투: <5> 방위: <10> 지략: <15>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <2> 방위: <5> 지략: <7>", "L", 칼라_주의)
ENDIF

@무기_설명_1013
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2013_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2013_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN