;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_303(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 냥즈 대쉬
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_303(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 35
	스탯증가:0 = 5 ; 방위
	스탯증가:1 = 25 ; 지략
ELSE
	스탯증가:0 = 2 ; 방위
	스탯증가:1 = 12 ; 지략
ENDIF
; 스탯
ABL:대상:방위 += 스탯증가:0 * 탈착
ABL:대상:지략 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 303
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1303, 0)
	; 무기사용가능:303 = 0
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 100
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "게임, 스타트!")
	; 무기사용가능:303 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_303(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 35
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_치명대미지 = 20
ELSE
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_치명대미지 = 10
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_303(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"유즈: 공격력: <20> 치명대미지: <20>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <10> 치명대미지: <10>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"유즈: 방위: <5> 지략: <25>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 방위: <2> 지략: <12>", "L", 칼라_주의)
ENDIF

@무기_설명_303
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1303_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1303_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <무투>", "L", 칼라_주의)
SETCOLOR 칼라_선택불가
PRINT   · 데미지 변동 폭이 크다.
RESETCOLOR
PRINTL 
RETURN