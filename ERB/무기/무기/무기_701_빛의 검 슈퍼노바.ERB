;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_701(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 빛의 검:슈퍼노바
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_701(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 32
	스탯증가:0 = 30 ; 무투
ELSE
	스탯증가:0 = 15 ; 무투
ENDIF
스탯증가:1 = -10 ; 방위
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 701
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1701, 0)
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "밸런스 붕괴")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_701(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 32
	RESULT:총력전_무기_공격력 = 25
	RESULT:총력전_무기_명중률 = 10
	RESULT:총력전_무기_치명대미지 = 15
ELSE
	RESULT:총력전_무기_공격력 = 12
	RESULT:총력전_무기_명중률 = 5
	RESULT:총력전_무기_치명대미지 = 7
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_701(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"아리스: 공격력: <25> 명중률: <10> 치명대미지: <15>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <12> 명중률: <5> 치명대미지: <7>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"아리스: 무투: <30> 방위: <-10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <15> 방위: <-10>", "L", 칼라_주의)
ENDIF

@무기_설명_701
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1701_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1701_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <무투>", "L", 칼라_주의)
PRINTL 
RETURN