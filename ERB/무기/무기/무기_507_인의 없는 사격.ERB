;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_507(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 인의 없는 사격
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_507(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 79
	스탯증가:0 = 15 ; 무투
	스탯증가:1 = 15 ; 가창
ELSE
	스탯증가:0 = 7 ; 무투
	스탯증가:1 = 7 ; 가창
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:가창 += 스탯증가:1 * 탈착


IF 탈착 == 1
	TALENT:대상:웨폰 = 507
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1507, 0)
	; 무기사용가능:507 = 0
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 100
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "연사 모드!")
	; 무기사용가능:507 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_507(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 79
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_회피율 = 5
	RESULT:총력전_무기_치명타 = 10
	RESULT:총력전_무기_치명대미지 = 5
ELSE
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_회피율 = 2
	RESULT:총력전_무기_치명타 = 5
	RESULT:총력전_무기_치명대미지 = 2
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_507(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"피나: 공격력: <20> 회피율: <5> 치명타: <10> 치명대미지: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <10> 회피율: <2> 치명타: <5> 치명대미지: <2>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"피나: 무투: <15> 가창: <15>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <7> 가창: <7>", "L", 칼라_주의)
ENDIF

@무기_설명_507
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1507_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1507_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <피로도>", "L", 칼라_선택불가)
PRINTL 
RETURN