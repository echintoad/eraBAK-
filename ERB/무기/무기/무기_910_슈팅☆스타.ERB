;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_910(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 슈팅☆스타
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_910(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 58
	스탯증가:0 = 10 ; 무투
	스탯증가:1 = 20 ; 방위
	스탯증가:2 = 10 ; 가창
ELSE
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 10 ; 방위
	스탯증가:2 = 5 ; 가창
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착
ABL:대상:가창 += 스탯증가:2 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 910
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1910, 0)
	; 무기사용가능:910 = 0
ELSEIF 탈착 == -1
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "도전장을 받으세요!")
	; 무기사용가능:910 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_910(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 58
	RESULT:총력전_무기_최대체력 = 700
	RESULT:총력전_무기_공격력 = 5
	RESULT:총력전_무기_방어력 = 25
ELSE
	RESULT:총력전_무기_최대체력 = 350
	RESULT:총력전_무기_공격력 = 2
	RESULT:총력전_무기_방어력 = 12
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_910(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"레이사: 최대체력: <700> 공격력: <5> 방어력: <25>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <350> 공격력: <2> 방어력: <12>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"레이사: 무투: <10> 방위: <20> 가창: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <5> 방위: <10> 가창: <5>", "L", 칼라_주의)
ENDIF

@무기_설명_910
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1910_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1910_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <무투>", "L", 칼라_주의)
PRINTL 
RETURN