;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_1005(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 비욘드 더 루미네이션
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1005(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 63
	스탯증가:0 = 10 ; 무투
	스탯증가:1 = 25 ; 방위
	스탯증가:2 = 5 ; 요리
ELSE
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 12 ; 방위
	스탯증가:2 = 2 ; 요리
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착
ABL:대상:요리 += 스탯증가:2 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1005
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 2005, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "비장의 수단")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1005(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 63
	RESULT:총력전_무기_최대체력 = 600
	RESULT:총력전_무기_방어력 = 25
	RESULT:총력전_무기_치유력 = 30
	RESULT:총력전_무기_군중제어저항 = 20
ELSE
	RESULT:총력전_무기_최대체력 = 300
	RESULT:총력전_무기_방어력 = 12
	RESULT:총력전_무기_치유력 = 15
	RESULT:총력전_무기_군중제어저항 = 10
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1005(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"나츠: 최대체력: <600> 방어력: <25> 치유력: <30> 군중저항: <20>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <300> 방어력: <12> 치유력: <15> 군중저항: <10>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"나츠: 무투: <10> 방위: <25> 요리: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <5> 방위: <12> 요리: <2>", "L", 칼라_주의)
ENDIF

@무기_설명_1005
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2005_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2005_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <요리>", "L", 칼라_주의)
PRINTL 
RETURN