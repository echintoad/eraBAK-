;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_415(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 파이에티
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_415(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 74
	스탯증가:0 = 10 ; 지략
	스탯증가:1 = 20 ; 요리
ELSE
	스탯증가:0 = 5 ; 지략
	스탯증가:1 = 10 ; 요리
ENDIF
; 스탯
ABL:대상:지략 += 스탯증가:0 * 탈착
ABL:대상:요리 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 415
	CALL SKILL_LEARN(대상, 스킬_장르_BASE, 1415, 0)
	; 무기사용가능:415 = 0
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 100
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_BASE, "신성한 가호")
	; 무기사용가능:415 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_415(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 74
	RESULT:총력전_무기_최대체력 = 200
	RESULT:총력전_무기_명중률 = 10
	RESULT:총력전_무기_치유력 = 60
ELSE
	RESULT:총력전_무기_최대체력 = 100
	RESULT:총력전_무기_명중률 = 5
	RESULT:총력전_무기_치유력 = 30
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_415(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"마리: 최대체력: <200> 명중률: <10> 치유력: <60>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <100> 명중률: <5> 치유력: <30>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"마리: 지략: <10> 요리: <20>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 지략: <5> 요리: <10>", "L", 칼라_주의)
ENDIF

@무기_설명_415
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1415_BASE_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1415_BASE_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN