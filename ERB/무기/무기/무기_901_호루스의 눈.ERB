;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_901(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 호루스의 눈
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_901(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 2
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 30 ; 방위
ELSEIF 대상 >= 0 && NO:대상 == 142
	스탯증가:0 = 7 ; 무투
	스탯증가:1 = 23 ; 방위
ELSE
	스탯증가:0 = 2 ; 무투
	스탯증가:1 = 15 ; 방위
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 901
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1901, 0)
	; 무기사용가능:901 = 0
ELSEIF 탈착 == -1
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "전술 진압")
	; 무기사용가능:901 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_901(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 2
	RESULT:총력전_무기_최대체력 = 700
	RESULT:총력전_무기_공격력 = 5
	RESULT:총력전_무기_방어력 = 30
ELSEIF 대상 >= 0 && NO:대상 == 142
	RESULT:총력전_무기_최대체력 = 500
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_방어력 = 20
ELSE
	RESULT:총력전_무기_최대체력 = 350
	RESULT:총력전_무기_공격력 = 2
	RESULT:총력전_무기_방어력 = 15
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_901(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"호시노: 최대체력: <700> 공격력: <5> 방어력: <30>", "L", 칼라_주의)
	CALL ICPRINT(@"쿠로코: 최대체력: <500> 공격력: <10> 방어력: <20>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <350> 공격력: <2> 방어력: <15>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"호시노: 무투: <5> 방위: <30>", "L", 칼라_주의)
	CALL ICPRINT(@"쿠로코: 무투: <7> 방위: <23>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <2> 방위: <15>", "L", 칼라_주의)
ENDIF

@무기_설명_901
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1901_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1901_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <무투> , <방위>", "L", 칼라_주의)
PRINTL 
RETURN