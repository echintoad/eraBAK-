;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_904(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 멀티 택티컬
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_904(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 49
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 25 ; 방위
ELSE
	스탯증가:0 = 2 ; 무투
	스탯증가:1 = 12 ; 방위
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 904
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1904, 0)
	; 무기사용가능:904 = 0
ELSEIF 탈착 == -1
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "불굴의 의지")
	; 무기사용가능:904 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_904(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 49
	RESULT:총력전_무기_최대체력 = 900
	RESULT:총력전_무기_방어력 = 30
	RESULT:총력전_무기_치유력 = 35
ELSE
	RESULT:총력전_무기_최대체력 = 450
	RESULT:총력전_무기_방어력 = 15
	RESULT:총력전_무기_치유력 = 17
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_904(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"에이미: 최대체력: <900> 방어력: <30> 치유력: <35>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <450> 방어력: <15> 치유력: <17>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"에이미: 무투: <5> 방위: <25>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <2> 방위: <12>", "L", 칼라_주의)
ENDIF

@무기_설명_904
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1904_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1904_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <방위>", "L", 칼라_주의)
PRINTL 
RETURN