;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_1012(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 트윈 드래곤
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1012(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 41
	스탯증가:0 = 15 ; 무투
	스탯증가:1 = 25 ; 방위
ELSE
	스탯증가:0 = 7 ; 무투
	스탯증가:1 = 12 ; 방위
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1012
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 2012, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "아앙~? 죽인다?")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1012(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 41
	RESULT:총력전_무기_최대체력 = 300
	RESULT:총력전_무기_공격력 = 25
	RESULT:총력전_무기_회피율 = 15
	RESULT:총력전_무기_치명타 = 10
ELSE
	RESULT:총력전_무기_최대체력 = 150
	RESULT:총력전_무기_공격력 = 12
	RESULT:총력전_무기_회피율 = 7
	RESULT:총력전_무기_치명타 = 5
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1012(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"네루: 최대체력: <300> 공격력: <25> 회피율: <15> 치명타: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <150> 공격력: <12> 회피율: <7> 치명타: <5>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"네루: 무투: <15> 방위: <25>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <7> 방위: <12>", "L", 칼라_주의)
ENDIF

@무기_설명_1012
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2012_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2012_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <무투> , <방위>", "L", 칼라_주의)
PRINTL 
RETURN