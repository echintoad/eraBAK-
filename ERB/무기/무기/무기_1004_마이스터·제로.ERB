;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_1004(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 마이스터·제로
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1004(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 46
	스탯증가:1 = 10 ; 방위
	스탯증가:2 = 25 ; 지략
ELSE
	스탯증가:1 = 5 ; 방위
	스탯증가:2 = 12 ; 지략
ENDIF
스탯증가:0 = -5 ; 무투
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착
ABL:대상:지략 += 스탯증가:2 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1004
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 2004, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "천둥이 등장")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1004(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 46
	RESULT:총력전_무기_최대체력 = 500
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_방어력 = 5
ELSE
	RESULT:총력전_무기_최대체력 = 250
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_방어력 = 2
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1004(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"우타하: 최대체력: <500> 공격력: <20> 방어력: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <250> 공격력: <10> 방어력: <2>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"우타하: 무투: <-5> 방위: <10> 지략: <25>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <-5> 방위: <5> 지략: <12>", "L", 칼라_주의)
ENDIF

@무기_설명_1004
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2004_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2004_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN