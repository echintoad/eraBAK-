;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_906(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 22
	RESULTS = 최신형 덤벨
ELSE 		 ;123456789012345678901234567890
	RESULTS = 밀레니엄제 최신형 덤벨
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_906(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 129
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 20 ; 방위
ELSE
	스탯증가:0 = 2 ; 무투
	스탯증가:1 = 10 ; 방위
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 906
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1906, 0)
	; 무기사용가능:906 = 0
ELSEIF 탈착 == -1
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "스퍼트 앤 슛")
	; 무기사용가능:906 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_906(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 129
	RESULT:총력전_무기_최대체력 = 400
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_방어력 = 10
ELSE
	RESULT:총력전_무기_최대체력 = 200
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_방어력 = 5
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_906(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"스미레: 최대체력: <400> 공격력: <20> 방어력: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <200> 공격력: <10> 방어력: <5>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"스미레: 무투: <5> 방위: <20>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <2> 방위: <10>", "L", 칼라_주의)
ENDIF

@무기_설명_906
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1906_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1906_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <방위>", "L", 칼라_주의)
PRINTL 
RETURN