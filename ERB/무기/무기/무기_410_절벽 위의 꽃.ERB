;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_410(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 절벽 위의 꽃
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_410(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 36
	스탯증가:0 = 5 ; 방위
	스탯증가:1 = 30 ; 지략
	스탯증가:2 = 5 ; 정치
ELSE
	스탯증가:0 = 2 ; 방위
	스탯증가:1 = 15 ; 지략
	스탯증가:2 = 2 ; 정치
ENDIF
; 스탯
ABL:대상:방위 += 스탯증가:0 * 탈착
ABL:대상:지략 += 스탯증가:1 * 탈착
ABL:대상:정치 += 스탯증가:2 * 탈착


IF 탈착 == 1
	TALENT:대상:웨폰 = 410
	CALL SKILL_LEARN(대상, 스킬_장르_BASE, 1410, 0)
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_BASE, "후후, 실력을 보여드리죠")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_410(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 36
	RESULT:총력전_무기_명중률 = 30
	RESULT:총력전_무기_치명타저항 = 10
	RESULT:총력전_무기_치명대미지저항 = 10
ELSE
	RESULT:총력전_무기_명중률 = 15
	RESULT:총력전_무기_치명타저항 = 5
	RESULT:총력전_무기_치명대미지저항 = 5
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_410(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"히마리: 명중률: <30> 치명저항: <10> 치명대미지저항: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 명중률: <15> 치명저항: <5> 치명대미지저항: <5>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"히마리: 방위: <5> 지략: <30> 정치: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 방위: <2> 지략: <15> 정치: <2>", "L", 칼라_주의)
ENDIF

@무기_설명_410
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1410_BASE_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1410_BASE_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN