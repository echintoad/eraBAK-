;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_301(iLen = 0)
#DIM DYNAMIC iLen
RESULTS = 575식 유탄발사기
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_301(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 77
	스탯증가:0 = 5 ; 요리
	스탯증가:1 = 30 ; 가창
ELSE
	스탯증가:0 = 2 ; 요리
	스탯증가:1 = 15 ; 가창
ENDIF
; 스탯
ABL:대상:요리 += 스탯증가:0 * 탈착
ABL:대상:가창 += 스탯증가:1 * 탈착


IF 탈착 == 1
	TALENT:대상:웨폰 = 301
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1301, 0)
	; 무기사용가능:301 = 0
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 100
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "아플지도 몰라~")
	; 무기사용가능:301 = 1
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_301(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 77
	RESULT:총력전_무기_공격력 = 25
	RESULT:총력전_무기_명중률 = 15
ELSE
	RESULT:총력전_무기_공격력 = 12
	RESULT:총력전_무기_명중률 = 7
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_301(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"치세: 공격력: <25> 명중률: <15>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <12> 명중률: <7>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"치세: 요리: <5> 가창: <30>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 요리: <2> 가창: <15>", "L", 칼라_주의)
ENDIF

@무기_설명_301
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1301_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1301_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN