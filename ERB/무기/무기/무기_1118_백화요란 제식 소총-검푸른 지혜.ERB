;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_1118(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 30
	RESULTS = 검푸른 지혜
ELSE		 ;123456789012345678901234567890
	RESULTS = 백화요란 제식 소총-검푸른 지혜
ENDIF
		   ;123456789012345678901234567890
; RESULTS = 백화요란 제식 소총-검푸른 지혜
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1118(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 2
IF 대상 >= 0 && NO:대상 == 138
	스탯증가:0 = 10 ; 무투
	스탯증가:1 = 20 ; 지략
ELSE
	스탯증가:0 = 5 ; 무투
	스탯증가:1 = 10 ; 지략
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:지략 += 스탯증가:1 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1118
	CALL SKILL_LEARN(대상, 스킬_장르_BASE, 2118, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_BASE, "신기묘산의 한 수")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1118(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 138
	RESULT:총력전_무기_공격력 = 20
	RESULT:총력전_무기_명중률 = 15
	RESULT:총력전_무기_치명타 = 5
ELSE
	RESULT:총력전_무기_공격력 = 10
	RESULT:총력전_무기_명중률 = 7
	RESULT:총력전_무기_치명타 = 2
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1118(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"키쿄: 공격력: <20> 명중률: <15> 치명타: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 공격력: <10> 명중률: <7> 치명타: <2>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"키쿄: 무투: <10> 지략: <20>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <5> 지략: <10>", "L", 칼라_주의)
ENDIF

@무기_설명_1118
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2118_BASE_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2118_BASE_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <지략>", "L", 칼라_주의)
PRINTL 
RETURN