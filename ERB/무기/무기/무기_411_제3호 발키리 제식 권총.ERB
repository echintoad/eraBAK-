;------------------------------------------
;이름
;+ 무기 있는지 확인용
;------------------------------------------
@무기_이름_411(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 17
	RESULTS = 제3호 권총
ELSEIF iLen > 0 && iLen < 22
	RESULTS = 제3호 발키리 권총
ELSE		 ;123456789012345678901234567890
	RESULTS = 제3호 발키리 제식 권총
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_411(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 105
	스탯증가:0 = -5 ; 무투
	스탯증가:1 = 25 ; 방위
	스탯증가:2 = 5 ; 지략
ELSE
	스탯증가:0 = -5 ; 무투
	스탯증가:1 = 12 ; 방위
	스탯증가:2 = 2 ; 지략
ENDIF
; 스탯
ABL:대상:무투 += 스탯증가:0 * 탈착
ABL:대상:방위 += 스탯증가:1 * 탈착
ABL:대상:지략 += 스탯증가:2 * 탈착


IF 탈착 == 1
	TALENT:대상:웨폰 = 411
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 1411, 0)
ELSEIF 탈착 == -1
	;이부분은 없어도 됨 혹시몰라 넣어놓음
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "협상은 없습니다!")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_411(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 105
	RESULT:총력전_무기_최대체력 = 200
	RESULT:총력전_무기_공격력 = 15
	RESULT:총력전_무기_명중률 = -5
	RESULT:총력전_무기_회피율 = 5
	RESULT:총력전_무기_치명대미지 = 15
ELSE
	RESULT:총력전_무기_최대체력 = 100
	RESULT:총력전_무기_공격력 = 7
	RESULT:총력전_무기_명중률 = -5
	RESULT:총력전_무기_회피율 = 2
	RESULT:총력전_무기_치명대미지 = 7
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_411(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"키리노: 최대체력: <200> 공격력: <15> 명중률: <-5> 회피율: <5> 치명대미지: <15>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <100> 공격력: <7> 명중률: <-5> 회피율: <2> 치명대미지: <7>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"키리노: 무투: <-5> 방위: <25> 지략: <5>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 무투: <-5> 방위: <12> 지략: <2>", "L", 칼라_주의)
ENDIF

@무기_설명_411
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_1411_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_1411_SP_0_EXPLANATION
PRINTFORML %RESULTS%
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN