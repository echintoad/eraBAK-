;------------------------------------------
;이름
;+ 무기 있는지 확인용
; 총력전에서 PRINT_HTML 써서 "&" 쓰기 불편함
; Ee 쓰는 동안은 HTML_STRINGLEN 못 써서...
;------------------------------------------
@무기_이름_1003(iLen = 0)
#DIM DYNAMIC iLen
IF iLen > 0 && iLen < 11
	RESULTS = 로직N리즌
ELSE		 ;123456789012345678901234567890
	RESULTS = 로직 N 리즌
ENDIF
;------------------------------------------
;착용 효과 (대상, 착용 1,미착용 -1)
;------------------------------------------
@무기_착용_1003(대상, 탈착 = 1)
#DIM 대상
#DIM 탈착
#DIM 스탯증가, 3
IF 대상 >= 0 && NO:대상 == 30
	스탯증가:0 = 5 ; 방위
	스탯증가:1 = 25 ; 지략
	스탯증가:2 = 10 ; 정치
ELSE
	스탯증가:0 = 2 ; 방위
	스탯증가:1 = 12 ; 지략
	스탯증가:2 = 5 ; 정치
ENDIF
; 스탯
ABL:대상:방위 += 스탯증가:0 * 탈착
ABL:대상:지략 += 스탯증가:1 * 탈착
ABL:대상:정치 += 스탯증가:2 * 탈착

IF 탈착 == 1
	TALENT:대상:웨폰 = 1003
	CALL SKILL_LEARN(대상, 스킬_장르_SP, 2003, 0)
ELSEIF 탈착 == -1
	TALENT:대상:웨폰 = 0
	CALL SKILL_FORGET_BY_NAME(대상, 스킬_장르_SP, "Q.E.D")
ENDIF

RETURN 탈착

;------------------------------------------
; 임시: 총력전 스탯 추가
; 나중에 총력전 장비 스탯 정리 하면서 같이 처리 되도록 변경
;------------------------------------------
@무기_총력전스탯_1003(대상)
#DIM 대상
VARSET RESULT, 0 ; WEAPON.ERH 참조
IF 대상 >= 0 && NO:대상 == 30
	RESULT:총력전_무기_최대체력 = 1000
	RESULT:총력전_무기_방어력 = 18
	RESULT:총력전_무기_회피율 = 30
	RESULT:총력전_무기_치유력 = 25
ELSE
	RESULT:총력전_무기_최대체력 = 500
	RESULT:총력전_무기_방어력 = 9
	RESULT:총력전_무기_회피율 = 15
	RESULT:총력전_무기_치유력 = 12
ENDIF

;------------------------------------------
;무기설명
;------------------------------------------
@무기_설명_스탯_1003(isRaid = 0)
#DIM DYNAMIC isRaid
IF isRaid
	CALL ICPRINT(@"유우카: 최대체력: <1000> 방어력: <18> 회피율: <30> 치유력: <25>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 최대체력: <500> 방어력: <9> 회피율: <15> 치유력: <12>", "L", 칼라_주의)
ELSE
	CALL ICPRINT(@"유우카: 방위: <5> 지략: <25> 정치: <10>", "L", 칼라_주의)
	CALL ICPRINT(@"나머지: 방위: <2> 지략: <12> 정치: <5>", "L", 칼라_주의)
ENDIF

@무기_설명_1003
CALL SINGLE_DRAWLINE
PRINTL 전용스킬
PRINTL 
CALL SKILL_2003_SP_0_NAME
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
PRINTFORML %RESULTS%
CALL COLOR_LINE
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL SKILL_2003_SP_0_EXPLANATION
PRINTFORML %RESULTS% 
PRINTL
SETCOLOR 칼라_선택불가
PRINT   · 
RESETCOLOR
CALL ICPRINT(@"영향 받는 능력치 : <없음>", "L", 칼라_주의)
PRINTL 
RETURN