;-------------------------------------------------
;CSV에서는 설정 할 수 없는 캐릭터 데이터의 초기설정
;-------------------------------------------------
@ADDITIONAL_CHARA_SETTING
;CFLAG:(NAME_TO_CHARA("앨리스")):모친 = GET_ID(NAME_TO_CHARA("신키"))
CALL ADDITIONAL_CHARA_SETTING_HEIGHT

;-------------------------------------------------
; 미실장 캐릭터 키 계산
; 캐릭터A의 키는 캐릭터B 랑 캐릭터C 사이에서 무작위로, 등등
; 이거 참조 하긴 하는데:
; https://www.fmkorea.com/7932416947
; 여기서 보면 캐릭터 이미지가 키 참조 100% 못 한다는 게 보임:
; https://gall.dcinside.com/mgallery/board/view/?id=projectmx&no=13276393
; 추가로 공식/콜라보 일러 참조 중...
; 추가 정보/일러 가 나오면 수정 바람
;-------------------------------------------------
@ADDITIONAL_CHARA_SETTING_HEIGHT
#DIM DYNAMIC 신장업데이트
#DIM DYNAMIC iTmp, 2
FOR iTmp, 0, CHARANUM
	신장업데이트 = 0
	SELECTCASE NO:iTmp
		CASE 88 ; 쿠즈노하 145.0 ~ 149.9
			; 스탠드: ~146cm, 비스듬이 서있는거, 세이아랑(149) 비슷할거라 가정
			MAXBASE:iTmp:신장 = 1450 + RAND:50
			신장업데이트 = 1
		; 폭스 소대
		CASE 111 ; 유키노 159.0 ~ 161.9
			; ~160cm? 출저: 나무위키 "후배 미야코와 대면하는 장면에서 미야코보다(156) 신장이 크게 그려져 있다. 대략 160cm 전후로 보인다."
			; 스탠드: ~162cm
			MAXBASE:iTmp:신장 = 1590 + RAND:30
			신장업데이트 = 1
		CASE 112 ; 니코 156.0 ~ 157.9
			; 유키노 보다 작다, 단체 사진이랑 유키노가 미야코 옆에 서있는 일러 보면 미야코랑 비슷 할듯?
			; 오토기, 쿠루미랑 차이를 주기 위해 최소 156.0
			; 스탠드: ~158cm
			MAXBASE:iTmp:신장 = 1560 + RAND:20
			신장업데이트 = 1
		CASE 127 ; 오토기 150.0 ~ 151.9
			; 150 ~ 152?(체격0), M107 LRSR(144cm) 머리 하나 크기 차이 (총 세워 잡는 일러)
			; 세계관 때문에 총기 자체가 작을 수 있긴 함 (그래도 미유[149cm] 보단 클거 같은데)
			; 스탠드: ~146cm
			MAXBASE:iTmp:신장 = 1500 + RAND:20
			신장업데이트 = 1
		CASE 128 ; 쿠루미 150.0 ~ 151.9
			; 오토기랑 동일
			; 스탠드: ~152cm
			MAXBASE:iTmp:신장 = 1500 + RAND:20
			신장업데이트 = 1
		; 총학생회
		CASE 119 ; 린 164.0 ~ 165.9
			; 최종편 일러에서 아코(165), 하나코랑(161) 비슷(표면이 평평하지 않을수도 있는점 명심)
			; 스탠드: ~166cm
			MAXBASE:iTmp:신장 = 1640 + RAND:20
			신장업데이트 = 1
		CASE 120 ; 모모카 145.0 ~ 145.9
			; 발표 일러, 스모모랑 같이 가장 작음, 거의 비슷해서 RAND:10 으로 제한
			; 스탠드: ~145cm
			MAXBASE:iTmp:신장 = 1450 + RAND:10
			신장업데이트 = 1
		CASE 121 ; 아유무 170.0 ~ 171.9
			; 발표 일러, 가장 큼
			; 스탠드: ~???cm
			MAXBASE:iTmp:신장 = 1700 + RAND:20
			신장업데이트 = 1
		CASE 122 ; 카야 157.0 ~ 160.9
			; 발표 일러, 아오이보다 작음, 아오이 스모모 사이 ~ 조금 크게 (155 ~ 157)
			; 스탠드: ~159cm
			MAXBASE:iTmp:신장 = 1570 + RAND:40
			신장업데이트 = 1
		CASE 123 ; 아오이 164.0 ~ 165.9
			; 발표 일러, 카야보다 큼
			; 최종편 일러에서 린, 모모카 키 차이랑 비슷, 린이랑 비슷할거라 예상
			; 스탠드: ~165cm
			MAXBASE:iTmp:신장 = 1640 + RAND:20
			신장업데이트 = 1
		CASE 134 ; 스모모 145.0 ~ 145.9
			; 발표 일러, 모모카랑 같이 가장 작음
			; 스탠드: ~146cm
			MAXBASE:iTmp:신장 = 1450 + RAND:10
			신장업데이트 = 1
		CASE 135 ; 하이네 168.0 ~ 169.9
			; 발표 일러, 아유무 보다 살짝 작음
			; 스탠드: ~168cm
			MAXBASE:iTmp:신장 = 1680 + RAND:20
			신장업데이트 = 1
		; ---
		CASE 125 ; 소라 142.0 ~ 148.9
			; 3차PV (1주년) 에선 아이리랑(160) 비슷, 나츠(152) 보단 커 보이던데, <- 무시
			; 로손 콜라보 이미지 에선 미유(149), 아즈사보다(149) 작게 나옴
			; 스탠드: ~142cm
			MAXBASE:iTmp:신장 = 1420 + RAND:70
			신장업데이트 = 1
		CASE 132 ; 아키라 152.0 ~ 156.9
			; 작단 느낌은 안 들어서 아리스보다(152) 크게
			; 스탠드: ~150cm
			MAXBASE:iTmp:신장 = 1520 + RAND:50
			신장업데이트 = 1
		CASE 133 ; 카이 165.0 ~ 169.9
			; 귀찮음 이슈로 170 이하로 맞춤 (체격 = 0), 맞춰서 변경 가능하긴 한데...
			; 스탠드: ~168cm
			MAXBASE:iTmp:신장 = 1650 + RAND:50
			신장업데이트 = 1
		CASE 141 ; 슈로 130.0 ~ 134.9
			; (일섭)4주년 PV 책상 보나 낮은점 (숨은 걸 수도 있긴 한데)
			; 스탠드: ~131cm
			MAXBASE:iTmp:신장 = 1300 + RAND:50
			신장업데이트 = 1
	ENDSELECT
	IF 신장업데이트 == 1
		BASE:iTmp:신장 = MAXBASE:iTmp:신장
		CALL SET_BODYSIZE(iTmp)
	ENDIF
NEXT