;게임 개시시나 로드시의 처리

;-------------------------
;타이틀 화면
;-------------------------
@SYSTEM_TITLE
; #DIM STARTA
#DIM LCOUNT,2
#DIMS sPrint_Text
RESETDATA
[SKIPSTART]
ALIGNMENT CENTER
FOR LOCAL , 0 , 50
	CLEARLINE LINECOUNT
	SETCOLOR 255 * MIN(LOCAL , 30) / 30 , 255 * MIN(LOCAL , 30) / 30 , 255 * MIN(LOCAL , 30) / 30
	FOR LCOUNT, 0, 23
		PRINTBUTTON " " * 80 , "0"
		PRINTL
	NEXT
	PRINTBUTTON " " * 23 + "　본 게임은　픽션으로" + " " * 23 , "0"
	PRINTL
	PRINTBUTTON " " * 23 +  "등장 하는 인물이나 집단은　실재의 인물 " + " " * 23 , "0"
	PRINTL
	PRINTBUTTON " " * 23 + "및 단체와는　일체의 관련이 없습니다" + " " * 23 , "0"
	PRINTL
	FOR LCOUNT, 0, 22
		PRINTBUTTON " " * 80 , 0
		PRINTL
	NEXT
	;[クリックorEnter待ち]표시
	STARTA = (GETMILLISECOND()) % 3000
	STARTA =  255 * ( STARTA > 1500 ? (3000 - STARTA) # (STARTA) ) / 1500
	SETCOLOR STARTA , STARTA , 0
	PRINTBUTTON " " * 27 +  "[Click or Hit Return key]" + " " * 27 , "1"
	PRINTL
	;ALIGNMENT LEFT
	RESETCOLOR
	TINPUTS 100, "-1" , 0
	SIF RESULTS != "-1"
		GOTO PRINT_TITLE
NEXT
CLEARLINE LINECOUNT
ALIGNMENT LEFT
[SKIPEND]
$PRINT_TITLE
CALL SINGLE_DRAWLINE
ALIGNMENT CENTER
PRINTFORML
PRINTFORML EraBlueArchiveK
PRINTFORML
CALL SYSTEM_TITLE_BANNER(0)
PRINTFORML %GAMEBASE_AUTHOR%
PRINTFORML Ver%GET_VERSION_STRING(GAMEBASE_VERSION)%
PRINTFORML %GAMEBASE_INFO%
CALL SINGLE_DRAWLINE
PRINTBUTTON " 0[  처음부터  ]", 0
PRINTL 
PRINTBUTTON " 1[  이어하기  ]", 1
PRINTL 
PRINTBUTTON " 2[커스텀캐릭터]", 2
PRINTL
PRINTBUTTON " 3[    헬프    ]", 3
PRINTL
[IF_DEBUG]
PRINTBUTTON "99[   DEBUG   ]", 99
PRINTL 
[ENDIF]
ALIGNMENT LEFT
$INPUT_LOOP
INPUT

IF RESULT == 0
	BEGIN FIRST
ELSEIF RESULT == 1
	CALL LOAD_GAME
	RESTART
ELSEIF RESULT == 2
	CALL CUSTOM_CHARA_MENU
	RESTART
ELSEIF RESULT == 3
	CALL CREATE_HELP_MAP
	CALL CONFIG_HELPMENU
	RESTART
ELSEIF RESULT == 99
	[IF_DEBUG]
	CALL DEBUGMENU()
	RESTART
	[ENDIF]
ENDIF
GOTO INPUT_LOOP

