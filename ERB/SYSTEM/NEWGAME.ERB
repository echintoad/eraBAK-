;0～199번의 아이템을 매도에 낸다
VARSET ITEMSALES, 1, 0, 200

CALL DAILY_SET_DISABLE("DRUG_SEX", 1)
CALL DAILY_SET_DISABLE("YOU_SEXHARA", 1)
CALL DAILY_SET_DISABLE("YOU_WANDERING", 1)

;주회를 0으로 설정
FLAG:주회수 = 0

;그림표시인원수 초기화
