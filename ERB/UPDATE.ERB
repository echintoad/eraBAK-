; 범용 무기 인지
@_UPDATE_IS_FIXED_WEAPON(무기번호)
#FUNCTION
#DIM 무기번호
#DIM CONST iWeaponNum = 100, 200, 300, 400, 500, 600, 700, 800, 900, 1000, 1100
SIF FINDELEMENT(iWeaponNum, 무기번호) != -1
	RETURNF 1
RETURNF 0

; 고정 무기 인지, 3101 ~ 4105 무기는 무시 하도록
@_UPDATE_IS_EXISTING_WEAPON(무기번호)
#FUNCTION
#DIM 무기번호
SIF _UPDATE_IS_FIXED_WEAPON(무기번호)
	RETURNF 0
SIF 무기번호 < 3000
	RETURNF 1
RETURNF 0


; 버전 0.5.5용 무기 해제
; 해제한 무기, 고정 무기면, RESULT 에 기록
; + 스킬
@_UPDATE_WEAPON_UNEQUIP_055(대상)
#DIM 대상
LOCAL = 0
SELECTCASE TALENT:대상:웨폰
	CASE 100 ; 양산형 돌격소총
		ABL:대상:무투 -= 10
		ABL:대상:방위 -= 10
	CASE 101 ; Et Omnia Vanitas
		LOCAL = 101
		ABL:대상:무투 -= 25
		ABL:대상:방위 -= 10
		ABL:대상:정치 -= -5
	CASE 102 ; honestwish
		LOCAL = 102
		ABL:대상:지략 -= 5
		ABL:대상:정치 -= 25
	CASE 103 ; WHITE FANG 465
		LOCAL = 103
		ABL:대상:무투 -= 25
		ABL:대상:방위 -= 5
	CASE 104 ; 라이브러리 룰러
		LOCAL = 104
		ABL:대상:방위 -= 20
		ABL:대상:지략 -= 10
	CASE 106 ; 마이 네세시티
		LOCAL = 106
		ABL:대상:무투 -= 5
		ABL:대상:방위 -= 25
	CASE 107 ; 탐식의 징표
		LOCAL = 107
		ABL:대상:무투 -= 25
		ABL:대상:방위 -= 5
	CASE 108 ; 백도어
		LOCAL = 108
		ABL:대상:방위 -= 5
		ABL:대상:지략 -= 25
	CASE 109 ; 서프라이즈 파티
		LOCAL = 109
		IF TALENT:대상:행운 == 1
			ABL:대상:무투 -= 10
			ABL:대상:방위 -= 10
			ABL:대상:지략 -= 10
			ABL:대상:정치 -= 10
		ELSE
			ABL:대상:무투 -= 5
			ABL:대상:방위 -= 5
