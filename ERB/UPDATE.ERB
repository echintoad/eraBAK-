;-------------------------------------------------
;준 버젼 문자열에 대응하는 버젼 수치의 취득
;-------------------------------------------------
@GET_VERSION_VALUE(버젼문자열)
#FUNCTION
#DIMS 버젼문자열
;RESULT 퇴피
LOCAL = RESULT
SPLIT 버젼문자열, ".", LOCALS
RESULT = LOCAL

RETURNF TOINT(LOCALS:0) * 10000 + TOINT(LOCALS:1) * 100 + TOINT(LOCALS:2)
;-------------------------------------------------
;준 버젼 수치에 대응하는 버젼 문자열의 취득
;-------------------------------------------------
@GET_VERSION_STRING(버젼수치)
#FUNCTIONS
#DIM 버젼수치

RETURNF TOSTR(버젼수치 / 10000) + "." + TOSTR(버젼수치 % 10000 / 100) + "." + TOSTR(버젼수치 % 10000 % 100)
;-------------------------------------------------
;준 버젼 문자열과 지금의 버젼을 비교해, 아프데가 필요한가 조사한다
;-------------------------------------------------
@CHECK_UPDATE(버젼문자열)
#FUNCTION
#DIMS 버젼문자열

RETURNF LASTLOAD_VERSION < GET_VERSION_VALUE(버젼문자열)

;-------------------------------------------------
;세이브 데이터의 업데이트 처리
;-------------------------------------------------
@UPDATE
#DIM 강제인계플래그
#DIM DYNAMIC cnt

강제인계플래그 = 0

IF LASTLOAD_VERSION != GAMEBASE_VERSION
	PRINTFORML 업데이트 처리를 실시합니다
	PRINTFORML 「엔들레스 루프의 혐의가 운운」이라고 나올 가능성이 있습니다만, 문제는 없기에 속행해 주세요
	PRINTFORMW
	CALL CLEAN_SPERM_MAP()
	; 이전 버전 세이브 CSTR 업데이트용
	; CSV 숫자 +1 만큼 루프 반복
	FOR COUNT:0, 1, 143
		FOR COUNT:1, 0, 100
			IF CSTR:(COUNT:0):(COUNT:1) != ""
;				PRINTFORML {COUNT:0}{COUNT:1} %CSTR:(COUNT:0):(COUNT:1)%
;				PRINTFORML {COUNT:0}{COUNT:1} %CSVCSTR(COUNT:0, COUNT:1)%
				CSTR:(COUNT:0):(COUNT:1) = %CSVCSTR(COUNT:0, COUNT:1)%
;				PRINTFORML {COUNT:0} %CSTR:(COUNT:0):(COUNT:1)%
			ENDIF
		NEXT
;		PRINTFORML %NAME:(COUNT:0)%
;		PRINTFORML %CALLNAME:(COUNT:0)%
		NAME:(COUNT:0) = %CSVNAME(COUNT:0)%
		CALLNAME:(COUNT:0) = %CSVCALLNAME(COUNT:0)%
;		PRINTFORML {COUNT:0} %NAME:(COUNT:0)%
;		PRINTFORML {COUNT:0} %CALLNAME:(COUNT:0)%
	NEXT
	PRINTFORMW 변경된 캐릭터네임을 업데이트했습니다
ENDIF

IF CHECK_UPDATE("0.1.2")
	CALL COLOR_PRINTW("Ver0.1.2", 칼라_주의)
	PRINTFORML + 의복 변경에 따른 화상 변경(치나츠, 히나)
	PRINTFORML + 의복(한벌옷) 종류 및 이름 변경
ENDIF

IF CHECK_UPDATE("0.3.8");랜덤/아이 캐릭터 장비 리셋
	PRINTFORML
	PRINTFORML 0.3.7 버전 이하에 있는 장비 버그를 고치기 위해 랜덤/아이/특수세력 캐릭터 장비를 리셋합니다
	PRINTFORMW 장비를 빼고 싶은 랜덤/아이/특수세력 캐릭터가 있으면 종료 -> 전 버전으로 빼고 돌아오시기를 바랍니다
	FOR COUNT, 0, CHARANUM
		IF IS_RANDOM_CHARA(COUNT) || IS_CHILD(COUNT) || IS_SP_CHARA(COUNT)
			PRINTFORML ID:{NO:COUNT} 장비 리셋
			FOR LOCAL, 0, 3
				착용장비:COUNT:LOCAL = -1
			NEXT
		ENDIF
	NEXT
ENDIF

IF CHECK_UPDATE("0.3.9");의상 리셋
	{
PRINTFORML \n== 0.3.9 버전에 의상 이름, 번호가 바뀌었습니다 ==
\n의상을 초기화 합니까?\n
	}
	PRINTBUTTON "0[예(추천)]", 0
	PRINTL
	PRINTBUTTON "1[아니오]", 1
	INPUT
	SELECTCASE RESULT
		CASE 0
		; 고정 캐릭터만 리셋
			FOR cnt, 1, 143
				CALL CLOTH_INIT(cnt)
			NEXT
			PRINTL 의상 초기화 완료
		CASE 1
			PRINTL 의상 초기화를 건너뜁니다
	ENDSELECT
ENDIF

IF CHECK_UPDATE("0.5.2");전투 화상 무작위 설정
	{
PRINTFORMW \n== 0.5.2 버전에 전투 화상 무작위 설정이 가능하게 되었습니다 ==
\n"전투 무작위화: ON" 으로 합니다
\n캐릭터 그림 설정 에서 변경 가능 합니다
	}
	FLAG:전투화상무작위화 = 1
ENDIF

IF 강제인계플래그
	FLAG:클리어직후플래그 = 1
	CALL SAVE_GAME
	FLAG:클리어직후플래그 = 0
	BEGIN TITLE
ENDIF

IF CHECK_UPDATE("0.5.4");치나츠 안경 추가
	PRINTW == 0.5.4 버전에 치나츠 안경 추가, 치나츠 의상을 초기화합니다 ==
	CALL CLOTH_INIT(16)
ENDIF

IF CHECK_UPDATE("0.5.10")
	; BLACKFANG 확인
	FOR LOCAL, 0, CHARANUM
		IF TALENT:LOCAL:웨폰 == 130
			PRINTL == 0.5.10 BLACKFANG465 장착시 스킬 변경 ==
			PRINTFORMW >> %ANAME(LOCAL)% "드론 소환: 화력 지원" -> "화력 강화"
			CALL SKILL_FORGET_BY_NAME(LOCAL, 스킬_장르_BASE, "드론 소환: 화력 지원")
			CALL SKILL_LEARN(LOCAL, 스킬_장르_BASE, 1130, 0)
		ENDIF
	NEXT
ENDIF

; chk update 0.6
IF CHECK_UPDATE("0.6.0")
	; debug confirm update
	PRINTL == 0.6.0 업데이트 ==
	PRINTL 세이브 백업을 강력 추천합니다
	WAITANYKEY
	; 보스 무지성 리셋
	PRINTL 총력전 보스 리셋중...
	CALL 총력전_보스활동_초기설정
	PRINTL 무기 리셋중...
	IF LASTLOAD_VERSION <= GET_VERSION_VALUE("0.5.5")
		; 무기 리셋
		FOR LOCAL, 0, CHARANUM
			LOCAL:1 = 0
			CALL _UPDATE_WEAPON_UNEQUIP_055(LOCAL) ; 무기 스탯 버프 제거
			SIF RESULT != 0
				LOCAL:1 = RESULT ; 해제한 무기 기록
			CALL _UPDATE_WEAPON_RMVSKILL(LOCAL) ; 무기 스킬 제거
			; 중복 고정 캐릭터가 있으면 첫번째만 바뀔듯?
			IF IS_FIXED_CHARA(LOCAL)
				CALL WEAPON_EQUIP(LOCAL, 100) ; failsafe
				CALL WEAPON_INIT(LOCAL)
			ELSEIF LOCAL:1 > 0
				; 범용 캐릭터/아이 캐릭터가 무기 받아 쓰고 있었으면 그냥 주기
				CALL WEAPON_ADD(LOCAL, LOCAL:1)
				CALL WEAPON_EQUIP(LOCAL, LOCAL:1)
			ELSE
				; 양산형 돌격소총
				CALL WEAPON_EQUIP(LOCAL, 100)
			ENDIF
		NEXT
	ELSE
		; 0.5.5 ~ 0.5.10, 스탯이 이미 어느정도 망쳐졌다 가정
		; 무기 시스템이 옛날건지 확인후, 무기 리셋
		FOR LOCAL, 0, CHARANUM
			; 고정 캐릭터는 무기 초기화 시켜 버리기
			IF IS_FIXED_CHARA(LOCAL)
				CALL WEAPON_INIT(LOCAL)
			ELSEIF _UPDATE_IS_EXISTING_WEAPON(TALENT:LOCAL:웨폰) && WEAPON_OWNED(LOCAL, TALENT:LOCAL:웨폰) == 0
				; 무기가 허가되지 않았으면 구 시스템이라 가정, 스킬 정리
				CALL _UPDATE_WEAPON_RMVSKILL(LOCAL)
				; 범용/아이 캐릭터는 장비한 무기가 허가 무기에 없으면 그냥 주기
				CALL WEAPON_ADD(LOCAL, TALENT:LOCAL:웨폰)
				CALL WEAPON_EQUIP(LOCAL, TALENT:LOCAL:웨폰)
			ELSEIF _UPDATE_IS_EXISTING_WEAPON(TALENT:LOCAL:웨폰) == 0 && _UPDATE_IS_FIXED_WEAPON(TALENT:LOCAL:웨폰) == 0
				; 버그 방지 양산형 돌격소총
				CALL WEAPON_EQUIP(LOCAL, 100)
			ENDIF
		NEXT
	ENDIF
	; 목걸이 있으면 장비 스탯 재계산
	PRINTL 목걸이 있으면 장비 재계산...
	FOR LOCAL, 0, CHARANUM
		; 목걸이 있으면 장비 장착 해제후 총력전장비스탯상승 초기화
		IF 장비타입(착용장비:LOCAL:2) == "목걸이"
			; 기존 장비번호 기록
			LOCAL:2 = 착용장비:LOCAL:0
			LOCAL:3 = 착용장비:LOCAL:1
			LOCAL:4 = 착용장비:LOCAL:2
			; 장비 해제
			SIF LOCAL:2 >= 0
				CALLFORM 총력전장비장착_{착용장비:LOCAL:0}(LOCAL, -1)
			SIF LOCAL:3 >= 0
				CALLFORM 총력전장비장착_{착용장비:LOCAL:1}(LOCAL, -1)
			SIF LOCAL:4 >= 0
				CALLFORM 총력전장비장착_{착용장비:LOCAL:2}(LOCAL, -1)
			; 총력전장비스탯상승 초기화
			FOR LOCAL:1, 0, 12
				총력전장비스탯상승:LOCAL:(LOCAL:1) = 0
			NEXT
			; 장비 장착
			SIF LOCAL:2 >= 0
				CALLFORM 총력전장비장착_{LOCAL:2}(LOCAL, 1)
			SIF LOCAL:3 >= 0
				CALLFORM 총력전장비장착_{LOCAL:3}(LOCAL, 1)
			SIF LOCAL:4 >= 0
				CALLFORM 총력전장비장착_{LOCAL:4}(LOCAL, 1)
		ENDIF
	NEXT
ENDIF

;-------------------------------------------------
