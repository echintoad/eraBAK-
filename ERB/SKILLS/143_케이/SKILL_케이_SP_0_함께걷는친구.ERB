;효과를 여기에 기술
@SKILL_143_SP_3_INVOKE(발동자, 발동번호, 발동측, 발동세력, 발동부대, 대상세력, 대상부대)
#DIM 발동자
#DIM 발동번호
#DIM 스킬
#DIMS 장르
#DIM 발동측
#DIM 발동세력
#DIM 발동부대
#DIM 대상측
#DIM 대상세력
#DIM 대상부대
대상측 = !발동측
PRINTFORML %ANAME(BATTLE_COMMANDER:대상측:COMBAT_SKILL_TARGET)%는 이 전투로 기술을 발동 할 수 없다!
BATTLE_SKILL_SEALED:대상측:COMBAT_SKILL_TARGET = 1
FOR LOCAL, 0, BATTLE_COMMANDER_NUM:대상측
	; 아리스 확인
	IF BATTLE_COMMANDER:발동측:LOCAL == NAME_TO_CHARA("아리스")
		BATTLE_SKILL_RATE:발동측:LOCAL += 15
		; 디버그 확인용
		PRINTFORML %ANAME(BATTLE_COMMANDER:대상측:LOCAL)%스킬 발동확률 +15 증가!
	ELSE
		BATTLE_SKILL_RATE:발동측:LOCAL += 5
		PRINTFORML %ANAME(BATTLE_COMMANDER:대상측:LOCAL)%스킬 발동확률 +5 증가!
	ENDIF
NEXT

