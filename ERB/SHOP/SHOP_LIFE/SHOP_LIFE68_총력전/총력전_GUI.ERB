; 총력전 전용 이미지
; RESULTS = HTML
; RETURN
; 
; 총력전 파티 번호, cell 전체 너비, 높이, yOffset
; 을 주면, 최대한 중앙으로 맟춤
; <div margin:'0 center'><img> 같은
; image_t 정리 할때 이동
@총력전_UI_이미지(sImage, iSize, iHeight, iPos)
#DIMS sImage ; 이미지 이름
#DIM iSize ; 전체 너비
#DIM iHeight ; 총력전 번호
#DIM iPos ; y offset

#DIM DYNAMIC iTmp
#DIM DYNAMIC iPad ; 옆 공간
#DIMS DYNAMIC sHtml

IF !SPRITECREATED(sImage)
	DEBUGPRINTFORML WARNING@총력전_UI_이미지: "%sImage%" 는 없는 이미지입니다
	RESULTS = <shape type='space' param='{iSize}'>
	RETURN
ENDIF

; 옆 공간 계산
; iSize - 500(image width) / 2
; DEBUGPRINTFORML image = %sImage%
; DEBUGPRINTFORML height:width = {SPRITEHEIGHT(sImage)}:{SPRITEWIDTH(sImage)}
iTmp = DIVIDE_ROUND(SPRITEWIDTH(sImage) * iHeight, MAX(SPRITEHEIGHT(sImage), 1))
iPad = (iSize - iTmp) / 2
; DEBUGPRINTFORML padding = {iPad}
IF iPad < 0
	iPad = 0
	; 너비를 iSize 로, iHeight, iPos 재 계산
	iTmp = DIVIDE_ROUND(SPRITEHEIGHT(sImage) * iSize, SPRITEWIDTH(sImage))
	; DEBUGPRINTFORML {iPos} + ({iHeight} - {iTmp}) / 2
	iPos = iPos + (iHeight - iTmp) / 2
	; DEBUGPRINTFORML = {iPos}
	iHeight = iTmp
ENDIF

; 이미지 틀어져서 추가 수정
sHtml = <shape type='space' param='{iPad}'>
sHtml += @"<img src='%sImage%' height='{iHeight}' ypos='{iPos}'>"
sHtml += @"<shape type='space' param='{iPad + 4}'>"

RESULTS = %sHtml%
; --- END 캐릭터 이미지 ---

; ----- 캐릭터 체력 -----
; 기본 체력 display
; 체력양 적으면 텍스트, 이상이면 바
@총력전_UI_캐릭터체력(캐릭터, 너비, ALIGN = "CENTER")
#DIM 캐릭터 ; 총력전 번호
#DIM 너비
#DIMS ALIGN

#DIMS DYNAMIC sTmp
#DIM DYNAMIC iTmp

IF 총력전_체력:캐릭터 >= 1000
	iTmp = GETVAR_RAIDSTAT_SUM(캐릭터, "최대체력")
	; BARSTR 가 너무 길면 오류남
	IF 너비 > 85
		; iTmp:1 = MIN(너비 - 5, 80)
		sTmp = HP:%BARSTR(총력전_체력:캐릭터, iTmp, 80)%
		sTmp = %ALIGN_TEXT(sTmp, 너비, ALIGN)%
	ELSEIF 너비 > 8
		sTmp = HP:%BARSTR(총력전_체력:캐릭터, iTmp, 너비 - 5)%
	ELSE
		sTmp = %BARSTR(총력전_체력:캐릭터, iTmp, 너비 - 2)%
	ENDIF
ELSE
	iTmp = GETVAR_RAIDSTAT_SUM(캐릭터, "최대체력")
	sTmp = HP:{총력전_체력:캐릭터}/{iTmp}
	SIF 너비 >= STRLENS(sTmp)
		GOTO SKIP
	sTmp = {총력전_체력:캐릭터}/{iTmp}
	SIF 너비 >= STRLENS(sTmp)
		GOTO SKIP
	sTmp = HP:{총력전_체력:캐릭터}
	SIF 너비 >= STRLENS(sTmp)
		GOTO SKIP
	sTmp = {총력전_체력:캐릭터}
	$SKIP
	sTmp = %ALIGN_TEXT(sTmp, 너비, ALIGN)%
ENDIF

RESULTS = %sTmp%

; RESULTS:0 = 체력
; RESULTS:1 = 보호막
; 체력양 적으면 텍스트, 이상이면 바
@총력전_UI_캐릭터보호체력(캐릭터, 너비) ; ALIGN = "CENTER")
#DIM 캐릭터 ; 총력전 번호
#DIM 너비
; #DIMS ALIGN

; #DIMS DYNAMIC sShield ; 보호막
; #DIMS DYNAMIC sHp ; 체력
; #DIM DYNAMIC iHpType ; 체력 0=000 1=[000] 2=[00/00] 3=[BAR]
; #DIM DYNAMIC iShieldType ; 보호막 -1=S 0=000 1=[000] 3=[BAR]
#DIM DYNAMIC iShieldLen ; 보호막 너비
#DIM DYNAMIC iHpLen ; 체력 너비
#DIM DYNAMIC iTmp, 3
#DIMS DYNAMIC sTmp

RESULTS:0 =
RESULTS:1 =

; 체력
IF 총력전_체력:캐릭터 >= 1000
	; 바 사용
	iTmp:0 = GETVAR_RAIDSTAT_SUM(캐릭터, "최대체력")
	iTmp:1 = 총력전_상태효과_합계(캐릭터, 상효_종류_보호막, 총력전_방식_지속)
	iTmp:2 = iTmp:0 + iTmp:1
	iHpLen = DIVIDE_ROUND(너비 * iTmp:0, iTmp:2)
	iShieldLen = 너비 - iHpLen
	; 너무 짧으면 (000)[체력바] 로
	IF iHpLen < 5 || iShieldLen < 5
		iTmp = 총력전_상태효과_합계(캐릭터, 상효_종류_보호막, 총력전_방식_지속)
		RESULTS:1 = [{iTmp}]
		iShieldLen = STRLENS(RESULTS:1)
		iHpLen = 너비 - iShieldLen
		; iHpLen < 3 은 나중에 처리
		IF iHpLen < 5
			; 보호막
			RESULTS:1 = {iTmp}
			iShieldLen = STRLENS(RESULTS:1)
			; 체력바 길이 조정
			iHpLen = 너비 - iShieldLen
		ENDIF
	ENDIF
	; BARSTR가 너무 길면 오류남
	; iTmp보다 길면 조정
	iTmp = 80
	IF iHpLen > iTmp || iShieldLen > iTmp
		IF iHpLen >= iShieldLen
			iShieldLen = DIVIDE_ROUND(iTmp * iShieldLen, iHpLen)
			iHpLen = iTmp
		ELSE
			iHpLen = DIVIDE_ROUND(iTmp * iHpLen, iShieldLen)
			iShieldLen = iTmp
		ENDIF
	ENDIF
	; 보호막 없으면 바 설정
	IF STRLENS(RESULTS:1) <= 0
		RESULTS:1 = %BARSTR(1, 1, iShieldLen - 2)%
	ENDIF
	; 체력 바 설정
	iTmp = GETVAR_RAIDSTAT_SUM(캐릭터, "최대체력")
	RESULTS:0 = %BARSTR(총력전_체력:캐릭터, iTmp, iHpLen - 2)%
ELSE
	; 체력 1000 이하
	; 너비 계산, 보호막
	iTmp = 총력전_상태효과_합계(캐릭터, 상효_종류_보호막, 총력전_방식_지속)
	RESULTS:1 = [{iTmp}]
	iShieldLen = STRLENS(RESULTS:1)
	; 체력
	iTmp = GETVAR_RAIDSTAT_SUM(캐릭터, "최대체력")
	RESULTS:0 = [{총력전_체력:캐릭터}/{iTmp}]
	iHpLen = STRLENS(RESULTS:0)
	IF (iShieldLen + iHpLen) <= 너비
		GOTO 패딩
	ENDIF
	; 최대체력 제거
	RESULTS:0 = [{총력전_체력:캐릭터}]
	iHpLen = STRLENS(RESULTS:0)
	IF (iShieldLen + iHpLen) <= 너비
		GOTO 패딩
	ENDIF
	; [] 제거
	iTmp = 총력전_상태효과_합계(캐릭터, 상효_종류_보호막, 총력전_방식_지속)
	RESULTS:1 = {iTmp}
	iShieldLen = STRLENS(RESULTS:1)
	IF (iShieldLen + iHpLen) <= 너비
		GOTO 패딩
	ENDIF
	; 보호막 숫자 제거, S[000]
	iShieldLen = 1
	RESULTS:1 = S
ENDIF
$패딩
; ALIGN 필요한지 확인
iTmp = iHpLen + iShieldLen
IF 너비 > iTmp
	; 패딩
	; 보호막 세팅
	iTmp = DIVIDE_ROUND(너비 - iTmp, 2)
	iTmp = iTmp + iShieldLen
	RESULTS:1 = %ALIGN_TEXT(RESULTS:1, iTmp, "LEFT")%
	; 체력
	iTmp = 너비 - iTmp
	RESULTS:0 = %ALIGN_TEXT(RESULTS:0, iTmp, "RIGHT")%
ENDIF

; 파티 선택용 최대 체력
@총력전_UI_캐릭터최대체력(캐릭터, 너비)
#DIM 캐릭터 ; 총력전 번호
#DIM 너비

#DIMS DYNAMIC sTmp

IF 너비 > 6
	sTmp = HP:{GETVAR_RAIDSTAT_SUM(캐릭터, "최대체력")}
	sTmp = %ALIGN_TEXT(sTmp, 너비, "CENTER")%
ELSE
	sTmp = {GETVAR_RAIDSTAT_SUM(캐릭터, "최대체력")}
	sTmp = %ALIGN_TEXT(sTmp, 너비, "CENTER")%
ENDIF

RESULTS = %sTmp%
; ----- END 캐릭터 체력 -----

; 초기 스탯 포함한 스탯, 칼라 포함
@총력전_UI_스탯_0(캐릭터, 너비, 스탯이름)
#DIM 캐릭터
#DIM 너비
#DIMS 스탯이름

#DIM DYNAMIC 초기스탯값
#DIM DYNAMIC 스탯값
#DIMS DYNAMIC 스탯문자열
#DIM DYNAMIC iDif
#DIMS DYNAMIC sDif
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 스탯값
초기스탯값 = GETVAR_RAIDSTAT_INIT(캐릭터, 스탯이름)
스탯값 = GETVAR_RAIDSTAT_SUM(캐릭터, 스탯이름)
iDif = 스탯값 - 초기스탯값
IF iDif > 0
	sDif = +{iDif}
	스탯문자열 = <font color='%INT_TO_HEXSTR(칼라_파파랑)%'>{스탯값}</font>
ELSEIF iDif < 0
	sDif = {iDif}
	스탯문자열 = <font color='%INT_TO_HEXSTR(칼라_빨강)%'>{스탯값}</font>
ELSE
	sDif = 
	스탯문자열 = {스탯값}
ENDIF

sTmp = {스탯값}({초기스탯값}%sDif%)
IF STRLENS(sTmp) <= 너비
	iTmp = 너비 - STRLENS(sTmp)
	RESULTS = %스탯문자열%({초기스탯값}%sDif%)%TOSTR_SPACE(iTmp)%
	RETURN
ENDIF
IF iDif != 0
	sTmp = {스탯값}(%sDif%)
ELSE
	sTmp = {스탯값}
ENDIF
IF STRLENS(sTmp) <= 너비
	iTmp = 너비 - STRLENS(sTmp)
	RESULTS = %스탯문자열%(%sDif%)%TOSTR_SPACE(iTmp)%
	RETURN
ENDIF
; <font> 떄문에 작동 안할거임...
; RESULTS = %ALIGN_TEXT(스탯문자열, 너비, "LEFT")%
IF iDif > 0
	RESULTS = %ALIGN_TEXT(@"{스탯값}+", 너비, "LEFT")%
ELSEIF iDif < 0
	RESULTS = %ALIGN_TEXT(@"{스탯값}-", 너비, "LEFT")%
ELSE
	RESULTS = %ALIGN_TEXT(@"{스탯값}", 너비, "LEFT")%
ENDIF

; 총력전_스킬_조준, 위치, 범위 참조후
; + 아군 버프 선택?
; 총력전_UI_칼라 설정
@총력전_UI_칼라계산
#DIM DYNAMIC 캐릭번호
#DIM DYNAMIC 범위, 총력전_캐릭터수
#DIM DYNAMIC iTmp, 3
; 리셋?
VARSET 총력전_UI_칼라, -1

FOR 캐릭번호, 0, 총력전_캐릭터수
	VARSIZE 총력전_스킬_조준
	FOR iTmp, 0, RESULT:1
		IF 총력전_스킬_조준:캐릭번호:iTmp >= 0 || 총력전_스킬_위치:캐릭번호:iTmp >= 0
			; 범위 확인
			IF 총력전_스킬_범위:캐릭번호:iTmp >= 0
				IF 총력전_스킬_조준:캐릭번호:iTmp >= 0
					CALL 총력전_목표_범위(범위, 총력전_스킬_조준:캐릭번호:iTmp, -1, 총력전_스킬_범위:캐릭번호:iTmp)
				ELSEIF 총력전_스킬_위치:캐릭번호:iTmp >= 0
					; 위치 -> 총력전 번호, 나중에 위치 -> 범위 함수 있으면 편할듯?
					iTmp:1 = FINDELEMENT(총력전_위치, 총력전_스킬_위치:캐릭번호:iTmp)
					CALL 총력전_목표_범위(범위, iTmp:1, -1, 총력전_스킬_범위:캐릭번호:iTmp)
				ENDIF
				; 총력전_UI_칼라 설정된거 없으면 설정
				FOR iTmp:1, 0, 총력전_캐릭터수
					iTmp:2 = 범위:(iTmp:1)
					SIF iTmp:2 < 0
						BREAK
					IF 총력전_UI_칼라:(iTmp:2) == -1
						총력전_UI_칼라:(iTmp:2) = 칼라_오렌지
					ENDIF
				NEXT
			ENDIF
			IF 총력전_스킬_조준:캐릭번호:iTmp >= 0
				; 총력전_UI_칼라 강색 설정
				iTmp:1 = 총력전_스킬_조준:캐릭번호:iTmp
				총력전_UI_칼라:(iTmp:1) = 칼라_빨강
			; ELSE
			; 	; 총력전_UI_칼라 설정된거 없으면 설정
			; 	iTmp:1 = FINDELEMENT(총력전_위치, 총력전_스킬_위치:캐릭번호:iTmp)
			; 	IF 총력전_UI_칼라:(iTmp:1) == -1
			; 		총력전_UI_칼라:(iTmp:1) = 칼라_오렌지
			; 	ENDIF
			ENDIF
		ENDIF
	NEXT
NEXT

; #endregion == Utility ==