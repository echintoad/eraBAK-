; ====================
; 총력전용 GUI
; 전체 너비는 ~120 정도로, 나누기 쉽게
; 
; 됄수있으면 보스.ERB 에서도 쓸수 있게
; 
; 작업노트
; era 전체 너비는 124?
; 한글 == 스페이스 * 2
; 굴림체 비율 높이:너비 2:1? 100:50?
; 모바일에선 GDRAW 관련 흰색 박스로 나옴
; 
; html center 해결법 알면 변경
; _FUNCTION 에 textcenter 같은거 만들면/찾으면 사용
; 
; ERH 에 sHtml(sHtmlGrp) 저장? (+sHtml_cnt)
; sHtmlGrp 세팅 -> CLEARLINE -> HTML_PRINT
; 화면 깜빡임이 너무 심하면
; 
; 사용된 alt characters
; ►◄♦ <- 모바일에서 사이즈 다름? 굴림체가 아닌가?
; ====================
; --- 파티 이미지 ID ---
; 총력전:ID 에 따라 정리하는 1~6 + 8 명 용 프레임
; 파티 선택용
; -------------------------------

; 주 총력전 화면
; 어떤 타입이냐 따라 버튼을 어떻게 활성화 할지
@총력전_UI_Main(선택종류_아군, 선택종류_적군 = 0, 선택모드 = 0) ; 줄강제 = 0,
#DIM 선택종류_아군
#DIM DYNAMIC 선택종류_적군
#DIM DYNAMIC 선택모드 ; (스킬)선택용 버튼으로 변경

#DIM DYNAMIC 시작위치_0 = -1 ; 한줄
#DIM DYNAMIC 시작위치_1, 2 ; 두줄
#DIM DYNAMIC 보스줄수 ; 보스쪽 HTML 줄수, 기록용
#DIM DYNAMIC 캐릭터줄수 ; 캐릭터쪽 HTML 줄수, 계산용
#DIM DYNAMIC 텍트스줄수 ; 텍스트 HTML 줄수, 계산용
#DIM DYNAMIC 줄수 ; 캐릭터 몇줄이 필요한지
#DIMS DYNAMIC sHtml_end ; 시작과 끝 부분
#DIM DYNAMIC iTmp, 3
; #DIMS DYNAMIC sTmp, 2
#DIM DYNAMIC iBlank

; 조준 칼라 계산
CALL 총력전_UI_칼라계산

; 보스.ERB 에 특수 UI 있는지 확인
; RETURN 1 이면 보스 UI 에 자체 UI가 있다 가정
RESULT = 0
TRYCALLFORM 총력전_보스_UI_{총력전_보스}(선택종류_아군, 선택종류_적군, 선택모드)
IF RESULT == 1
	; 총려전_HTML 생기면 보스 UI 에서 설정, 여기서 HTML_PRINT 처리?
	RETURN
ENDIF

sHtml_end = |%TOSTR_REPEAT("=",121)%|

시작위치_1:0 = 0
시작위치_1:1 = 5
시작위치_0 = -1
줄수 = 0
; LATER: 적군 줄수 확인?
IF 선택종류_아군 == 총력전_선택_엄폐물 || 선택종류_아군 == 총력전_선택_빈공간 || 선택종류_아군 == 총력전_선택_전체
	줄수 = 2
ELSE
	; 팀 0 위치 확인
	FOR iTmp, 0, 5
		; 위치에 있는 총력전 ID
		iTmp:1 = FINDELEMENT(총력전_위치, iTmp)
		; DEBUGPRINTFORML chk ID:{iTmp:1}, 상태:{총력전_상태:(iTmp:1)}, 팀:{총력전_팀:(iTmp:1)}
		; 못찾으면 -1?
		IF iTmp:1 >= 0 && 총력전_상태:(iTmp:1) ; && 총력전_팀:(iTmp:1) == 0
			시작위치_0 = 0
			줄수 ++
			BREAK
		ENDIF
		; 엄폐물
		iTmp:2 = FINDELEMENT(총력전_엄폐물_위치, iTmp)
		IF iTmp:2 >= 0 && 총력전_엄폐물_소비방식:(iTmp:2):0 > 0
			시작위치_0 = 0
			줄수 ++
			BREAK
		ENDIF
	NEXT
	; 못 찾았으면 앞줄에 있다 가정
	SIF 시작위치_0 == -1
		시작위치_0 = 5
	FOR iTmp, 5, 10
		iTmp:1 = FINDELEMENT(총력전_위치, iTmp)
		; DEBUGPRINTFORML chk ID:{iTmp:1}, 상태:{총력전_상태:(iTmp:1)}, 팀:{총력전_팀:(iTmp:1)}
		IF iTmp:1 >= 0 && 총력전_상태:(iTmp:1) ; && 총력전_팀:(iTmp:1) == 0
			줄수 ++
			BREAK
		ENDIF
		; 엄폐물
		iTmp:2 = FINDELEMENT(총력전_엄폐물_위치, iTmp)
		IF iTmp:2 >= 0 && 총력전_엄폐물_소비방식:(iTmp:2):0 > 0
			줄수 ++
			BREAK
		ENDIF
	NEXT
ENDIF

; 해더
CALL 총력전_UI_줄추가(sHtml_end)

; 적 파티 프레임
RESULT = 0
TRYCCALLFORM 총력전_보스_UI_프레임_{총력전_보스}(선택종류_적군)
	보스줄수 = RESULT
CATCH
	; 없으면 팀1 확인, 수 만큼 1자로
	iTmp = MATCH(총력전_팀, 1)
	iBlank = FINDELEMENT(총력전_팀, 1)
	iBlank = 총력전_위치:iBlank
	; DEBUGPRINTFORML iBlank = {iBlank}
	IF FLAG:화상설정
		보스줄수 = 15
	ELSE
		보스줄수 = 5
	ENDIF
	; 이미지, 이름 + 체력만
	CALL 총력전_UI_프레임_3(iTmp, iBlank, 보스줄수, 선택종류_적군)
ENDCATCH
; 바: 턴수, 코스트, 게임 종료
CALL 총력전_UI_줄추가(sHtml_end)
CALL 총력전_UI_바_상
CALL 총력전_UI_줄추가(RESULTS)
CALL 총력전_UI_줄추가(sHtml_end)

; 줄? 계산
IF FLAG:화상설정
	캐릭터줄수 = 21
ELSE
	캐릭터줄수 = 17 ; 15
ENDIF
; 전체 허용 줄(48) - 캐릭터 - 보스
텍트스줄수 = 48 - 캐릭터줄수 - 보스줄수

; 전투 로그
CALL 총력전_UI_텍스트(텍트스줄수, 115)
; CALL 총력전_UI_텍스트(12, 115, 2)
; CALL 총력전_UI_텍스트_단선(1, 115, "| ) ", " ( |")
; HTML_PRINT RESULTS
; CALL 총력전_UI_텍스트_단선(0, 115, "|) )", "( (|")
; HTML_PRINT RESULTS

; 바: 다음턴, 텍스트 컨트롤러
CALL 총력전_UI_줄추가(sHtml_end)
CALL 총력전_UI_바_하(선택모드)
CALL 총력전_UI_줄추가(RESULTS)
CALL 총력전_UI_줄추가(sHtml_end)
; 아군 파티 프레임
IF 줄수 == 2
	IF 총력전_캐릭터정보 == -1
		CALL 총력전_UI_프레임_2(5, 시작위치_1, 캐릭터줄수, 선택종류_아군)
	ELSE
		CALL 총력전_UI_프레임_2(5, 시작위치_1, 캐릭터줄수 - 8, 선택종류_아군)
		CALL 총력전_UI_줄추가(sHtml_end)
		CALL 총력전_UI_부품_캐릭터정보_0(총력전_캐릭터정보)
	ENDIF
ELSE
	IF 총력전_캐릭터정보 == -1
		CALL 총력전_UI_프레임_2(5, 시작위치_0, 캐릭터줄수, 선택종류_아군)
	ELSE
		CALL 총력전_UI_프레임_2(5, 시작위치_0, 캐릭터줄수 - 8, 선택종류_아군)
		CALL 총력전_UI_줄추가(sHtml_end)
		CALL 총력전_UI_부품_캐릭터정보_0(총력전_캐릭터정보)
	ENDIF	
ENDIF
CALL 총력전_UI_줄추가(sHtml_end)
CALL 총력전_UI_출력(3, 1)
; #region == 상/하 바 ==
; ====================
; 바: 턴수, 코스트, 게임 종료
; 123 - 4 - 4
@총력전_UI_바_상(너비 = 115, sPadStart = "| | ", sPadEnd = " | |")
#DIM DYNAMIC 너비 ; sPad 를 뺀 너비
#DIMS DYNAMIC sPadStart ; 줄 왼쪽 끝
#DIMS DYNAMIC sPadEnd ; 줄 오른쪽 끝

#DIM DYNAMIC iSect, 3
#DIMS DYNAMIC sSect, 3
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 턴수
sTmp = 턴:{총력전_턴수}/{총력전_턴_종료}
iTmp = 12
sSect:0 += @"%ALIGN_TEXT(sTmp, iTmp, "CENTER")%|"
iSect:0 = iTmp + 1
; 코스트
sTmp = 코스트:{총력전_코스트}/{총력전_코스트_최대}
iTmp = 14
sSect:0 += @"%ALIGN_TEXT(sTmp, iTmp, "CENTER")%|"
iSect:0 += iTmp + 1
; 종료 버튼
IF 총력전_전투단계 == 총력전_전투단계_종료
	; 종료 취소
	iTmp = 10
	CALL 총력전_UI_버튼("취소", iTmp, 1, -98, 8)
	sSect:2 = %RESULTS%
	iSect:2 = iTmp
	; 종료 확인
	iTmp = 10
	CALL 총력전_UI_버튼("나가기", iTmp, 1, -99, 8)
	sSect:2 += @"%RESULTS%"
	iSect:2 += iTmp
ELSE
	; 취소
	iSect:2 = 15
	CALL 총력전_UI_버튼("취소 / 나가기", iSect:2, 1, -99, 8)
	sSect:2 = %RESULTS%
ENDIF
; 중안 공백 처리
iSect:1 = 너비 - iSect:0 - iSect:2
sSect:1 = %TOSTR_SPACE(iSect:1)%

RESULTS = %sPadStart%%sSect:0%%sSect:1%%sSect:2%%sPadEnd%
; CALL 총력전_UI_줄추가(RESULTS)

; 바: 다음턴, 텍스트 컨트롤러
@총력전_UI_바_하(선택모드 = 0, 너비 = 115, sPadStart = "| | ", sPadEnd = " | |")
#DIM DYNAMIC 선택모드 ; (스킬)선택용 버튼으로 변경
#DIM DYNAMIC 너비 ; sPad 를 뺀 너비
#DIMS DYNAMIC sPadStart ; 줄 왼쪽 끝
#DIMS DYNAMIC sPadEnd ; 줄 오른쪽 끝

#DIM DYNAMIC iSect, 2 ; 0 = 좌/우, 1 = 중
#DIMS DYNAMIC sSect, 3
#DIM DYNAMIC iTmp, 3
#DIMS DYNAMIC sTmp, 3

; 턴 종료 강조, 필요하면 활성화
; #DIM DYNAMIC 코스트합
; #DIM DYNAMIC 시전가능

; 미리 Section 나눠놓기 30:r:30
; "[전 선택 취소] [선택 리셋]" = 26
iSect:0 = 30
iSect:1 = 너비 - iSect:0 * 2
; 왼쪽: 선택 취소/리셋
IF 선택모드 == 1
	; 전 선택 취소
	iTmp = 16
	CALL 총력전_UI_버튼("전 선택 취소", iTmp, 1, -2, 8)
	sSect:0 = %RESULTS%
	iTmp:1 = iTmp
	; 선택 리셋
	iTmp = 12
	CALL 총력전_UI_버튼("선택 리셋", iTmp, 1, -3, 8)
	sSect:0 += @"%RESULTS%"
	iTmp:1 += iTmp
	; 공백 추가
	iTmp = iSect:0 - iTmp:1
	IF iTmp > 0
		sSect:0 += @"%TOSTR_SPACE(iTmp)%"
	ENDIF
ELSE
	sSect:0 = %TOSTR_SPACE(iSect:0)%
ENDIF
; 중: 다음턴
IF 선택모드 == 1
	CALL 총력전_UI_버튼("선택 종료", iSect:1, 1, -1, 16)
	sSect:1 = %RESULTS%
ELSE
	; == 턴 종료 강조 ==
	; IF 총력전_전투단계 != 총력전_전투단계_플레이어
	; 	시전가능 = 1
	; 	GOTO 확인스킵
	; ENDIF
	; ; 시전중인 코스트 합 계산
	; FOR iTmp:1, 0, 총력전_캐릭터수
	; 	iTmp = 총력전_스킬_시전:(iTmp:1) ; 캐릭터 번호
	; 	SIF iTmp == -1
	; 		BREAK
	; 	코스트합 += 총력전_스킬_코스트:iTmp
	; NEXT
	; ; 시전 가능한 스킬 확인
	; IF 총력전_코스트 - 코스트합 > 0
	; 	FOR iTmp, 0, 총력전_캐릭터수
	; 		; 행동불능, 소환수 무시 || 스킬 쿨 다운 1 이상
	; 		SIF 총력전_상태:iTmp != 총력전_상태_보통 || 총력전_스킬_쿨다운:iTmp > 0 || FINDELEMENT(총력전_스킬_시전, iTmp) >= 0
	; 			CONTINUE
	; 		; 시전가능한 스킬 있으면 시전가능 = 1, BREAK
	; 		; 코스트 0은 무시? 드히나 0 코스트 공격 스킬은?
	; 		IF 총력전_팀:iTmp == 0 && 총력전_스킬_코스트:iTmp <= 총력전_코스트 - 코스트합
	; 			시전가능 = 1
	; 			BREAK
	; 		ENDIF
	; 	NEXT
	; ENDIF
	; $확인스킵
	; IF 시전가능
	; 	CALL 총력전_UI_버튼("다음턴", iSect:1, 1, -1, 16)
	; ELSE
	; 	CALL 총력전_UI_버튼("★ 다음턴 ★", iSect:1, 1, -1, 16)
	; ENDIF
	; sSect:1 = %RESULTS%
	; == 위/아래 중 하나만 활성화 ==
	CALL 총력전_UI_버튼("다음턴", iSect:1, 1, -1, 16)
	sSect:1 = %RESULTS%
ENDIF
; 오른쪽: 텍스트 조정
iTmp:0 = 8
CALL 총력전_UI_버튼("△", iTmp:0, 1, -5, 6)
sTmp:0 = %RESULTS%
iTmp:1 = 8
CALL 총력전_UI_버튼("▽", iTmp:1, 1, -6, 6)
sTmp:1 = %RESULTS%
iTmp:2 = 10
CALL 총력전_UI_버튼("최하단", iTmp:2, 1, -7, 6)
sTmp:2 = %RESULTS%
; 공백 계산
iTmp = iSect:0 - iTmp:0 - iTmp:1 - iTmp:2
sSect:2 = %TOSTR_SPACE(iTmp)%%sTmp:0%%sTmp:1%%sTmp:2%

RESULTS = %sPadStart%%sSect:0%%sSect:1%%sSect:2%%sPadEnd%
; CALL 총력전_UI_줄추가(RESULTS)

; #endregion == 상/하 바 ==

; #region == 프레임 0 ==
; 총력전 번호에 따라 증분(?) 순서대로 기본정보 배치
; ====================
; 기본 프레임 옵션
; 파티 선택용, 총력전 번호 기반
@총력전_UI_프레임_0(인원수, 시작번호 = 0, 스탯표시 = 0, bBtn = 0)
#DIM 인원수
#DIM DYNAMIC 시작번호
#DIM DYNAMIC 스탯표시
#DIM DYNAMIC bBtn ; 버튼 작동 여부, 총력전_선택_ 참조

; 전체너비를 스페이스바로
; arg 로 가능하긴 하니까 따로 놔둠
#DIM CONST iSpace = 120
; 캐릭터 부분 너비
#DIM DYNAMIC 너비
#DIMS DYNAMIC sHtml_end ; 시작과 끝 부분
#DIMS DYNAMIC sHtml_div ; 나누는 선
#DIMS DYNAMIC sHtml_blank ; 캐릭터 사이 선 있는 부분
#DIM DYNAMIC iTmp, 4
#DIMS DYNAMIC sTmp, 3

; 너비 계산
; 전체너비 / 인원수 - 장식
너비 = DIVIDE_ROUND(iSpace, 인원수) - 3
; 스페이스바 너미 * 폰트 너비?

; 라인 세팅
sHtml_end = |%TOSTR_REPEAT("=",121)%|
FOR iTmp, 0, 인원수
	iTmp:1 = iTmp:0 + 시작번호 ; 총력전 번호
	IF iTmp == 0
		sHtml_blank += @"| "
		sHtml_div += @"|-"
	ENDIF 
	sHtml_blank += @"|%TOSTR_SPACE(너비)%| "
	IF 총력전_상태:(iTmp:1) == 0
		sHtml_div += @"|%TOSTR_REPEAT("-",너비)%|-"
	ELSE
		iTmp:2 = 너비 / 4
		iTmp:3 = 너비 - iTmp:2 * 2
		sTmp = %TOSTR_REPEAT("-",iTmp:2)%%TOSTR_SPACE(iTmp:3)%%TOSTR_REPEAT("-",iTmp:2)%
		sHtml_div += @"|%sTmp%|-" 
	ENDIF
	IF iTmp == 인원수 - 1
		sHtml_blank += @"|"
		sHtml_div += @"|"
	ENDIF
NEXT

CALL 총력전_UI_줄추가(sHtml_end)
IF FLAG:화상설정
	CALL 총력전_UI_줄(인원수, 너비, 0, 시작번호, "이름_0", iTmp, sTmp, bBtn)
	CALL 총력전_UI_줄추가(RESULTS)
	IF 너비 < 10
		CALL 총력전_UI_프레임_0_이미지(인원수, 너비, sHtml_blank, 0, 시작번호, 5)
	ELSE
		CALL 총력전_UI_프레임_0_이미지(인원수, 너비, sHtml_blank, 0, 시작번호, 9)
	ENDIF
ELSE
	CALL 총력전_UI_줄추가(sHtml_blank)
	CALL 총력전_UI_줄(인원수, 너비, 0, 시작번호, "이름_0", iTmp, sTmp, bBtn)
	CALL 총력전_UI_줄추가(RESULTS)
	CALL 총력전_UI_줄추가(sHtml_blank)
ENDIF
IF 스탯표시 == 1
	CALL 총력전_UI_줄추가(sHtml_div)
	CALL 총력전_UI_줄(인원수, 너비, 0, 시작번호, "최대체력_0", iTmp, sTmp)
	CALL 총력전_UI_줄추가(RESULTS)
	CALL 총력전_UI_부품_스탯(인원수, 너비, 0, 시작번호, 4)
ENDIF
CALL 총력전_UI_줄추가(sHtml_end)

; 정리후 부품으로 이동
@총력전_UI_프레임_0_이미지(인원수, 너비, sHtml_blank, 위치사용 = 0, 시작번호 = 0, iSize = 7)
#DIM 인원수
#DIM 너비 ; 셀 너비
#DIMS sHtml_blank ; 공백선은 미리 세팅해놓고 받기
#DIM DYNAMIC 위치사용
#DIM DYNAMIC 시작번호
; 사이즈 변화 원하면 활성화
#DIM DYNAMIC iSize ; 라인 수, 4 ~ 

#DIMS DYNAMIC sHtml_break ; sHtml_break 딴데도 필요하면 ARG 로 변경
#DIMS DYNAMIC sHtml_img
#DIMS DYNAMIC sHtml_frame
#DIM DYNAMIC 캐릭터 ; 총력전 번호
#DIM DYNAMIC iSizeIsOdd
#DIM DYNAMIC iImgSize ; pixel
#DIM DYNAMIC iImgYPos ; pixel
#DIM DYNAMIC iFrameYPos ; pixel
#DIM DYNAMIC 너비픽셀
#DIM DYNAMIC iTmp, 3
#DIMS DYNAMIC sTmp

; 나중에 폰트 사이즈 비례계산 필요할 수도
; 너비 (space) 를 픽셀로 계산
너비픽셀 = 너비 * 50
; iSize clamp
iSize = MAX(iSize, 4)
iSizeIsOdd = iSize % 2
; 이미지 높이 + Y Pos 계산
iImgSize = iSize * 100 - 50
IF iSizeIsOdd
	iImgYPos = (iSize * 100 - 300) / -2 + 30
	iFrameYPos = iImgYPos - 200
ELSE
	iImgYPos = (iSize * 100 - 200) / -2 + 30
	iFrameYPos = iImgYPos - 100
ENDIF
; iImgYPos = iSize * 100 - 50

; 세팅
CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "__", iTmp, sTmp, 0, "|=|", "|=|", "|=|")
sHtml_break = %RESULTS%
FOR iTmp, 0, 인원수
	; 총력전 번호
	캐릭터 = 총력전_UI_캐릭터번호(위치사용, iTmp + 시작번호)
	IF iTmp == 0
		sHtml_img += @"<shape type='space' param='10'>%TOSTR_SPACE(2)%"
		sHtml_frame += @"<shape type='space' param='10'>%TOSTR_SPACE(2)%"
	ENDIF
	; 총력전 스프라이트 이름
	IF 캐릭터 < 0
		sTmp =
	ELSE
		sTmp = %총력전_이미지:(캐릭터)%
	ENDIF
	IF STRLENS(sTmp)
		CALL 총력전_UI_이미지(sTmp, 너비픽셀, iImgSize, iImgYPos)
		sHtml_img += @" %RESULTS%  "
		; 이미지 사이즈가 맞으면 프레임 포함
		IF SPRITEWIDTH(sTmp) == 200 && SPRITEHEIGHT(sTmp) == 240 && FLAG:화상범위표시
			sTmp = 프레임_{FLAG:화상범위표시}_통상
			CALL 총력전_UI_이미지(sTmp, 너비픽셀, iImgSize, iFrameYPos)
			sHtml_frame += @" %RESULTS%  "
		ELSE
			sHtml_frame += @" %TOSTR_SPACE(너비)%  "
		ENDIF
	ELSE
		sHtml_img += @" %TOSTR_SPACE(너비)%  "
		sHtml_frame += @" %TOSTR_SPACE(너비)%  "
	ENDIF
NEXT

; 프린트
IF iSizeIsOdd
	iTmp = (iSize - 5) / 2
ELSE
	iTmp = (iSize - 4) / 2
ENDIF
REPEAT iTmp
	CALL 총력전_UI_줄추가(sHtml_blank)
REND
IF iSizeIsOdd
	CALL 총력전_UI_줄추가(sHtml_break)
	CALL 총력전_UI_줄추가(sHtml_img)
	CALL 총력전_UI_줄추가(sHtml_break)
	CALL 총력전_UI_줄추가(sHtml_frame)
	CALL 총력전_UI_줄추가(sHtml_break)
ELSE
	CALL 총력전_UI_줄추가(sHtml_break)
	CALL 총력전_UI_줄추가(sHtml_img)
	CALL 총력전_UI_줄추가(sHtml_frame)
	CALL 총력전_UI_줄추가(sHtml_break)
ENDIF
REPEAT iTmp
	CALL 총력전_UI_줄추가(sHtml_blank)
REND

; #endregion == 프레임 0 ==
 

; #region == 프레임 2 ==
; 전투용, 위치 기반 ver2
; 왼쪽 -> 오른쪽
; 캐릭터당 필요한 줄만 출력
@총력전_UI_프레임_2(인원수, 시작위치, cell_height = 13, bBtn = 총력전_선택_캐릭터)
#DIM 인원수 ; 한 줄당 인원수
#DIM REF 시작위치, 0 ; 시작위치 번호
#DIM DYNAMIC cell_height ; 셀 높이 6 ~ 21?
#DIM DYNAMIC bBtn ; 버튼 작동 여부, 총력전_선택_ 참조

#DIM CONST iSpace = 120

#DIMS DYNAMIC sHtml_end ; 줄 사이 브레이크
; #DIMS DYNAMIC sHtml_div, 5 ; 나누는 선, 필요하면 증가
#DIMS DYNAMIC sHtml_blank ; 캐릭터 사이 선 있는 부분
#DIM DYNAMIC cell_height_remainder ; 남은 셀 높이
#DIM DYNAMIC cell_height_line, 6 ; 줄당 셀 높이
; #DIM DYNAMIC cell_height_img, 6 ; 셀 이미지 높이
#DIM DYNAMIC 캐릭터있음, 6 ; 줄에 캐릭터 있는지
#DIM DYNAMIC 화상있음, 6 ; 줄에 캐릭터 화상 있는지
#DIM DYNAMIC 엄폐물있음, 6 ; 엄폐물 있는지
#DIM DYNAMIC 보호막있음, 6 ; 보호막 있는지
#DIM DYNAMIC 줄수 ; 시작위치 SIZE
#DIM DYNAMIC 너비 ; 캐릭터 부분 너비
#DIM DYNAMIC 줄당스탯 ; 한줄당 스탯수
#DIM DYNAMIC 캐릭번호 ; 임시 캐릭터 번호
#DIM DYNAMIC 위치번호 ; 임시 위치 번호
#DIM DYNAMIC iTmp, 4
#DIMS DYNAMIC sTmp, 1

; 너비 계산
; 전체너비 / 인원수 - 장식
너비 = DIVIDE_ROUND(iSpace, 인원수) - 3
; 줄수 계산
VARSIZE 시작위치
줄수 = RESULT

; 라인 세팅
sHtml_end = |-|%TOSTR_REPEAT("-",iSpace - 3)%|-|
CALL 총력전_UI_줄(인원수, 너비, 1, 0, "__", iTmp, sTmp)
sHtml_blank = %RESULTS%
; 한줄에 몇 스탯 들어갈지 계산
줄당스탯 = 너비 / 9

; 줄에 캐릭터, 보호막, 엄폐물 확인
FOR iTmp, 0, 줄수
	FOR iTmp:1, 0, 인원수
		; 위치, 캐릭터 번호 설정
		위치번호 = 시작위치:iTmp + iTmp:1
		캐릭번호 = FINDELEMENT(총력전_위치, 위치번호)
		; DEBUGPRINTFORML 줄:{iTmp}, 인원:{iTmp:1}
		; DEBUGPRINTFORML 위치번호 = {위치번호}
		; DEBUGPRINTFORML 캐릭번호 = {캐릭번호} ({총력전_ID:캐릭번호})
		; 엄폐물 있는지 확인
		IF 엄폐물있음:iTmp == 0
			; 엄폐물번호
			iTmp:2 = FINDELEMENT(총력전_엄폐물_위치, 위치번호)
			IF iTmp:2 >= 0 && 총력전_엄폐물_소비방식:(iTmp:2):0 > 0
				엄폐물있음:iTmp = 1
			ENDIF
		ENDIF
		; 캐릭터 있는지 확인
		; IF 캐릭터있음:iTmp == 0 && 캐릭번호 >= 0
		IF 캐릭터있음:iTmp == 0 && 총력전_상태:캐릭번호 > 0
			캐릭터있음:iTmp = 1
		ENDIF
		; 화상 확인
		IF FLAG:화상설정 && 화상있음:iTmp == 0 && 캐릭번호 >= 0 && STRLENS(총력전_이미지:캐릭번호) > 0
			화상있음:iTmp = 1
		ENDIF		
		; 보호막 있는지 확인
		IF 보호막있음:iTmp == 0 && 캐릭번호 >= 0
			iTmp:2 = 총력전_상태효과_합계(캐릭번호, 상효_종류_보호막, 총력전_방식_지속)
			; DEBUGPRINTFORML 보호막 확인 = {iTmp:2}
			IF 총력전_상태:캐릭번호 != 0 && iTmp:2 > 0
				보호막있음:iTmp = 1
			ENDIF
		ENDIF
	NEXT
NEXT
; 줄 하나면 높이 계산 건너뛰기
IF 줄수 == 1
	cell_height_line:0 = cell_height
	GOTO 출력
ENDIF
; 줄 높이 계산
cell_height_remainder = cell_height - (줄수 - 1)
; 캐릭터 없는 줄 먼저 확인, 줄 높이 설정
FOR iTmp, 0, 줄수
	; 캐릭터 없음, 2~4줄 정도
	IF !캐릭터있음:iTmp
		; 남은 줄 화인 할 필요 있나?
		; 엄폐물 있음: 3~4
		IF 엄폐물있음:iTmp
			IF cell_height_remainder >= 4
				cell_height_line:iTmp = 4
				cell_height_remainder -= 4
			ELSE
				cell_height_line:iTmp = 0
			ENDIF
		; 엄폐물 없음: 2~3
		ELSE
			IF cell_height_remainder >= 3
				cell_height_line:iTmp = 3
				cell_height_remainder -= 3
			ELSE
				cell_height_line:iTmp = 0
			ENDIF
		ENDIF
	ENDIF
NEXT
; 남은줄 캐릭터 있는 수에 따라 설정
SIF cell_height_remainder <= 0
	GOTO 출력
iTmp:1 = 0
VARSIZE 캐릭터있음
FOR iTmp, 0, RESULT
	SIF 캐릭터있음:iTmp > 0
		iTmp:1 ++
NEXT
iTmp:2 = cell_height_remainder / iTmp:1
iTmp:3 = 0 ; track line with characters
FOR iTmp, 0, 줄수
	IF 캐릭터있음:iTmp
		; 막줄이면
		IF iTmp:3 + 1 == iTmp:1
			cell_height_line:iTmp = cell_height_remainder
			BREAK
		ELSE
			cell_height_line:iTmp = iTmp:2
			cell_height_remainder -= iTmp:2
			iTmp:3 ++
		ENDIF
	ENDIF
NEXT

$출력
; DEBUGPRINTFORML FLAG:화상설정 = {FLAG:화상설정}
FOR iTmp, 0, 줄수
	IF 캐릭터있음:iTmp
		cell_height_remainder = cell_height_line:iTmp
		; 이름 버튼
		IF !FLAG:화상설정 && cell_height_line:iTmp > 6
			CALL 총력전_UI_줄추가(sHtml_blank)
			cell_height_remainder --
		ENDIF
		CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "이름_1", iTmp, sTmp, bBtn)
		CALL 총력전_UI_줄추가(RESULTS)
		cell_height_remainder --
		; 이미지 줄 계산
		iTmp:1 = 0 ; 이미지 사이즈
		; DEBUGPRINTFORML cell_height_line:{iTmp} = {cell_height_line:iTmp}
		IF FLAG:화상설정 && 화상있음:iTmp == 1
			iTmp:2 = cell_height_line:iTmp
			SIF 엄폐물있음:iTmp
				iTmp:2 --
			IF cell_height_line:iTmp >= 18
				; DEBUGPRINTFORML line abv 18
				iTmp:1 = 9
			ELSEIF cell_height_line:iTmp >= 12
				; DEBUGPRINTFORML line abv 12
				iTmp:1 = cell_height_line:iTmp / 2
			ELSEIF cell_height_line:iTmp >= 10
				; DEBUGPRINTFORML line abv 10
				iTmp:1 = 6
			ELSE
				iTmp:1 = 1
			ENDIF
		ELSE
			IF cell_height_line:iTmp > 20
				iTmp:1 = 2
			ELSE
				iTmp:1 = 1
			ENDIF
		ENDIF
		cell_height_remainder -= iTmp:1
		; 이미지 줄 출력
		IF iTmp:1 < 6
			; 6보다 낮으면 빈 공간 출력
			FOR iTmp:2, 0, iTmp:1
				CALL 총력전_UI_줄추가(sHtml_blank)
			NEXT
		ELSE
			CALL 총력전_UI_프레임_0_이미지(인원수, 너비, sHtml_blank, 1, 시작위치:iTmp, iTmp:1)
		ENDIF
		; 스킬 버튼
		CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "무기_1", iTmp, sTmp, bBtn)
		CALL 총력전_UI_줄추가(RESULTS)
		cell_height_remainder --
		; 엄폐물 공간
		IF 엄폐물있음:iTmp
			CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "엄폐물_0", iTmp, sTmp)
			CALL 총력전_UI_줄추가(RESULTS)
			cell_height_remainder --
		ENDIF
		; 체력 && 보호막
		IF 보호막있음:iTmp && cell_height_remainder >= 5
			CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "보호막_0", iTmp, sTmp)
			CALL 총력전_UI_줄추가(RESULTS)
			CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "체력_0", iTmp, sTmp)
			CALL 총력전_UI_줄추가(RESULTS)
			cell_height_remainder -= 2
		ELSE
			IF 보호막있음:iTmp
				CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "체력_1", iTmp, sTmp)
				CALL 총력전_UI_줄추가(RESULTS)
			ELSE
				CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "체력_0", iTmp, sTmp)
				CALL 총력전_UI_줄추가(RESULTS)
			ENDIF
			cell_height_remainder --
		ENDIF
		; 스탯
		iTmp:1 = MIN(cell_height_remainder, 9)
		CALL 총력전_UI_부품_스탯(인원수, 너비, 1, 시작위치:iTmp, iTmp:1)
		iTmp:1 = cell_height_remainder - iTmp:1
		FOR iTmp:2, 0, iTmp:1
			CALL 총력전_UI_줄추가(sHtml_blank)
		NEXT
	ELSE
		; 이름 버튼
		CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "이름_1", iTmp, sTmp, bBtn)
		CALL 총력전_UI_줄추가(RESULTS)
		; 빈공간
		iTmp:1 = cell_height_line:iTmp - 2
		SIF 엄폐물있음:iTmp
			iTmp:1 --
		iTmp:1 = MAX(iTmp:1, 0)
		FOR iTmp:2, 0, iTmp:1
			CALL 총력전_UI_줄추가(sHtml_blank)
		NEXT
		; 스킬 버튼
		CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "무기_1", iTmp, sTmp, bBtn)
		CALL 총력전_UI_줄추가(RESULTS)
		; 엄폐물 공간
		IF 엄폐물있음:iTmp
			CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "엄폐물_0", iTmp, sTmp)
			CALL 총력전_UI_줄추가(RESULTS)
		ENDIF
	ENDIF
	; 막줄 아니면 줄 추가
	SIF iTmp < 줄수 - 1
		CALL 총력전_UI_줄추가(sHtml_end)
NEXT
; #endregion == 프레임 2 ==

; #region == 프레임 3 ==
; 프레임 2, 이름 + 이미지 + 체력만
; 한줄만
; 보스 폴백용(fallback)
@총력전_UI_프레임_3(인원수, 시작위치, cell_height = 13, bBtn = 총력전_선택_캐릭터)
#DIM 인원수 ; 한 줄당 인원수
#DIM REF 시작위치, 0 ; 시작위치 번호
#DIM DYNAMIC cell_height ; 셀 높이 6 ~ 21?
#DIM DYNAMIC bBtn ; 버튼 작동 여부, 총력전_선택_ 참조

#DIM CONST iSpace = 120

#DIMS DYNAMIC sHtml_end ; 줄 사이 브레이크
#DIMS DYNAMIC sHtml_blank ; 캐릭터 사이 선 있는 부분
#DIM DYNAMIC cell_height_remainder ; 남은 셀 높이
#DIM DYNAMIC cell_height_line, 6 ; 줄당 셀 높이
#DIM DYNAMIC 엄폐물있음, 6 ; 엄폐물 있는지
#DIM DYNAMIC 보호막있음, 6 ; 보호막 있는지
#DIM DYNAMIC 줄수 ; 시작위치 SIZE
#DIM DYNAMIC 너비 ; 캐릭터 부분 너비
#DIM DYNAMIC 캐릭번호 ; 임시 캐릭터 번호
#DIM DYNAMIC 위치번호 ; 임시 위치 번호
#DIM DYNAMIC iTmp, 3
#DIMS DYNAMIC sTmp

; 너비 계산
; 전체너비 / 인원수 - 장식
너비 = DIVIDE_ROUND(iSpace, 인원수) - 3
; 줄수 계산
VARSIZE 시작위치
줄수 = RESULT
; 라인 세팅
CALL 총력전_UI_줄(인원수, 너비, 1, 0, "__", iTmp, sTmp)
sHtml_blank = %RESULTS%
; 줄에 캐릭터, 보호막, 엄폐물 확인
FOR iTmp, 0, 줄수
	FOR iTmp:1, 0, 인원수
		; 위치, 캐릭터 번호 설정
		위치번호 = 시작위치:iTmp + iTmp:1
		캐릭번호 = FINDELEMENT(총력전_위치, 위치번호)
		; DEBUGPRINTFORML 줄:{iTmp}, 인원:{iTmp:1}
		; DEBUGPRINTFORML 위치번호 = {위치번호}
		; DEBUGPRINTFORML 캐릭번호 = {캐릭번호}
		; 엄폐물 있는지 확인
		IF 엄폐물있음:iTmp == 0
			; 엄폐물번호
			iTmp:2 = FINDELEMENT(총력전_엄폐물_위치, 위치번호)
			IF iTmp:2 >= 0 && 총력전_엄폐물_소비방식:(iTmp:2):0 > 0
				엄폐물있음:iTmp = 1
			ENDIF
		ENDIF
		; 보호막 있는지 확인
		IF 보호막있음:iTmp == 0 && 캐릭번호 >= 0
			iTmp:2 = 총력전_상태효과_합계(캐릭번호, 상효_종류_보호막, 총력전_방식_지속)
			; DEBUGPRINTFORML 보호막 확인 = {iTmp:2}
			IF 총력전_상태:캐릭번호 != 0 && iTmp:2 > 0
				보호막있음:iTmp = 1
			ENDIF
		ENDIF
	NEXT
NEXT
; 줄 하나면 높이 계산 건너뛰기
IF 줄수 == 1
	cell_height_line:0 = cell_height
	GOTO 출력
ENDIF
; 줄 높이 계산, 간단
; cell_height_remainder = cell_height - (줄수 - 1)
iTmp:1 = (cell_height - (줄수 - 1)) / 줄수
FOR iTmp, 0, 줄수 - 1
	cell_height_line:iTmp = iTmp:1
NEXT
cell_height_line:(줄수 - 1) = cell_height - iTmp:1 * (줄수 - 1)

$출력
FOR iTmp, 0, 줄수
	cell_height_remainder = cell_height_line:iTmp ; 이미지 사이즈
	IF !FLAG:화상설정
		CALL 총력전_UI_줄추가(sHtml_blank)
		cell_height_remainder --
	ENDIF
	; 이름 버튼
	CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "이름_1", iTmp, sTmp, bBtn)
	CALL 총력전_UI_줄추가(RESULTS)
	cell_height_remainder -= 2 ; 체력줄 미리 제거
	; 이미지
	SIF 엄폐물있음:iTmp
		cell_height_remainder --
	SIF 보호막있음:iTmp
		cell_height_remainder --
	; 이미지 줄 출력
	; 6보다 낮으면 빈 공간 출력
	IF FLAG:화상설정
		IF cell_height_remainder < 4
			GOTO IMGBLANK
		ENDIF
		CALL 총력전_UI_프레임_0_이미지(인원수, 너비, sHtml_blank, 1, 시작위치:iTmp, cell_height_remainder)
	ELSE
		$IMGBLANK
		; 빈공간
		FOR iTmp:1, 0, cell_height_remainder
			CALL 총력전_UI_줄추가(sHtml_blank)
		NEXT
	ENDIF
	IF 엄폐물있음:iTmp
		CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "엄폐물_0", iTmp, sTmp)
		CALL 총력전_UI_줄추가(RESULTS)
	ENDIF
	IF 보호막있음:iTmp
		CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "보호막_0", iTmp, sTmp)
		CALL 총력전_UI_줄추가(RESULTS)
	ENDIF
	CALL 총력전_UI_줄(인원수, 너비, 1, 시작위치:iTmp, "체력_0", iTmp, sTmp)
	CALL 총력전_UI_줄추가(RESULTS)
NEXT
; #endregion == 프레임 3 ==

; #region == HTML ==
; 총력전 전용(?) HTML 출력 보조 함수
; 한줄씩 출력하는 것 보다, 중간에 계산 없게
; 모은후 한번에 출력
; ==================
; CLEAR -> HTML 전체 출력
@총력전_UI_출력(delay = 0, clearAll = 0)
#DIM DYNAMIC delay
#DIM DYNAMIC clearAll
#DIM DYNAMIC iTmp
IF clearAll
	CLEARLINE LINECOUNT
ENDIF
FOR iTmp, 0, 총력전_HTML_출력줄수
	HTML_PRINT 총력전_HTML:iTmp
NEXT
IF delay > 0
	AWAIT delay
ENDIF
총력전_HTML_출력줄수 = 0

; HTML 줄 추가
@총력전_UI_줄추가(sHtml)
#DIMS sHtml
총력전_HTML:총력전_HTML_출력줄수 = %sHtml%
총력전_HTML_출력줄수 ++
RETURN 총력전_HTML_출력줄수 - 1 ; 필요 없긴 할건데...

; #endregion == HTML ==


; #region == 텍스트 ==
; 총력전 전투 로그
; ARRAYSHIFT
; ====================
; 건너뛰기: 하단 몇 줄을 다른 장식으로 하고 싶으면
@총력전_UI_텍스트(줄수, 너비, 건너뛰기 = 0, sPadStart = "| | ", sPadEnd = " | |")
#DIM 줄수 ; 높이(?)
#DIM 너비 ; sPad 를 뺀 너비
#DIM 건너뛰기 ; 로그 건너뛰기
#DIMS DYNAMIC sPadStart ; 줄 왼쪽 끝
#DIMS DYNAMIC sPadEnd ; 줄 오른쪽 끝

#DIM DYNAMIC iTmp

FOR iTmp, 줄수 - 1, -1, -1
	CALL 총력전_UI_텍스트_단선(iTmp + 건너뛰기, 너비, sPadStart, sPadEnd)
	CALL 총력전_UI_줄추가(RESULTS)
NEXT

; REPEAT 줄수
; 	CALL 총력전_UI_텍스트_단선(COUNT + 건너뛰기, 너비, sPadStart, sPadEnd)
; 	HTML_PRINT RESULTS
; REND

; 텍스트 한줄
@총력전_UI_텍스트_단선(줄번호, 너비, sPadStart = "| | ", sPadEnd = " | |")
#DIM 줄번호 ; 총력전_텍스트:총력전_텍스트_표시행 + 줄번호
#DIM 너비 ; sPad 를 뺀 너비
#DIMS DYNAMIC sPadStart ; 줄 왼쪽 끝
#DIMS DYNAMIC sPadEnd ; 줄 오른쪽 끝

#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

iTmp = 총력전_텍스트_표시행 + 줄번호
IF iTmp >= 총력전_텍스트_최대행수
	총력전_텍스트_표시행 = 총력전_텍스트_최대행수 - 줄번호 - 1
	iTmp = 총력전_텍스트_표시행 + 줄번호
ENDIF
; 너비 비례 정리?
; DEBUGPRINTFORML 줄번호:{iTmp}
sTmp = %ALIGN_TEXT(총력전_텍스트:iTmp, 너비, "LEFT")%
RESULTS = %sPadStart%<font color='%총력전_텍스트_색상:iTmp%'>%sTmp%</font>%sPadEnd%

; -1 이면 힌색으로
@총력전_UI_텍스트_추가(텍스트, 칼라 = -1)
#DIMS 텍스트
#DIM DYNAMIC 칼라
#DIMS DYNAMIC col

IF 칼라 < 0
	col = %INT_TO_HEXSTR(칼라_흰색)%
ELSE
	col = %INT_TO_HEXSTR(칼라)%
ENDIF
ARRAYSHIFT 총력전_텍스트, 1, 텍스트
ARRAYSHIFT 총력전_텍스트_색상, 1, col

@총력전_UI_텍스트_제거(제거수)
#DIM 제거수

IF 제거수 <= 0
	RETURN
ENDIF

ARRAYREMOVE 총력전_텍스트, 0, 제거수
CALL ARRAYREMOVE_SVAL(총력전_텍스트_색상, 0, 제거수, "#C0C0C0")

; #endregion == 텍스트 ==

; #region == 부품 ==
; HTML_PRINT 그룹
; 나누는 방법이 없던가, 아직 몰라서
; ==================
; 스탯 줄 프린트
@총력전_UI_부품_스탯(인원수, 너비, 위치사용, 시작번호, 줄수, sPadStart = "| |", sPadEnd = "| |", sCellDiv = "| |")
#DIM 인원수
#DIM 너비 ; 셀 너비
#DIM 위치사용
#DIM 시작번호
#DIM 줄수 ; 1 ~ 7
#DIMS DYNAMIC sPadStart ; 줄 왼쪽 끝
#DIMS DYNAMIC sPadEnd ; 줄 오른쪽 끝
#DIMS DYNAMIC sCellDiv ; 사이 부분
#DIM DYNAMIC 줄당스탯
#DIMS 스탯이름_9 = "공", "방", "명", "회", "치유", "치명", "치피", "치명저", "치피저"
#DIMS 스탯이름_3A = "명", "회", "치유"
#DIMS 스탯이름_3B = "치유", "치명", "치피"
#DIMS 스탯이름_4 = "치명", "치피", "치명저", "치피저"
#DIMS 스탯이름_2A = "치명", "치피"
#DIMS 스탯이름_2B = "치명저", "치피저"
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp, 3
; 한줄에 몇 스탯 들어갈지 계산
줄당스탯 = 너비 / 10
SELECTCASE 줄수
	CASE 1
		SELECTCASE 줄당스탯
			CASE IS <= 1
				iTmp = 1
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", iTmp, 스탯이름_9, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
			CASE 2 TO 9 ; 줄당스탯 쓰고 있어서 CASEELSE 안씀
				; iTmp = 2
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, 스탯이름_9, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
		ENDSELECT
	CASE 2
		SELECTCASE 줄당스탯
			CASE IS <= 1
				iTmp = 1
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", iTmp, 스탯이름_9, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
				sTmp = 방
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", iTmp, sTmp, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
			CASE 2
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, 스탯이름_9, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
				sTmp:0 = 회
				sTmp:1 = 치명
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, sTmp, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
			CASE 3
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, 스탯이름_9, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
				sTmp:0 = 치명
				sTmp:1 = 치피
				sTmp:2 = 회
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, sTmp, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
			CASE 4
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, 스탯이름_9, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, 스탯이름_4, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
			CASEELSE
				iTmp = 5
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", iTmp, 스탯이름_9, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
				iTmp = 4
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", iTmp, 스탯이름_4, 0, sPadStart, sPadEnd, sCellDiv)
		ENDSELECT
	CASE 3
		SELECTCASE 줄당스탯
			CASE IS <= 1
				iTmp = 1
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", iTmp, 스탯이름_9, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
				sTmp = 방
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", iTmp, sTmp, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
				sTmp = 치명
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", iTmp, sTmp, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
			CASE 2
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, 스탯이름_9, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, 스탯이름_3A, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, 스탯이름_4, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
			CASE 3
				sTmp:0 = 공
				sTmp:1 = 방
				sTmp:2 = 치유
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, sTmp, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
				sTmp:0 = 치명
				sTmp:1 = 치명저
				sTmp:2 = 명
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, sTmp, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
				sTmp:0 = 치피
				sTmp:0 = 치피저
				sTmp:0 = 회
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", 줄당스탯, sTmp, 0, sPadStart, sPadEnd, sCellDiv)
				CALL 총력전_UI_줄추가(RESULTS)
			CASEELSE
				iTmp = 2
				CALL 총력전_UI_줄(인원수, 너비, 위치사용, 시작번호, "스탯_0", iTmp, 스탯이름_9, 0, sPadStart, sPadEnd, sCellDiv)
