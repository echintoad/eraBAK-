; #region 보스 GUI
; 전체적으로 바꾸고 싶으면
; RETURN 1 = 기본 프레임 렌더 하지 않음
@총력전_보스_UI_0(선택종류_아군, 선택종류_적군, 선택모드)
#DIM 선택종류_아군
#DIM DYNAMIC 선택종류_적군
#DIM DYNAMIC 선택모드 ; (스킬)선택용 버튼으로 변경

#DIM DYNAMIC 시작위치_0 = -1 ; 한줄
#DIM DYNAMIC 시작위치_1, 2 ; 두줄
#DIM DYNAMIC 보스번호 ; 보스 번호
#DIM DYNAMIC 보스위치 ; 보스 위치 번호
#DIM DYNAMIC 엄폐물있음 ; 보스 엄폐물 있는지
#DIM DYNAMIC 보호막있음 ; 보스 보호막 있는지
#DIM DYNAMIC 줄수 ; 캐릭터 몇줄이 필요한지
#DIMS DYNAMIC sHtml_end, 4 ; 시작과 끝 부분
#DIMS DYNAMIC sHtml_col
#DIM DYNAMIC iTmp, 3
#DIMS DYNAMIC sTmp, 2
#DIM DYNAMIC iBlank

; 페이즈 1 또는 화상없으면 스킵
SIF 총력전_보스_페이즈 == 0 || !FLAG:화상설정
	RETURN 0

; 페이즈 2
; 보스 번호 + 위치
보스번호 = 10
보스위치 = 총력전_위치:10
; 한번만 해도돼는 셋업
; #FFCC00
sHtml_col = #FFCC00
시작위치_1:0 = 0
시작위치_1:1 = 5
시작위치_0 = -1
줄수 = 0
IF 선택종류_아군 == 총력전_선택_엄폐물 || 선택종류_아군 == 총력전_선택_빈공간 || 선택종류_아군 == 총력전_선택_전체
	줄수 = 2
ELSE
	; 팀 0 위치 확인
	FOR iTmp, 0, 5
		; 위치에 있는 총력전 ID
		iTmp:1 = FINDELEMENT(총력전_위치, iTmp)
		; 못찾으면 -1?
		IF iTmp:1 >= 0 && 총력전_상태:(iTmp:1)
			시작위치_0 = 0
			줄수 ++
			BREAK
		ENDIF
		; 엄폐물
		iTmp:2 = FINDELEMENT(총력전_엄폐물_위치, iTmp)
		IF iTmp:2 >= 0 && 총력전_엄폐물_소비방식:(iTmp:2):0 > 0
			시작위치_0 = 0
			줄수 ++
			BREAK
		ENDIF
	NEXT
	; 못 찾았으면 앞줄에 있다 가정
	SIF 시작위치_0 == -1
		시작위치_0 = 5
	FOR iTmp, 5, 10
		iTmp:1 = FINDELEMENT(총력전_위치, iTmp)
		IF iTmp:1 >= 0 && 총력전_상태:(iTmp:1)
			줄수 ++
			BREAK
		ENDIF
		; 엄폐물
		iTmp:2 = FINDELEMENT(총력전_엄폐물_위치, iTmp)
		IF iTmp:2 >= 0 && 총력전_엄폐물_소비방식:(iTmp:2):0 > 0
			줄수 ++
			BREAK
		ENDIF
	NEXT
ENDIF
; 줄수 계산
; 보스줄수 = 15
; 캐릭터줄수 = 21
; 텍트스줄수 = 48 - 21 - 15 ; 12
; 보스 엄폐물 있는지 확인
iTmp = FINDELEMENT(총력전_엄폐물_위치, 보스위치)
SIF iTmp >= 0 && 총력전_엄폐물_소비방식:iTmp:0 > 0
	엄폐물있음 = 1
; 보스 보호막 있는지 확인
iTmp = 총력전_상태효과_합계(보스번호, 상효_종류_보호막, 총력전_방식_지속)
SIF 총력전_상태:보스번호 != 0 && iTmp > 0
	보호막있음 = 1

; 연출 안했으면 연출, 이후 고정
; 총력전_보스_쿨다운:5 를 연출 기록용으로
IF 총력전_보스_쿨다운:5 != -2
	CALL _총력전_보스_UI_0_프레임_0(선택종류_아군, 선택종류_적군, 선택모드, 시작위치_0, 시작위치_1:0, 시작위치_1:1, 줄수, sHtml_col)
	총력전_보스_쿨다운:5 = -2
ENDIF
CALL _총력전_보스_UI_0_프레임_1(선택종류_아군, 선택종류_적군, 선택모드, 시작위치_0, 시작위치_1:0, 시작위치_1:1, 줄수, 엄폐물있음, 보호막있음, sHtml_col)
RETURN 1

; 페이즈 2 프레임 + 애니메이션
; 그냥 엄폐물 + 보호막 무시
@_총력전_보스_UI_0_프레임_0(선택종류_아군, 선택종류_적군, 선택모드, 시작위치_0, 시작위치_1:0, 시작위치_1:1, 줄수, sHtml_col)
#DIM 선택종류_아군
#DIM 선택종류_적군
#DIM 선택모드 ; (스킬)선택용 버튼으로 변경
#DIM 시작위치_0 = -1 ; 한줄
#DIM 시작위치_1, 2 ; 두줄
#DIM 줄수 ; 캐릭터 몇줄이 필요한지
#DIMS sHtml_col

#DIM CONST 너비 = 115
#DIM CONST 보스번호 = 10
#DIM 보스위치

#DIMS DYNAMIC sHtml_anim, 15, 80 ; 프레임수, 총력전_HTML 사이즈
#DIM DYNAMIC sHtml_출력줄수
#DIMS DYNAMIC sHtml_end, 3 ; 시작과 끝 부분
#DIMS DYNAMIC sHtml_img, 3
#DIMS DYNAMIC sHtml_imgBlank, 4 ; 이미지선 추가 부분 0=기존무, 1=기존break, 2=blank, 3=break
#DIMS DYNAMIC sPad, 6 ; 줄 좌/우 끝
#DIM DYNAMIC frameCnt ; 에니메이션 프레임 카운트
#DIM DYNAMIC iRand ; RAND 한번만 하며 되게
#DIM DYNAMIC iRandCnt
#DIM DYNAMIC 셀높이 = 13 ; 15 -이름 -체력
#DIM DYNAMIC iTmp, 3
#DIMS DYNAMIC sTmp, 2

#DIM ccc = 0

보스위치 = 총력전_위치:10

; 최초 + 최종 텍스트 준비
sHtml_end:0 = |%TOSTR_REPEAT("=",121)%|
sHtml_end:1 = |%TOSTR_REPEAT("=",50)%|   DECAGRAMMATON   |%TOSTR_REPEAT("=",50)%|
sHtml_end:2 = |%TOSTR_REPEAT("=",25)%| 12 |%TOSTR_REPEAT("=",26)%| 14 |%TOSTR_REPEAT("=",26)%| 17 |%TOSTR_REPEAT("=",26)%|
sPad:0 += @"<font color='%sHtml_col%'>|  |</font>"
sPad:1 += @"<font color='%sHtml_col%'>|==|</font>"
sPad:2 += @"<font color='%sHtml_col%'>| | </font>"
sPad:3 += @"<font color='%sHtml_col%'> | |</font>"
sPad:4 += @"<font color='%sHtml_col%'>|</font> | "
sPad:5 += @" | <font color='%sHtml_col%'>|</font>"
CALL 총력전_UI_줄(1, 너비 + 2, 1, 0, "__", iTmp, sTmp)
sHtml_imgBlank:0 = %RESULTS%
CALL 총력전_UI_줄(1, 너비 + 2, 1, 0, "__", iTmp, sTmp, 0, "|=|", "|=|", "|=|")
sHtml_imgBlank:1 = %RESULTS%
CALL 총력전_UI_줄(1, 너비, 1, 0, "__", iTmp, sTmp, 0, sPad:0, sPad:0)
sHtml_imgBlank:2 = %RESULTS%
CALL 총력전_UI_줄(1, 너비, 1, 0, "__", iTmp, sTmp, 0, sPad:1, sPad:1)
sHtml_imgBlank:3 = %RESULTS%
iTmp:0 = (너비 + 2) * 50 ; 너비 pixel
iTmp:1 = 셀높이 * 100 - 50 ; size
iTmp:2 = (셀높이 * 100 - 500) / -2 + 30 ; yPos
CALL 총력전_UI_이미지("Boss_0_S_1", iTmp:0, iTmp:1, iTmp:2)
sHtml_img:0 = <shape type='space' param='10'>%TOSTR_SPACE(3)%%RESULTS%
CALL 총력전_UI_이미지(총력전_이미지:10, iTmp:0, iTmp:1, iTmp:2)
sHtml_img:1 = <shape type='space' param='10'>%TOSTR_SPACE(3)%%RESULTS%
; Boss_0_S_2 나중에 추가

iRand = RAND(POWER(2, 62))

FOR frameCnt, 0, 15
	; 헤더
	SELECTCASE frameCnt
	CASE IS < 2
		sTmp:0 = %sHtml_end:1%
	CASE IS < 11
		SELECTCASE frameCnt ; 프레임수
		CASE 2
			iTmp:1 = 18 ; binary
			iTmp:2 = 0 ; sHtml_end:1
			STRLENFORM %sHtml_end:1%
			iTmp:0 = RESULT/2 - (iTmp:1/2)
		CASE 3 TO 8
			iTmp:1 = 12 ; binary
			iTmp:2 = 16 * (frameCnt - 3) + 10 ; sHtml_end:1
			STRLENFORM %sHtml_end:1%
			iTmp:0 = RESULT/2 - iTmp:1 - (iTmp:2/2)
		ENDSELECT
		IF frameCnt == 9
			sTmp:1 = %_총력전_보스_UI_0_BINARY(iRand, iRandCnt, 8)%
			sTmp:0 = <font color='%sHtml_col%'>%sTmp:1%
			STRLENFORM %sHtml_end:2%
			sTmp:0 += @"%SUBSTRING(sHtml_end:2, 8, RESULT - 17)%"
			sTmp:1 = %_총력전_보스_UI_0_BINARY(iRand, iRandCnt, 9)%
			sTmp:0 += @"%sTmp:1%</font>"
		ELSEIF frameCnt == 10
			sTmp:1 = %_총력전_보스_UI_0_BINARY(iRand, iRandCnt, 2)%
			sTmp:0 = <font color='%sHtml_col%'>%sTmp:1%
			STRLENFORM %sHtml_end:2%
			sTmp:0 += @"%SUBSTRING(sHtml_end:2, 2, RESULT - 5)%"
			sTmp:1 = %_총력전_보스_UI_0_BINARY(iRand, iRandCnt, 3)%
			sTmp:0 += @"%sTmp:1%</font>"
		ELSE
			sTmp:1 = %_총력전_보스_UI_0_BINARY(iRand, iRandCnt, iTmp:1)%
			sTmp:0 = %SUBSTRING(sHtml_end:1, 0, iTmp:0)%
			IF iTmp:2 == 0
				sTmp:0 += @"<font color='%sHtml_col%'>%sTmp:1%</font>"
				sTmp:0 += @"%SUBSTRING(sHtml_end:1, iTmp:0 + iTmp:1, -1)%"
			ELSE
				sTmp:0 += @"<font color='%sHtml_col%'>%sTmp:1%"
				sTmp:0 += @"%SUBSTRING(sHtml_end:2, iTmp:0 + iTmp:1, iTmp:2)%"
				sTmp:0 += @"%sTmp:1%</font>"
				sTmp:0 += @"%SUBSTRING(sHtml_end:1, iTmp:0 + iTmp:1 * 2 + iTmp:2, -1)%"
			ENDIF
		ENDIF
	CASEELSE
		sTmp:0 = <font color='%sHtml_col%'>%sHtml_end:2%</font>
	ENDSELECT
	CALL 총력전_UI_줄추가(sTmp:0)
	; 적 파티 프레임
	; 이름 버튼
	SELECTCASE frameCnt
		CASE IS < 9
			CALL 총력전_UI_줄(1, 너비 + 2, 1, 보스위치, "이름_1", iTmp, sTmp, 선택종류_적군)
			CALL 총력전_UI_줄추가(RESULTS)
			CALL 총력전_UI_줄추가(sHtml_imgBlank:0)
			CALL 총력전_UI_줄추가(sHtml_imgBlank:0)
		CASE IS <= 10
			sTmp:0 = <font color='%sHtml_col%'>%_총력전_보스_UI_0_BINARY(iRand, iRandCnt, 4)%</font>
			sTmp:1 = <font color='%sHtml_col%'>%_총력전_보스_UI_0_BINARY(iRand, iRandCnt, 4)%</font>
			CALL 총력전_UI_줄(1, 너비, 1, 보스위치, "이름_1", iTmp, sTmp, 선택종류_적군, sTmp:0, sTmp:1)
			CALL 총력전_UI_줄추가(RESULTS)
			sTmp:0 = <font color='%sHtml_col%'>%_총력전_보스_UI_0_BINARY(iRand, iRandCnt, 4)%</font>
			sTmp:1 = <font color='%sHtml_col%'>%_총력전_보스_UI_0_BINARY(iRand, iRandCnt, 4)%</font>
			CALL 총력전_UI_줄(1, 너비, 1, 0, "__", iTmp, sTmp, 0, sTmp:0, sTmp:1)
			CALL 총력전_UI_줄추가(RESULTS)
			sTmp:0 = <font color='%sHtml_col%'>%_총력전_보스_UI_0_BINARY(iRand, iRandCnt, 4)%</font>
			sTmp:1 = <font color='%sHtml_col%'>%_총력전_보스_UI_0_BINARY(iRand, iRandCnt, 4)%</font>
			CALL 총력전_UI_줄(1, 너비, 1, 0, "__", iTmp, sTmp, 0, sTmp:0, sTmp:1)
			CALL 총력전_UI_줄추가(RESULTS)
		CASEELSE
			CALL 총력전_UI_줄(1, 너비, 1, 보스위치, "이름_1", iTmp, sTmp, 선택종류_적군, sPad:0, sPad:0)
