; sHtml_col = #FFD700

; 페이즈 1 또는 화상없으면 스킵
SIF 총력전_보스_페이즈 == 1 || !FLAG:화상설정
	RETURN 0
; 페이즈 2
IF 총력전_보스_페이즈 == 0
	; 보스 번호 + 위치
	보스번호 = 10
	보스위치 = 총력전_위치:10
	; 한번만 해도돼는 셋업
	시작위치_1:0 = 0
	시작위치_1:1 = 5
	시작위치_0 = -1
	줄수 = 0
	IF 선택종류_아군 == 총력전_선택_엄폐물 || 선택종류_아군 == 총력전_선택_빈공간 || 선택종류_아군 == 총력전_선택_전체
		줄수 = 2
	ELSE
		; 팀 0 위치 확인
		FOR iTmp, 0, 5
			; 위치에 있는 총력전 ID
			iTmp:1 = FINDELEMENT(총력전_위치, iTmp)
			; 못찾으면 -1?
			IF iTmp:1 >= 0 && 총력전_상태:(iTmp:1)
				시작위치_0 = 0
				줄수 ++
				BREAK
			ENDIF
			; 엄폐물
			iTmp:2 = FINDELEMENT(총력전_엄폐물_위치, iTmp)
			IF iTmp:2 >= 0 && 총력전_엄폐물_소비방식:(iTmp:2):0 > 0
				시작위치_0 = 0
				줄수 ++
				BREAK
			ENDIF
		NEXT
		; 못 찾았으면 앞줄에 있다 가정
		SIF 시작위치_0 == -1
			시작위치_0 = 5
		FOR iTmp, 5, 10
			iTmp:1 = FINDELEMENT(총력전_위치, iTmp)
			IF iTmp:1 >= 0 && 총력전_상태:(iTmp:1)
				줄수 ++
				BREAK
			ENDIF
			; 엄폐물
			iTmp:2 = FINDELEMENT(총력전_엄폐물_위치, iTmp)
			IF iTmp:2 >= 0 && 총력전_엄폐물_소비방식:(iTmp:2):0 > 0
				줄수 ++
				BREAK
			ENDIF
		NEXT
	ENDIF
	; 줄수 계산
	; 보스줄수 = 15
	캐릭터줄수 = 21
	텍트스줄수 = 48 - 캐릭터줄수 - 15 ; 보스줄수 = 15
	CALL _총력전_보스_UI_0_프레임_1(선택종류_아군, 선택종류_적군, 선택모드, 시작위치_0, 시작위치_1:0, 시작위치_1:1, 보스번호, 보스위치, 캐릭터줄수, 텍트스줄수, 줄수, sHtml_col)
	RETURN 1
ENDIF

