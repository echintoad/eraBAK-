		난이도계수:3 = 90
		난이도계수:4 = 82
	CASEELSE
		난이도계수 = 100
		난이도계수:1 = 100
		난이도계수:2 = 100
		난이도계수:3 = 100
		난이도계수:4 = 100
ENDSELECT
; 체력
총력전_최대체력_최초:보스번호 = 28000 * 난이도계수:1 / 100
; 총력전_최대체력_최초:보스번호 = 40000 * 난이도계수 / 100
