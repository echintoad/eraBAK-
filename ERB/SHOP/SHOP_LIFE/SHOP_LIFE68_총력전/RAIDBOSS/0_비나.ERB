@_총력전_보스_UI_0_프레임_1(선택종류_아군, 선택종류_적군, 선택모드, 시작위치_0, 시작위치_1:0, 시작위치_1:1, 줄수, 엄폐물있음, 보호막있음, sHtml_col)
#DIM 선택종류_아군
#DIM 선택종류_적군
#DIM 선택모드 ; (스킬)선택용 버튼으로 변경
#DIM 시작위치_0 = -1 ; 한줄
#DIM 시작위치_1, 2 ; 두줄
; #DIM 캐릭터줄수 ; 캐릭터쪽 HTML 줄수, 계산용
#DIM 텍트스줄수 ; 텍스트 HTML 줄수, 계산용
#DIM 줄수 ; 캐릭터 몇줄이 필요한지
#DIM 엄폐물있음 ; 엄폐물 있는지
#DIM 보호막있음 ; 보호막 있는지
#DIMS sHtml_col

#DIM CONST iSpace = 120
; #DIM CONST 보스번호 = 10
#DIM 보스위치

#DIMS DYNAMIC sHtml_end, 3 ; 시작과 끝 부분
#DIMS DYNAMIC sHtml_imgBlank, 2 ; 이미지선 추가 부분 0=blank, 1=break
#DIMS DYNAMIC sPad, 2 ; 줄 좌/우 끝
#DIM DYNAMIC 셀높이 = 15 ; 이미지 셀 높이 6 ~ 21?
#DIM DYNAMIC 너비
#DIM DYNAMIC iSizeIsOdd
#DIM DYNAMIC iImgSize ; pixel
#DIM DYNAMIC iImgYPos ; pixel
#DIM DYNAMIC iTmp, 2
#DIMS DYNAMIC sTmp, 2

보스위치 = 총력전_위치:10

; sHtml
sHtml_end:0 = |%TOSTR_REPEAT("=",121)%|
sHtml_end:1 = <font color='%sHtml_col%'>|%TOSTR_REPEAT("=",121)%|</font>
sHtml_end:2 = <font color='%sHtml_col%'>|%TOSTR_REPEAT("=",25)%| 12 |%TOSTR_REPEAT("=",26)%| 14 |%TOSTR_REPEAT("=",26)%| 17 |%TOSTR_REPEAT("=",26)%|</font>

; 헤더
CALL 총력전_UI_줄추가(sHtml_end:2)

; 적 파티 프레임
; 커스텀 필요
너비 = iSpace - 3 - 2
셀높이 = 15
sPad:0 += @"<font color='%sHtml_col%'>|  |</font>"
sPad:1 += @"<font color='%sHtml_col%'>|==|</font>"
; 라인 세팅
CALL 총력전_UI_줄(1, 너비, 1, 0, "__", iTmp, sTmp, 0, sPad:0, sPad:0)
sHtml_imgBlank:0 = %RESULTS%
CALL 총력전_UI_줄(1, 너비, 1, 0, "__", iTmp, sTmp, 0, sPad:1, sPad:1)
sHtml_imgBlank:1 = %RESULTS%
; 셀높이 계산
셀높이 -= 2 ; -이름 -체력
SIF 엄폐물있음
	셀높이 --
SIF 보호막있음
	셀높이 --
; 이미지 줄 출력 커스텀
iSizeIsOdd = 셀높이 % 2
iImgSize = 셀높이 * 100 - 50
IF iSizeIsOdd
	iImgYPos = (셀높이 * 100 - 500) / -2 + 30
ELSE
	iImgYPos = (셀높이 * 100 - 600) / -2 + 30
ENDIF

; 출력
; 이름 버튼
CALL 총력전_UI_줄(1, 너비, 1, 보스위치, "이름_1", iTmp, sTmp, 선택종류_적군, sPad:0, sPad:0)
CALL 총력전_UI_줄추가(RESULTS)
; 이미지
CALL 총력전_UI_이미지(총력전_이미지:10, (너비 + 2) * 50, iImgSize, iImgYPos)
sTmp = <shape type='space' param='10'>%TOSTR_SPACE(3)%%RESULTS%
iTmp = (셀높이 - 7) / 2
FOR iTmp:1, 0, iTmp
	CALL 총력전_UI_줄추가(sHtml_imgBlank:0)
NEXT
CALL 총력전_UI_줄추가(sHtml_imgBlank:1)
CALL 총력전_UI_줄추가(sTmp)
CALL 총력전_UI_줄추가(sHtml_imgBlank:1)
CALL 총력전_UI_줄추가(@"<font color='%sHtml_col%'>|  |%TOSTR_SPACE(너비)%|18|</font>")
CALL 총력전_UI_줄추가(sHtml_imgBlank:1)
CALL 총력전_UI_줄추가("  ")
CALL 총력전_UI_줄추가(sHtml_imgBlank:1)
SIF !iSizeIsOdd
	iTmp ++
FOR iTmp:1, 0, iTmp
	CALL 총력전_UI_줄추가(sHtml_imgBlank:0)
NEXT
IF 엄폐물있음
	CALL 총력전_UI_줄(1, 너비, 1, 보스위치, "엄폐물_0", iTmp, sTmp, 0, sPad:0, sPad:0)
	CALL 총력전_UI_줄추가(RESULTS)
ENDIF
IF 보호막있음
	CALL 총력전_UI_줄(1, 너비, 1, 보스위치, "보호막_0", iTmp, sTmp, 0, sPad:0, sPad:0)
	CALL 총력전_UI_줄추가(RESULTS)
ENDIF
CALL 총력전_UI_줄(1, 너비, 1, 보스위치, "체력_0", iTmp, sTmp, 0, sPad:0, sPad:0)
CALL 총력전_UI_줄추가(RESULTS)

; 바: 턴수, 코스트, 게임 종료
sTmp:0 = <font color='%sHtml_col%'>| | </font>
sTmp:1 = <font color='%sHtml_col%'> | |</font>
CALL 총력전_UI_줄추가(sHtml_end:1)
CALL 총력전_UI_바_상(115, sTmp:0, sTmp:1)
CALL 총력전_UI_줄추가(RESULTS)
CALL 총력전_UI_줄추가(sHtml_end:1)

; 전투로그, 텍트스줄수 = 12
CALL 총력전_UI_텍스트(3, 115, 12 - 3, sTmp:0, sTmp:1)
sTmp:0 =
sTmp:0 += @"<font color='%sHtml_col%'>|</font> | "
sTmp:1 =
sTmp:1 += @" | <font color='%sHtml_col%'>|</font>"
CALL 총력전_UI_텍스트(3, 115, 12 - 6, sTmp:0, sTmp:1)
CALL 총력전_UI_텍스트(12 - 6, 115)

; 바: 다음턴, 텍스트 컨트롤러
CALL 총력전_UI_줄추가(sHtml_end)
CALL 총력전_UI_바_하(선택모드)
CALL 총력전_UI_줄추가(RESULTS)
CALL 총력전_UI_줄추가(sHtml_end)
; 아군 파티 프레임
IF 줄수 == 2
	IF 총력전_캐릭터정보 == -1
		; CALL 총력전_UI_프레임_2(5, 시작위치_1, 캐릭터줄수, 선택종류_아군)
		CALL 총력전_UI_프레임_2(5, 시작위치_1, 21, 선택종류_아군)
	ELSE
		CALL 총력전_UI_프레임_2(5, 시작위치_1, 21 - 8, 선택종류_아군)
		CALL 총력전_UI_줄추가(sHtml_end)
		CALL 총력전_UI_부품_캐릭터정보_0(총력전_캐릭터정보)
	ENDIF
ELSE
	IF 총력전_캐릭터정보 == -1
		CALL 총력전_UI_프레임_2(5, 시작위치_0, 21, 선택종류_아군)
	ELSE
		CALL 총력전_UI_프레임_2(5, 시작위치_0, 21 - 8, 선택종류_아군)
		CALL 총력전_UI_줄추가(sHtml_end)
		CALL 총력전_UI_부품_캐릭터정보_0(총력전_캐릭터정보)
	ENDIF	
ENDIF
CALL 총력전_UI_줄추가(sHtml_end)
; 출력
CALL 총력전_UI_출력(3, 1)
RETURN 1

