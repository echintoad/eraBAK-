@총력전_보스_UI_헤더_1
; shape, space = 왜인진 모르겠지만 살짝 왼쪽으로 틀어져서
#DIMS CONST 이펙트 = @"<shape type='space' param='25'><img src='Boss_1_EFX' height='1200' ypos='2000'>"
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp
; 총력전_보스_쿨다운:1 = -2 ~ -8
; -2 |x|x|o|o|o|
; -3 |o|x|x|o|o|
; -4 |o|o|x|x|o|
; -5 |o|o|o|x|x|
; -6 |x|x|x|x|o|
; -7 |x|x|o|x|x|
; -8 |o|x|x|x|x|
IF FLAG:화상설정
	; 돌진 스킬에 맞춰서 배경 추가
	; iTmp = (총력전_턴수 - 1) % 4
	; sTmp = %TOSTR_SPACE(3 + 24 * iTmp)%
	sTmp = %TOSTR_SPACE(3)%
	; 이미지
	IF 총력전_보스_쿨다운:1 == -2 || 총력전_보스_쿨다운:1 == -6 || 총력전_보스_쿨다운:1 == -7
		sTmp += @"%이펙트%%TOSTR_SPACE(3)%"
	ENDIF
	; 공간
	IF 총력전_보스_쿨다운:1 == -3 || 총력전_보스_쿨다운:1 == -7 || 총력전_보스_쿨다운:1 == -8
		sTmp += @"%TOSTR_SPACE(24)%"
	ELSEIF 총력전_보스_쿨다운:1 == -4
		sTmp += @"%TOSTR_SPACE(24*2)%"
	ELSEIF 총력전_보스_쿨다운:1 == -5
		sTmp += @"%TOSTR_SPACE(24*3)%"
	ENDIF
	; 이미지
	IF 총력전_보스_쿨다운:1 == -3 || 총력전_보스_쿨다운:1 == -4 || 총력전_보스_쿨다운:1 == -5 || 총력전_보스_쿨다운:1 == -6 || 총력전_보스_쿨다운:1 == -7 || 총력전_보스_쿨다운:1 == -8
		sTmp += @"%이펙트%%TOSTR_SPACE(3)%"
	ENDIF
	; 이미지
	IF 총력전_보스_쿨다운:1 == -8
		sTmp += @"%이펙트%%TOSTR_SPACE(3)%"
	ENDIF
	CALL 총력전_UI_줄추가(sTmp)
ENDIF
CALL 총력전_UI_줄추가(@"|%TOSTR_REPEAT("=",50)%|%TOSTR_SPACE(6)%SLUMPIA%TOSTR_SPACE(6)%|%TOSTR_REPEAT("=",50)%|")
RETURN 1

