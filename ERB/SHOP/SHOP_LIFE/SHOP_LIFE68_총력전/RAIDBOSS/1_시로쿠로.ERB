; 최소 일수
SIF DAY < 3
	RETURN 0
IF 총력전_보스_활동_쿨다운:1 == -2
	RETURN 1
ELSEIF 총력전_보스_활동_쿨다운:1 == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF

