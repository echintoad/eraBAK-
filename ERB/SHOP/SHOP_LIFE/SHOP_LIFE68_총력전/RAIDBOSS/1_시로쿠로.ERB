; #region == 페이즈 ==
@총력전_보스_페이즈_판단_1
#DIM CONST 보스번호 = 10, 11 ; 시로, 쿠로
#DIM DYNAMIC 살아있는보스 = -1
#DIM DYNAMIC 치유량
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp
IF 총력전_상태:10 != 0 && 총력전_상태:11 != 0
	; 같이 처치 됬을때를 대비해서 
	IF 총력전_상태:10 == 총력전_상태_보스_행동불능 && 총력전_상태:11 != 총력전_상태_보스_행동불능
		총력전_상태:10 = 0
		총력전_팀:10 = -1 ; 프레임3 에 뜨지 않게
	ELSEIF 총력전_상태:11 == 총력전_상태_보스_행동불능 && 총력전_상태:10 != 총력전_상태_보스_행동불능
		총력전_상태:11 = 0
		총력전_팀:11 = -1
	ENDIF
ENDIF
SELECTCASE 총력전_보스_페이즈
	CASE 0
		; 보스 상태 확인
		IF 총력전_상태:11 == 0 && 총력전_상태:10 != 0
			살아있는보스 = 10
		ELSEIF 총력전_상태:10 == 0 && 총력전_상태:11 != 0
			살아있는보스 = 11
		ENDIF
		IF 살아있는보스 != -1 || 총력전_턴수 >= 20
			총력전_보스_페이즈 = 1
			IF 살아있는보스 != -1
				; 보스 체력 비율
				iTmp = 총력전_체력:살아있는보스 * 100 / GETVAR_RAIDSTAT_SUM(살아있는보스, "최대체력")
				IF iTmp > 20 ; 체력 20% 이상이면 치유
					치유량 = GETVAR_RAIDSTAT_SUM(살아있는보스, "최대체력") * 10
					치유량 = DIVIDE_ROUND(치유량, 100)
					CALL 총력전_처리_치유(치유량, 살아있는보스)
				ENDIF
			ENDIF
		ENDIF
ENDSELECT


