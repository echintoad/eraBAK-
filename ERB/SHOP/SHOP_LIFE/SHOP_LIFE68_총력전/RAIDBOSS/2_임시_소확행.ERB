; #region == 카운터 ==
@총력전_스킬_2_0_카운터_증가(캐릭터, 대상, 카운터번호, 증가양)
#DIM 캐릭터
#DIM 대상
#DIM 카운터번호
#DIM 증가양

; #DIM DYNAMIC 목표
#DIM DYNAMIC 대미지
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

IF 총력전_카운터_증가양:캐릭터:카운터번호 == 0
	총력전_카운터_증가양:캐릭터:카운터번호 = 1
	sTmp = 「이런 예술도 모르는 것들이!」
	CALL 총력전_UI_텍스트_추가(sTmp)
	sTmp = %조사처리(총력전_이름:캐릭터,"가")% 반격해 왔다
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	CALL 총력전_UI_Main(0)
	WAITANYKEY
	; 대미지
	SELECTCASE 총력전_보스_난이도
		CASE 4, 3
			대미지 = GETVAR_RAIDSTAT_SUM(캐릭터, "공격력") * 110
		CASE 2, 1
			대미지 = GETVAR_RAIDSTAT_SUM(캐릭터, "공격력") * 80
		CASEELSE ; 0
			대미지 = GETVAR_RAIDSTAT_SUM(캐릭터, "공격력") * 40
	ENDSELECT
	대미지 = DIVIDE_ROUND(대미지, 100)
	; 무작위 공격 3번
	FOR iTmp, 0, 3
		CALL 총력전_목표_무작위(0)
		IF RESULT == -1
			DEBUGPRINTFORML 목표 없음
			BREAK
		ENDIF
		CALL 총력전_처리_피격(대미지, RESULT, 캐릭터)
	NEXT
ENDIF

; AR, 피격 취소 1
@총력전_스킬_2_1_카운터_증가(캐릭터, 대상, 카운터번호, 증가양)
#DIM 캐릭터
#DIM 대상
#DIM 카운터번호
#DIM 증가양
#DIMS DYNAMIC sTmp
IF 총력전_카운터_증가양:캐릭터:카운터번호 > 0
	총력전_카운터_증가양:캐릭터:카운터번호 = 총력전_카운터_증가양:캐릭터:카운터번호 - 1 ; 0 되면 공격 취소
	IF 총력전_카운터_증가양:캐릭터:카운터번호 == 0
		sTmp = %총력전_이름:캐릭터% 연타 공격 취소!
		CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
		CALL 총력전_UI_Main(0)
		WAITANYKEY
	ENDIF
ENDIF

@총력전_스킬_2_1_카운터_종료(대상, 카운터번호)
#DIM 대상
#DIM 카운터번호
#DIM DYNAMIC iTmp
; LOCALS = %총력전_이름:대상% 연타 1 카운터 = {카운터번호}, 양:{총력전_카운터_증가양:대상:카운터번호}
; CALL 총력전_UI_텍스트_추가(LOCALS, 칼라_노랑)
IF 총력전_카운터_증가양:대상:카운터번호 > 0
	FOR iTmp, 0, 총력전_카운터_증가양:대상:카운터번호
		CALL _총력전_스킬_2_소확행공격(대상)
	NEXT
ENDIF
CALL 총력전_카운터_제거(대상, 카운터번호)

; 턴 종료시 대상 사망처리
@총력전_스킬_2_2_카운터_종료(대상, 카운터번호)
#DIM 대상
#DIM 카운터번호
IF 총력전_체력:대상 > 0
	총력전_체력:대상 = 0
	CALL 총력전_확인_행동불능(대상)
	CALL 총력전_UI_텍스트_추가(@"마지막 멤버가 도망쳤다...", 칼라_노랑)
ENDIF
CALL 총력전_카운터_제거(대상, 카운터번호)

; #region == 개인 함수? ==
@_총력전_스킬_2_소확행공격(캐릭터)
#DIM 캐릭터
#DIM DYNAMIC 목표
#DIM DYNAMIC 대미지
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp
sTmp = %총력전_이름:캐릭터% 연타 공격!
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
대미지 = GETVAR_RAIDSTAT_SUM(캐릭터, "공격력") * 130
대미지 = DIVIDE_ROUND(대미지, 100)
FOR iTmp, 0, 3
	; 무작위 목표
	CALL 총력전_목표_무작위(0)
	목표 = RESULT
	; 목표 없으면
	SIF 목표 < 0
		CONTINUE
	; 목표 = 0
	CALL 총력전_처리_피격(대미지, 목표, 캐릭터)
NEXT

