; #endregion == 페이즈 ==

; #region == 스킬 ==
@총력전_보스_스킬_초기_2
; 공격 버프 (AR)
총력전_보스_쿨다운:0 = 2
; 회피 버프 (HG)
총력전_보스_쿨다운:1 = 1
; 후방 저격 (SR)
총력전_보스_쿨다운:2 = 2
; 난사
총력전_보스_쿨다운:3 = 99

@총력전_보스_시퀀스_스킬_2
#DIM DYNAMIC 시전가능스킬, 10
#DIM DYNAMIC 시전가능스킬수
; 10=AR, 11=HG, 12=SR
#DIM CONST 보스번호 = 10, 11, 12
#DIM DYNAMIC iTmp, 2

; 시전중인 스킬 있으면 마저 시전
IF 총력전_보스_시전스킬 >= 0
	GOTO CAST_SKILL
ENDIF

VARSET 시전가능스킬, -1
; 페이즈 2 확인
IF 총력전_보스_페이즈 == 1 && 총력전_보스_쿨다운:3 <= 0
	시전가능스킬:시전가능스킬수 = 3
	시전가능스킬수 ++
ENDIF
; 연타 공격 (AR)
; 회피 버프 (HG)
; 후방 저격 (SR)
FOR iTmp, 0, 3
	IF 총력전_체력:(보스번호:iTmp) > 0 && 총력전_보스_쿨다운:iTmp <= 0
		IF iTmp == 0 ; 임시 AR 확률 업
			시전가능스킬:시전가능스킬수 = iTmp
			시전가능스킬수 ++
			시전가능스킬:시전가능스킬수 = iTmp
			시전가능스킬수 ++
		ENDIF
		시전가능스킬:시전가능스킬수 = iTmp
		시전가능스킬수 ++
	ENDIF	
NEXT
; 시전 가능 스킬 없으면
IF 시전가능스킬:0 < 0
	RETURN
ENDIF
; 시전스킬 선택
총력전_보스_시전스킬 = 시전가능스킬:(RAND:시전가능스킬수)

$CAST_SKILL
VARSIZE 보스번호
FOR iTmp, 0, RESULT
	SIF 총력전_상태:(보스번호:iTmp) == 총력전_상태_보스_행동불능
		CONTINUE
	; 상태효과 적용
	SETBIT 총력전_스탯상태:(보스번호:iTmp), 총력전_방식_스킬
	CALL 총력전_상태효과_스탯처리(보스번호:iTmp)
	; 카운터
	CALL 총력전_카운터_증가(보스번호:iTmp, -1, 총력전_방식_스킬)
	CALL 총력전_카운터_소비(보스번호:iTmp, 총력전_방식_스킬)
NEXT
; 시전
CALLFORM 총력전_보스_2_스킬_{총력전_보스_시전스킬}

VARSIZE 보스번호
FOR iTmp, 0, RESULT
	SIF 총력전_상태:(보스번호:iTmp) == 총력전_상태_보스_행동불능
		CONTINUE
	; 스킬 상태효과 종료
	CLEARBIT 총력전_스탯상태:(보스번호:iTmp), 총력전_방식_스킬
	CALL 총력전_상태효과_스탯처리(보스번호:iTmp)
	; CALL 총력전_초기화_스탯_상효(보스번호:iTmp)
	; 스킬 상태효과 소비
	CALL 총력전_상태효과_소비(보스번호:iTmp, 총력전_방식_스킬)
NEXT

; 공격 버프 (AR)
; (AR) 피격 카운터 추가, 1턴후 카운터 있으면 공격
; 미도리 스킬 비슷하게
@총력전_보스_2_스킬_0
; 10=AR, 11=HG, 12=SR
#DIM CONST 보스번호 = 10, 11, 12
#DIM DYNAMIC 대상, 총력전_캐릭터수
#DIM DYNAMIC 공격회수
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

SELECTCASE 총력전_보스_난이도
	CASE 4, 3
		공격회수 = 3
	CASE 2, 1
		공격회수 = 2
	CASEELSE
		공격회수 = 1
ENDSELECT

; 합동 공격 준비
; 1턴 준비후, n회 공격 연타 공격
sTmp = %조사처리(총력전_이름:(보스번호:0),"가")% 팀 연타 공격을 준비중이다
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
sTmp = 보스마다 1턴 준비 후 {공격회수 * 3}회 공격
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY
; 총력전 처음만 추가 설명, 안쓰이는 총력전_보스_쿨다운:4 사용
IF 총력전_보스_쿨다운:4 == -1
	총력전_보스_쿨다운:4 = -2
	; 피격 1회마다 공격 회수 감소
	sTmp = 보스 피격 1회마다 공격 회수 3 감소
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	; UI 업데이트
	CALL 총력전_UI_Main(0)
	WAITANYKEY
ENDIF
; 카운터 추가
FOR iTmp, 0, 3
	IF 총력전_체력:(보스번호:iTmp) > 0
		CALL 총력전_카운터_추가(보스번호:iTmp, 보스번호:iTmp, 총력전_방식_피격, 총력전_방식_턴, 2, 2, 1)
		; 카운터 번호 회수
		CALL 총력전_카운터_검색_스킬번호(보스번호:iTmp, 2, 1)
		; 양 = 공격회수
		총력전_카운터_증가양:(보스번호:iTmp):RESULT = 공격회수
	ENDIF
NEXT
; 종료
총력전_보스_쿨다운:0 = 4
CALL 총력전_보스_스킬종료(2)


; 회피 버프 (HG)
@총력전_보스_2_스킬_1
; 10=AR, 11=HG, 12=SR
#DIM CONST 보스번호 = 10, 11, 12
#DIM DYNAMIC 대상, 총력전_캐릭터수
#DIM DYNAMIC 카운터번호
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp
; 경고 후 종료
IF 총력전_보스_시전중 == 0
	총력전_보스_시전중 = 1
	sTmp = %조사처리(총력전_이름:(보스번호:1),"가")% 악기를 꺼냈다!
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	sTmp = 1턴 준비 후, 방해받지 않았으면 팀 회피율 버프.
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	; UI 업데이트
	CALL 총력전_UI_Main(0)
	WAITANYKEY
	; 피격 카운터 추가
	CALL 총력전_카운터_추가(보스번호:1, 보스번호:1, 총력전_방식_피격, 총력전_방식_턴, 2, 2, 0)
	; 종료
	RETURN
ENDIF
; 피격 카운터 확인
CALL 총력전_카운터_검색_스킬번호(보스번호:1, 2, 0)
카운터번호 = RESULT
IF 총력전_카운터_증가양:(보스번호:1):카운터번호 == 1
	GOTO CLEANUP
ENDIF
; 시전 텍스트
sTmp = 연주에 따라 춤을 추기 시작했다!
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
sTmp = ...정신 사나워서 조준하기 힘들다
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY
; 대상 처리
CALL 총력전_목표_전체(대상, 1)
; 버프
FOR iTmp, 0, 3
	SIF 대상:iTmp < 0
		BREAK
	CALL 총력전_상태효과_추가_텍스트(대상:iTmp, 보스번호:0, 상효_종류_회피율백분율, 30, 1, 총력전_방식_지속, 총력전_방식_턴, 4, 2, 4)
NEXT
$CLEANUP
; 종료
총력전_보스_쿨다운:1 = 5
CALL 총력전_카운터_제거(보스번호:1, 카운터번호)
CALL 총력전_보스_스킬종료(2)


; 후방 저격 (SR)
; 피격시 명중률 감소?
@총력전_보스_2_스킬_2
; 10=AR, 11=HG, 12=SR
#DIM CONST 보스번호 = 12
#DIM DYNAMIC 대미지
#DIM DYNAMIC iBlank
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp
; 조준 후 종료
IF 총력전_보스_시전중 == 0
	iBlank = 0
	CALL 총력전_목표_후방(iTmp, 0, 10)
	; 목표 없으면
	SIF RESULT == -1
		RETURN
	총력전_스킬_조준:보스번호:0 = RESULT
	; 시전 경고
	sTmp = %조사처리(총력전_이름:보스번호,"가")% %조사처리(총력전_이름:(총력전_스킬_조준:보스번호:0), "을")% 노리고 있다!
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	; UI 업데이트
	CALL 총력전_UI_Main(0)
	WAITANYKEY
	; 종료
	총력전_보스_시전중 = 1
	RETURN
ENDIF
; 스킬 시전
; 목표 아직도 있는지 확인, 없으면 스킬 쿨 다운
iTmp = 총력전_스킬_조준:보스번호:0
IF iTmp < 0 || 총력전_상태:iTmp <= 0 || 총력전_상태:iTmp == 총력전_상태_행동불능
	sTmp = 목표 없음, 시전 취소
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	GOTO CLEANUP
ENDIF
; 대미지
SELECTCASE 총력전_보스_난이도
	CASE 4
		대미지 = GETVAR_RAIDSTAT_SUM(보스번호, "공격력") * 350
	CASE 3
		대미지 = GETVAR_RAIDSTAT_SUM(보스번호, "공격력") * 300
	CASE 2
		대미지 = GETVAR_RAIDSTAT_SUM(보스번호, "공격력") * 250
	CASEELSE ; 1 & 0
		대미지 = GETVAR_RAIDSTAT_SUM(보스번호, "공격력") * 200
ENDSELECT
대미지 = DIVIDE_ROUND(대미지, 100)
CALL 총력전_처리_피격(대미지, 총력전_스킬_조준:보스번호:0, 보스번호)
; 종료
$CLEANUP
총력전_보스_쿨다운:2 = 3
CALL 총력전_보스_스킬종료(1)

; 난사
@총력전_보스_2_스킬_3
#DIM DYNAMIC 살아있는보스
