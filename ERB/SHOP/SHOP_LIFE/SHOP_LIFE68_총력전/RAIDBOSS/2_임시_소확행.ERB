살아있는보스 = 1
CALL 총력전_목표(살아있는보스, 0, 총력전_캐릭터수)
; 살아있는 보스 없으면
SIF RESULT == -1
	RETURN
살아있는보스 = RESULT
; 경고 후 종료
IF 총력전_보스_시전중 == 0
	총력전_보스_시전중 = 1
	sTmp = 1턴 준비 후, 무작위 5번 공격.
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	; UI 업데이트
	CALL 총력전_UI_Main(0)
	WAITANYKEY
	; 종료
	RETURN
ENDIF
; 대미지
SELECTCASE 총력전_보스_난이도
	CASE 4, 3
		대미지 = GETVAR_RAIDSTAT_SUM(살아있는보스, "공격력") * 200
	CASE 2
		대미지 = GETVAR_RAIDSTAT_SUM(살아있는보스, "공격력") * 150
	CASE 1
		대미지 = GETVAR_RAIDSTAT_SUM(살아있는보스, "공격력") * 100
	CASEELSE ; 0
		대미지 = GETVAR_RAIDSTAT_SUM(살아있는보스, "공격력") * 50
ENDSELECT
대미지 = DIVIDE_ROUND(대미지, 100)
; 무작위 공격 5번
FOR iTmp, 0, 5
	CALL 총력전_목표_무작위(0)
	IF RESULT == -1
		DEBUGPRINTFORML 목표 없음
		BREAK
	ENDIF
	CALL 총력전_처리_피격(대미지, RESULT, 살아있는보스)
NEXT
; 종료
$CLEANUP
; 총력전_보스_쿨다운:3 = 3
CALL 총력전_보스_스킬종료(2)

