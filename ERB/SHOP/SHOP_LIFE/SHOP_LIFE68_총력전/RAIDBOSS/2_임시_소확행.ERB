총력전_이미지_초기:(보스번호:2) = Boss_2_S_2
총력전_이미지:(보스번호:0) = %총력전_이미지_초기:(보스번호:0)%
총력전_이미지:(보스번호:1) = %총력전_이미지_초기:(보스번호:1)%
총력전_이미지:(보스번호:2) = %총력전_이미지_초기:(보스번호:2)%
; 위치, 10 -> 17, 뒤 중앙으로 이동
CALL 총력전_이동_위치(12, 13)
CALL 총력전_이동_위치(11, 12)
CALL 총력전_이동_위치(10, 11)
; 팀
총력전_팀:(보스번호:0) = 1
총력전_팀:(보스번호:1) = 1
총력전_팀:(보스번호:2) = 1

; 스탯
; 필요 없는 옵션 제거
SELECTCASE 총력전_보스_난이도
	CASE 0
		난이도계수:0 = 20 ; -20
		난이도계수:1 = 32 ; -17
		난이도계수:2 = 40 ; -15
		난이도계수:3 = 52 ; -12
		난이도계수:4 = 64 ; -9
		난이도계수:5 = 76 ; -6
	CASE 1
		난이도계수:0 = 40 ; -20
		난이도계수:1 = 49 ; -17
		난이도계수:2 = 55 ; -15
		난이도계수:3 = 64 ; -12
		난이도계수:4 = 73 ; -9
		난이도계수:5 = 82 ; -6
	CASE 2
		난이도계수:0 = 60 ; -20
		난이도계수:1 = 66 ; -17
		난이도계수:2 = 70 ; -15
		난이도계수:3 = 76 ; -12
		난이도계수:4 = 82 ; -9
		난이도계수:5 = 88 ; -6
	CASE 3
		난이도계수:0 = 80 ; -20
		난이도계수:1 = 83 ; -17
		난이도계수:2 = 85 ; -15
		난이도계수:3 = 88 ; -12
		난이도계수:4 = 91 ; -9
		난이도계수:5 = 94 ; -6
	CASEELSE
		VARSET 난이도계수, 100
ENDSELECT
; 체력
총력전_최대체력_최초:(보스번호:0) = DIVIDE_ROUND(75000 * 난이도계수:0, 300)
총력전_최대체력_최초:(보스번호:1) = 총력전_최대체력_최초:(보스번호:0)
총력전_최대체력_최초:(보스번호:2) = 총력전_최대체력_최초:(보스번호:0)
; 공격력 HG 감소
총력전_공격력_최초:(보스번호:0) = DIVIDE_ROUND(380 * 난이도계수:1, 100)
총력전_공격력_최초:(보스번호:1) = DIVIDE_ROUND(260 * 난이도계수:1, 100)
총력전_공격력_최초:(보스번호:2) = DIVIDE_ROUND(430 * 난이도계수:1, 100)
; 방어력 AR 소증가
총력전_방어력_최초:(보스번호:0) = DIVIDE_ROUND(180 * 난이도계수:4, 100)
총력전_방어력_최초:(보스번호:1) = DIVIDE_ROUND(150 * 난이도계수:4, 100)
총력전_방어력_최초:(보스번호:2) = 총력전_방어력_최초:(보스번호:1)
; 명중률
총력전_명중률_최초:(보스번호:0) = DIVIDE_ROUND(380 * 난이도계수:4, 100)
총력전_명중률_최초:(보스번호:1) = 총력전_명중률_최초:(보스번호:0)
총력전_명중률_최초:(보스번호:2) = 총력전_명중률_최초:(보스번호:0)
; 회피율 HG 증가
총력전_회피율_최초:(보스번호:0) = DIVIDE_ROUND(190 * 난이도계수:1, 100) ; 1-(1-x)^2?
총력전_회피율_최초:(보스번호:1) = DIVIDE_ROUND(270 * 난이도계수:1, 100)
총력전_회피율_최초:(보스번호:2) = 총력전_회피율_최초:(보스번호:0)
; 치유력
총력전_치유력_최초:(보스번호:0) = 10
총력전_치유력_최초:(보스번호:1) = 총력전_치유력_최초:(보스번호:0)
총력전_치유력_최초:(보스번호:2) = 총력전_치유력_최초:(보스번호:0)
; 치명타 SR 증가
총력전_치명타_최초:(보스번호:0) = DIVIDE_ROUND(150 * 난이도계수:4, 100)
총력전_치명타_최초:(보스번호:1) = 총력전_치명타_최초:(보스번호:0)
총력전_치명타_최초:(보스번호:2) = DIVIDE_ROUND(200 * 난이도계수:4, 100)
; 치명타 저항
총력전_치명타_저항_최초:(보스번호:0) = DIVIDE_ROUND(320 * 난이도계수:2, 100)
총력전_치명타_저항_최초:(보스번호:1) = 총력전_치명타_저항_최초:(보스번호:0)
총력전_치명타_저항_최초:(보스번호:2) = 총력전_치명타_저항_최초:(보스번호:0)
; 치명타 대미지 SR 증가
총력전_치명타_대미지_최초:(보스번호:0) = DIVIDE_ROUND(150 * 난이도계수:3, 100)
총력전_치명타_대미지_최초:(보스번호:1) = 총력전_치명타_대미지_최초:(보스번호:0)
총력전_치명타_대미지_최초:(보스번호:2) = DIVIDE_ROUND(250 * 난이도계수:3, 100)
; 치명타 대미지 저항
총력전_치명타_대미지_저항_최초:(보스번호:0) = DIVIDE_ROUND(120 * 난이도계수:4, 100)
총력전_치명타_대미지_저항_최초:(보스번호:1) = 총력전_치명타_대미지_저항_최초:(보스번호:0)
총력전_치명타_대미지_저항_최초:(보스번호:2) = 총력전_치명타_대미지_저항_최초:(보스번호:0)
; 군중제어 한계, 1000 이하로 떨어지지 않게 주의
총력전_군중제어_한계_최초:(보스번호:0) = DIVIDE_ROUND(2000 * 난이도계수:3, 100)
총력전_군중제어_한계_최초:(보스번호:1) = 총력전_군중제어_한계_최초:(보스번호:0)
총력전_군중제어_한계_최초:(보스번호:2) = 총력전_군중제어_한계_최초:(보스번호:0)
; 군중제어 강화
총력전_군중제어_강화_최초:(보스번호:0) = 0
총력전_군중제어_강화_최초:(보스번호:1) = 0
총력전_군중제어_강화_최초:(보스번호:2) = 0
; 군중제어 저항
총력전_군중제어_저항_최초:(보스번호:0) = 0
총력전_군중제어_저항_최초:(보스번호:1) = 0
총력전_군중제어_저항_최초:(보스번호:2) = 0


; #region == 페이즈 ==
@총력전_보스_페이즈_판단_2
; 10=AR, 11=HG, 12=SR
#DIM CONST 보스번호 = 10, 11, 12
#DIM DYNAMIC 공증가 = 10
#DIM DYNAMIC 치댐증가 = 20
#DIM DYNAMIC 회피증가 ; 계산
#DIM DYNAMIC 방어감소 = -20
#DIM DYNAMIC 살아있는보스 = -1
#DIM DYNAMIC iTmp, 3
#DIMS DYNAMIC sTmp

IF 총력전_보스_페이즈 == 0
	; 보스 혼자만 남았는지 확인
	FOR iTmp, 0, 3
		IF 총력전_체력:(보스번호:iTmp) > 0
			; 살아있는 보스 한명 이상이면
			IF 살아있는보스 >= 0
				살아있는보스 = -1
				BREAK
			ENDIF
			살아있는보스 = 보스번호:iTmp
		ENDIF
	NEXT
	; 보스 하나만 살아있으면 버프, 페이즈 2(1)
	IF 살아있는보스 >= 0
		총력전_보스_페이즈 = 1
		총력전_보스_쿨다운:3 = 0
		; 텍스트
		sTmp = 「히이이익!!」
		CALL 총력전_UI_텍스트_추가(sTmp)
		CALL 총력전_UI_Main(0)
		WAITANYKEY
		; 살아있는 보스 체력 백분율 확인, 정확할 필요 없음, 효율적으로
		iTmp = 총력전_체력:살아있는보스 * 100 / GETVAR_RAIDSTAT_SUM(살아있는보스, "최대체력")
		SELECTCASE 총력전_보스_난이도
			CASE 0
				iTmp:2 = 25
			CASE 1
				iTmp:2 = 20
			CASE 2
				iTmp:2 = 15
			CASE 3
				iTmp:2 = 10
			CASEELSE
				GOTO PHASE2
		ENDSELECT
		; 퇴장 텍스트 + 마지막 턴 버프
		IF iTmp < iTmp:2
			sTmp = 「나 혼자는 못해! 지, 집에 갈 거야!」
			CALL 총력전_UI_텍스트_추가(sTmp)
			CALL 총력전_UI_Main(0)
			WAITANYKEY
			sTmp = 노숙자가 도망친다, 이번턴만 버티면 우승
			CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
			CALL 총력전_UI_Main(0)
			WAITANYKEY
			; 버프
			CALL 총력전_상태효과_추가(살아있는보스, 살아있는보스, 상효_종류_공격력백분율, 공증가, 1, 총력전_방식_지속, 총력전_방식_지속, 1, 2, 0)
			CALL 총력전_상태효과_추가(살아있는보스, 살아있는보스, 상효_종류_방어력백분율, 방어감소, 0, 총력전_방식_지속, 총력전_방식_지속, 1, 2, 1)
			sTmp = %조사처리(총력전_이름:살아있는보스, "의")% 공격력 ({공증가}％) 증가, 방어력 ({방어감소}％) 감소
			; 턴 종료 카운터
			CALL 총력전_카운터_추가(살아있는보스, 살아있는보스, 총력전_방식_턴, 총력전_방식_턴, 1, 2, 2)
			CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
			CALL 총력전_UI_Main(0)
			RETURN
		ENDIF
		; (10, 15, 20, 25)n% 이상이면 치유 + 버프
		; 이하면 공격 증가, 방어 감소
		; TORMENT, 100%
		$PHASE2
		sTmp = 땡그랑!
		CALL 총력전_UI_텍스트_추가(sTmp, 칼라_오렌지)
		CALL 총력전_UI_Main(0)
		WAITANYKEY
