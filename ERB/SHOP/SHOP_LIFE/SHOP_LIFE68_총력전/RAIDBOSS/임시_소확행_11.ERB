; #DIMS DYNAMIC sTmp

; 보스 쿨다운 + 설정
총력전_보스_활동_쿨다운:11 = 3
CALL 총력전_보스활동_제거(11)

; 코인 보상
CALL 총력전_보스_보상_공통코인(0)
