; #region 보스 초기 설정
; 총력전 최대 턴수
@총력전_보스_턴_종료_11
RETURN 30

; 기본 공격모드 설정, 필요하면 활성화
; 0 = 기본, 1 = 무작위
@총력전_보스_공격모드_설정_11
총력전_공격모드:0 = 1 ; 아군
총력전_공격모드:1 = 0 ; 보스

; 보스 스탯 설정
; 보스가 여럿 있을시 등등, 스탯 개별 설정 보다 이렇는게 더 유연(?)함
@총력전_보스_설정_11
#DIM 난이도계수, 4 ; 필요하면 다차원 배열
#DIM CONST 보스번호 = 10, 11, 12
#DIM DYNAMIC iTmp
; 상태
총력전_상태:(보스번호:0) = 총력전_상태_보스
총력전_상태:(보스번호:1) = 총력전_상태_보스
총력전_상태:(보스번호:2) = 총력전_상태_보스
; ID?
; 총력전_ID:보스번호 = -1 ; 필요없을수도...
; 토벌 이름
CALL 총력전_보스_이름_11
총력전_보스_이름 = %RESULTS%
; 캐릭터 카드 이름
총력전_이름:(보스번호:0) = 히피 드로이드 (AR)
총력전_이름:(보스번호:1) = 히피 드로이드 (HG)
총력전_이름:(보스번호:2) = 히피 드로이드 (SR)
; 이미지
총력전_이미지_초기:(보스번호:0) = Boss_11_S_0
총력전_이미지_초기:(보스번호:1) = Boss_11_S_1
총력전_이미지_초기:(보스번호:2) = Boss_11_S_2
총력전_이미지:(보스번호:0) = %총력전_이미지_초기:(보스번호:0)%
총력전_이미지:(보스번호:1) = %총력전_이미지_초기:(보스번호:1)%
총력전_이미지:(보스번호:2) = %총력전_이미지_초기:(보스번호:2)%
; 위치, 10 -> 17, 뒤 중앙으로 이동
CALL 총력전_이동_위치(12, 13)
CALL 총력전_이동_위치(11, 12)
CALL 총력전_이동_위치(10, 11)
; 팀
총력전_팀:(보스번호:0) = 1
총력전_팀:(보스번호:1) = 1
총력전_팀:(보스번호:2) = 1

; 스탯
; 소환수 스탯 -> 체력뺀 보스 스탯
; 계속 계산 할 필요 없게
SELECTCASE 총력전_보스_난이도
	CASE 0
		난이도계수 = 36
		난이도계수:1 = 64
		난이도계수:2 = 45
		난이도계수:3 = 60
	CASE 1
		난이도계수 = 52
		난이도계수:1 = 73
		난이도계수:2 = 59
		난이도계수:3 = 70
	CASE 2
		난이도계수 = 68
		난이도계수:1 = 82
		난이도계수:2 = 72
		난이도계수:3 = 80
	CASE 3
		난이도계수 = 84
		난이도계수:1 = 91
		난이도계수:2 = 86
		난이도계수:3 = 90
	CASEELSE
		난이도계수 = 100
		난이도계수:1 = 100
		난이도계수:2 = 100
		난이도계수:3 = 100
ENDSELECT
; 체력
총력전_최대체력_최초:(보스번호:0) = DIVIDE_ROUND(25000 * 난이도계수:1, 300)
총력전_최대체력_최초:(보스번호:1) = 총력전_최대체력_최초:(보스번호:0)
총력전_최대체력_최초:(보스번호:2) = 총력전_최대체력_최초:(보스번호:0)
; 공격력 HG 감소
총력전_공격력_최초:(보스번호:0) = DIVIDE_ROUND(200 * 난이도계수:2, 100)
총력전_공격력_최초:(보스번호:1) = DIVIDE_ROUND(140 * 난이도계수:2, 100)
총력전_공격력_최초:(보스번호:2) = 총력전_공격력_최초:(보스번호:0)
; 방어력 AR 소증가
총력전_방어력_최초:(보스번호:0) = DIVIDE_ROUND(200 * 난이도계수:1, 100)
총력전_방어력_최초:(보스번호:1) = DIVIDE_ROUND(180 * 난이도계수:1, 100)
총력전_방어력_최초:(보스번호:2) = 총력전_방어력_최초:(보스번호:1)
; 명중률
총력전_명중률_최초:(보스번호:0) = DIVIDE_ROUND(250 * 난이도계수:3, 100)
총력전_명중률_최초:(보스번호:1) = 총력전_명중률_최초:(보스번호:0)
총력전_명중률_최초:(보스번호:2) = 총력전_명중률_최초:(보스번호:0)
; 회피율 HG 증가
총력전_회피율_최초:(보스번호:0) = DIVIDE_ROUND(140 * 난이도계수, 100)
총력전_회피율_최초:(보스번호:1) = DIVIDE_ROUND(200 * 난이도계수, 100)
총력전_회피율_최초:(보스번호:2) = 총력전_회피율_최초:(보스번호:0)
; 치유력
총력전_치유력_최초:(보스번호:0) = 10
총력전_치유력_최초:(보스번호:1) = 총력전_치유력_최초:(보스번호:0)
총력전_치유력_최초:(보스번호:2) = 총력전_치유력_최초:(보스번호:0)
; 치명타 SR 증가
총력전_치명타_최초:(보스번호:0) = DIVIDE_ROUND(100 * 난이도계수:3, 100)
총력전_치명타_최초:(보스번호:1) = 총력전_치명타_최초:(보스번호:0)
총력전_치명타_최초:(보스번호:2) = DIVIDE_ROUND(150 * 난이도계수:3, 100)
; 치명타 저항
총력전_치명타_저항_최초:(보스번호:0) = DIVIDE_ROUND(100 * 난이도계수:3, 100)
총력전_치명타_저항_최초:(보스번호:1) = 총력전_치명타_저항_최초:(보스번호:0)
총력전_치명타_저항_최초:(보스번호:2) = 총력전_치명타_저항_최초:(보스번호:0)
; 치명타 대미지 SR 증가
총력전_치명타_대미지_최초:(보스번호:0) = DIVIDE_ROUND(200 * 난이도계수:2, 100)
총력전_치명타_대미지_최초:(보스번호:1) = 총력전_치명타_대미지_최초:(보스번호:0)
총력전_치명타_대미지_최초:(보스번호:2) = DIVIDE_ROUND(300 * 난이도계수:2, 100)
; 치명타 대미지 저항
총력전_치명타_대미지_저항_최초:(보스번호:0) = DIVIDE_ROUND(100 * 난이도계수:2, 100)
총력전_치명타_대미지_저항_최초:(보스번호:1) = 총력전_치명타_대미지_저항_최초:(보스번호:0)
총력전_치명타_대미지_저항_최초:(보스번호:2) = 총력전_치명타_대미지_저항_최초:(보스번호:0)
; 군중제어 한계, 1000 이하로 떨어지지 않게 주의
총력전_군중제어_한계_최초:(보스번호:0) = DIVIDE_ROUND(2000 * 난이도계수:3, 100)
총력전_군중제어_한계_최초:(보스번호:1) = 총력전_군중제어_한계_최초:(보스번호:0)
총력전_군중제어_한계_최초:(보스번호:2) = 총력전_군중제어_한계_최초:(보스번호:0)
; 군중제어 강화
총력전_군중제어_강화_최초:(보스번호:0) = 0
총력전_군중제어_강화_최초:(보스번호:1) = 0
총력전_군중제어_강화_최초:(보스번호:2) = 0
; 군중제어 저항
총력전_군중제어_저항_최초:(보스번호:0) = 0
총력전_군중제어_저항_최초:(보스번호:1) = 0
총력전_군중제어_저항_최초:(보스번호:2) = 0


; #region == 페이즈 ==
@총력전_보스_페이즈_판단_11
; 10=AR, 11=HG, 12=SR
#DIM CONST 보스번호 = 10, 11, 12
#DIM DYNAMIC 살아있는보스 = -1
#DIM DYNAMIC iTmp, 3
#DIMS DYNAMIC sTmp

IF 총력전_보스_페이즈 == 0
	; 보스 혼자만 남았는지 확인
	FOR iTmp, 0, 3
		IF 총력전_체력:(보스번호:iTmp) > 0
			; 살아있는 보스 한명 이상이면
			IF 살아있는보스 > 0
				살아있는보스 = -1
				BREAK
			ENDIF
			살아있는보스 = 보스번호:iTmp
		ENDIF
	NEXT
	; 보스 하나만 살아있으면 버프, 페이즈 2(1)
	IF 살아있는보스 > 0
		총력전_보스_페이즈 = 1
		총력전_보스_쿨다운:3 = 0
		; 텍스트
		sTmp = 「히이이익!!」
		CALL 총력전_UI_텍스트_추가(sTmp)
		CALL 총력전_UI_Main(0)
		WAITANYKEY
		sTmp = 「나 혼자는 못해! 지, 집에 갈 거야!」
		CALL 총력전_UI_텍스트_추가(sTmp)
		CALL 총력전_UI_Main(0)
		WAITANYKEY
		sTmp = 땡그랑!
		CALL 총력전_UI_텍스트_추가(sTmp, 칼라_오렌지)
		CALL 총력전_UI_Main(0)
		WAITANYKEY
		sTmp = 「...고급 통조림?」
		CALL 총력전_UI_텍스트_추가(sTmp)
		CALL 총력전_UI_Main(0)
		WAITANYKEY
		sTmp = 「혼자? 나 혼자? 어?」
		CALL 총력전_UI_텍스트_추가(sTmp)
		CALL 총력전_UI_Main(0)
		WAITANYKEY
		sTmp = 「이, 이기면 내 거다! 다 내 거야!」
		CALL 총력전_UI_텍스트_추가(sTmp)
		CALL 총력전_UI_Main(0)
		WAITANYKEY
		; 버프 추가
		; 공백, 치댐
		iTmp:0 = 15
		; 회피율은 HG 비례
		iTmp:1 = DIVIDE_ROUND(총력전_회피율_최초:(보스번호:1) * 20, 100)
		CALL 총력전_상태효과_추가(살아있는보스, 살아있는보스, 상효_종류_공격력백분율, iTmp:0, 1, 총력전_방식_지속, 총력전_방식_지속, 1, 11, 0)
		CALL 총력전_상태효과_추가(살아있는보스, 살아있는보스, 상효_종류_회피율, iTmp:1, 1, 총력전_방식_지속, 총력전_방식_지속, 1, 11, 1)
		CALL 총력전_상태효과_추가(살아있는보스, 살아있는보스, 상효_종류_치명타대미지백분율, iTmp:0, 1, 총력전_방식_지속, 총력전_방식_지속, 1, 11, 2)
		; 텍스트 추가
		sTmp = %조사처리(총력전_이름:살아있는보스, "의")% 공격력 ({iTmp:0}％), 회피율 ({iTmp:1}), 치명 대미지 ({iTmp:0}％) 증가
		CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
		; UI 업데이트
		CALL 총력전_UI_Main(0)
		WAITANYKEY
	ENDIF
ENDIF

; #endregion == 페이즈 ==

; #region == 스킬 ==
@총력전_보스_스킬_초기_11
; 공격 버프 (AR)
총력전_보스_쿨다운:0 = 2
; 회피 버프 (HG)
총력전_보스_쿨다운:1 = 1
; 후방 저격 (SR)
총력전_보스_쿨다운:2 = 2
; 난사
총력전_보스_쿨다운:3 = 99

@총력전_보스_시퀀스_스킬_11
#DIM DYNAMIC 시전가능스킬, 3
#DIM DYNAMIC 시전가능스킬수
; 10=AR, 11=HG, 12=SR
#DIM CONST 보스번호 = 10, 11, 12
#DIM DYNAMIC iTmp, 2

; 시전중인 스킬 있으면 마저 시전
IF 총력전_보스_시전스킬 >= 0
	GOTO CAST_SKILL
ENDIF

VARSET 시전가능스킬, -1
; 페이즈 2 확인
IF 총력전_보스_페이즈 == 1 && 총력전_보스_쿨다운:3 <= 0
	시전가능스킬:시전가능스킬수 = 3
	시전가능스킬수 ++
ENDIF
; 공격 버프 (AR)
; 회피 버프 (HG)
; 후방 저격 (SR)
FOR iTmp, 0, 3
	IF 총력전_체력:(보스번호:iTmp) > 0 && 총력전_보스_쿨다운:iTmp <= 0
		시전가능스킬:시전가능스킬수 = iTmp
		시전가능스킬수 ++
	ENDIF	
NEXT
; 시전 가능 스킬 없으면
IF 시전가능스킬:0 < 0
	RETURN
ENDIF
; 시전스킬 선택
총력전_보스_시전스킬 = 시전가능스킬:(RAND:시전가능스킬수)

$CAST_SKILL
VARSIZE 보스번호
FOR iTmp, 0, RESULT
	SIF 총력전_상태:(보스번호:iTmp) == 총력전_상태_보스_행동불능
		CONTINUE
	; 상태효과 적용
	CALL 총력전_상태효과_스탯처리(보스번호:iTmp, 총력전_방식_스킬)
	; 카운터
	CALL 총력전_카운터_증가(보스번호:iTmp, -1, 총력전_방식_스킬)
	CALL 총력전_카운터_소비(보스번호:iTmp, 총력전_방식_스킬)
NEXT
; 시전
CALLFORM 총력전_보스_11_스킬_{총력전_보스_시전스킬}

VARSIZE 보스번호
FOR iTmp, 0, RESULT
	SIF 총력전_상태:(보스번호:iTmp) == 총력전_상태_보스_행동불능
		CONTINUE
	; 스킬 상태효과 종료
	CALL 총력전_초기화_스탯_상효(보스번호:iTmp)
	CALL 총력전_초기화_상태효과_적용(보스번호:iTmp, 총력전_방식_스킬)
	; 스킬 상태효과 소비
	CALL 총력전_상태효과_소비(보스번호:iTmp, 총력전_방식_스킬)
NEXT

; 공격 버프 (AR)
@총력전_보스_11_스킬_0
; 10=AR, 11=HG, 12=SR
#DIM CONST 보스번호 = 10, 11, 12
#DIM DYNAMIC 대상, 총력전_캐릭터수
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

; 경고 후 종료
IF 총력전_보스_시전중 == 0
	총력전_보스_시전중 = 1
	sTmp = %조사처리(총력전_이름:(보스번호:0),"가")% 춤을 추기 시작했다!
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	sTmp = 1턴뒤 팀 공격력 버프
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	; UI 업데이트
	CALL 총력전_UI_Main(0)
	WAITANYKEY
	; 종료
	RETURN
ENDIF
; 시전자 생존 확인
IF 총력전_상태:(보스번호:0) == 총력전_상태_보스_행동불능
	; 텍스트
	sTmp = 하지만 아무도 없었다 
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	; UI 업데이트
	CALL 총력전_UI_Main(0)
	WAITANYKEY
	; 종료
	CALL 총력전_보스_스킬종료(1)
	RETURN
ENDIF
; 시전 텍스트
sTmp = 춤을 본 팀원들은 용기를 얻었다
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
IF RAND:5 == 0
	sTmp = ...아니 왜?
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
ENDIF
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY
; 대상 처리
CALL 총력전_목표_전체(대상, 1)
; 버프
FOR iTmp, 0, 3
	CALL 총력전_상태효과_추가_텍스트(대상:iTmp, 보스번호:0, 상효_종류_공격력백분율, 20, 0, 총력전_방식_지속, 총력전_방식_턴, 4, 11, 3)
NEXT
; 종료
CALL 총력전_보스_스킬종료(2)


; 회피 버프 (HG)
@총력전_보스_11_스킬_1
; 10=AR, 11=HG, 12=SR
#DIM CONST 보스번호 = 10, 11, 12
#DIM DYNAMIC 대상, 총력전_캐릭터수
#DIM DYNAMIC 카운터번호
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp
; 경고 후 종료
IF 총력전_보스_시전중 == 0
	총력전_보스_시전중 = 1
	sTmp = %조사처리(총력전_이름:(보스번호:1),"가")% 악기를 꺼냈다!
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	sTmp = 1턴 준비 후, 방해받지 않았으면 팀 회피율 버프.
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	; UI 업데이트
	CALL 총력전_UI_Main(0)
	WAITANYKEY
	; 피격 카운터 추가
	CALL 총력전_카운터_추가(보스번호:1, 보스번호:1, 총력전_방식_피격, 총력전_방식_턴, 2, 11, 0)
	; 종료
	RETURN
ENDIF
; 피격 카운터 확인
CALL 총력전_카운터_검색_스킬번호(보스번호:1, 11, 0)
카운터번호 = RESULT
IF 총력전_카운터_증가양:(보스번호:1):카운터번호 == 1
	GOTO CLEANUP
ENDIF
; 시전 텍스트
sTmp = 연주에 따라 춤을 추기 시작했다!
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
sTmp = ...정신 사나워서 조준하기 힘들다
CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
; UI 업데이트
CALL 총력전_UI_Main(0)
WAITANYKEY
; 대상 처리
CALL 총력전_목표_전체(대상, 1)
; 버프
FOR iTmp, 0, 3
	CALL 총력전_상태효과_추가_텍스트(대상:iTmp, 보스번호:0, 상효_종류_회피율백분율, 30, 0, 총력전_방식_지속, 총력전_방식_턴, 4, 11, 4)
NEXT
$CLEANUP
; 종료
CALL 총력전_카운터_제거(보스번호:1, 카운터번호)
CALL 총력전_보스_스킬종료(2)


; 후방 저격 (SR)
@총력전_보스_11_스킬_2
; 10=AR, 11=HG, 12=SR
#DIM CONST 보스번호 = 12
#DIM DYNAMIC 대미지
#DIM DYNAMIC iBlank
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp
; 조준 후 종료
IF 총력전_보스_시전중 == 0
	iBlank = 0
	CALL 총력전_목표_후방(iTmp, 0, 10)
	; 목표 없으면
	SIF RESULT == -1
		RETURN
	총력전_보스_조준:0 = RESULT
	; 시전 경고
	sTmp = %조사처리(총력전_이름:보스번호,"가")% %조사처리(총력전_이름:(총력전_보스_조준:0), "을")% 노리고 있다!
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	; UI 업데이트
	CALL 총력전_UI_Main(0)
	WAITANYKEY
	; 종료
	총력전_보스_시전중 = 1
	RETURN
ENDIF
; 스킬 시전
; 목표 아직도 있는지 확인, 없으면 스킬 쿨 다운
iTmp = 총력전_보스_조준:0
IF iTmp < 0 || 총력전_상태:iTmp <= 0 || 총력전_상태:iTmp == 총력전_상태_행동불능
	sTmp = 목표 없음, 시전 취소
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	GOTO CLEANUP
ENDIF
; 대미지
SELECTCASE 총력전_보스_난이도
	CASE 4
		대미지 = GETVAR_RAIDSTAT_SUM(보스번호, "공격력") * 300
	CASE 3
		대미지 = GETVAR_RAIDSTAT_SUM(보스번호, "공격력") * 250
	CASE 2
		대미지 = GETVAR_RAIDSTAT_SUM(보스번호, "공격력") * 200
	CASEELSE ; 1 & 0
		대미지 = GETVAR_RAIDSTAT_SUM(보스번호, "공격력") * 150
ENDSELECT
대미지 = DIVIDE_ROUND(대미지, 100)
CALL 총력전_처리_피격(대미지, 총력전_보스_조준:0, 보스번호)
; 종료
$CLEANUP
CALL 총력전_보스_스킬종료(2)

; 난사
@총력전_보스_11_스킬_3
#DIM DYNAMIC 살아있는보스
#DIM DYNAMIC 대미지
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp
; 살아있는 보스 확인
살아있는보스 = 1
CALL 총력전_목표(살아있는보스, 0, 총력전_캐릭터수)
; 살아있는 보스 없으면
SIF RESULT == -1
	RETURN
살아있는보스 = RESULT
; 경고 후 종료
IF 총력전_보스_시전중 == 0
	총력전_보스_시전중 = 1
	sTmp = 1턴 준비 후, 무작위 5번 공격.
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	; UI 업데이트
	CALL 총력전_UI_Main(0)
	WAITANYKEY
	; 종료
	RETURN
ENDIF
; 대미지
SELECTCASE 총력전_보스_난이도
	CASE 4, 3
		대미지 = GETVAR_RAIDSTAT_SUM(살아있는보스, "공격력") * 120
	CASE 2
		대미지 = GETVAR_RAIDSTAT_SUM(살아있는보스, "공격력") * 90
	CASE 1
		대미지 = GETVAR_RAIDSTAT_SUM(살아있는보스, "공격력") * 70
	CASEELSE ; 0
		대미지 = GETVAR_RAIDSTAT_SUM(살아있는보스, "공격력") * 50
ENDSELECT
대미지 = DIVIDE_ROUND(대미지, 100)
; 무작위 공격 5번
FOR iTmp, 0, 5
	CALL 총력전_목표_무작위(0)
	IF RESULT == -1
		DEBUGPRINTFORML 목표 없음
		BREAK
	ENDIF
	CALL 총력전_처리_피격(대미지, RESULT, 살아있는보스)
NEXT

; #endregion == 스킬 ==

; #region == 카운터 ==
@총력전_스킬_11_0_카운터_증가(캐릭터, 대상, 카운터번호, 증가양)
#DIM 캐릭터
#DIM 대상
#DIM 카운터번호
#DIM 증가양

; #DIM DYNAMIC 목표
#DIM DYNAMIC 대미지
#DIM DYNAMIC iTmp
#DIMS DYNAMIC sTmp

IF 총력전_카운터_증가양:캐릭터:카운터번호 == 0
	총력전_카운터_증가양:캐릭터:카운터번호 = 1
	sTmp = 「이런 예술도 모르는 것들이!」
	CALL 총력전_UI_텍스트_추가(sTmp)
	sTmp = %조사처리(총력전_이름:캐릭터,"가")% 반격해 왔다
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	CALL 총력전_UI_Main(0)
	WAITANYKEY
	; 대미지
	SELECTCASE 총력전_보스_난이도
		CASE 4, 3
			대미지 = GETVAR_RAIDSTAT_SUM(캐릭터, "공격력") * 90
		CASE 2, 1
			대미지 = GETVAR_RAIDSTAT_SUM(캐릭터, "공격력") * 70
		CASEELSE ; 0
			대미지 = GETVAR_RAIDSTAT_SUM(캐릭터, "공격력") * 40
	ENDSELECT
	대미지 = DIVIDE_ROUND(대미지, 100)
	; 무작위 공격 3번
	FOR iTmp, 0, 3
		CALL 총력전_목표_무작위(0)
		IF RESULT == -1
			DEBUGPRINTFORML 목표 없음
			BREAK
		ENDIF
		CALL 총력전_처리_피격(대미지, RESULT, 캐릭터)
	NEXT
ENDIF
