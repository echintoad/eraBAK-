; ===== 개발노트 =====
; 테스트용 보스
; 소환수 5명
; 보스 체력은 소환수 처리시 감소
; ====================
; 보스 팀 이름, 예 시로 앤 쿠로
@총력전_보스_이름_10
RESULTS = 카이저 이사

; 보스 선택창 이미지, 총력전시 이미지는 보스_설정 에서
@총력전_보스_이미지_10
RESULTS = Boss_10_F

; 총력전 보스 소환 가능한지 확인
; RETURN 1 = 무작위 소환에 추가
@총력전_보스_소환_확인_10
; 최소 일수
; SIF DAY < 3
; 	RETURN 0
IF 총력전_보스_활동_쿨다운:10 == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF

; 보스 소환시 나오는 이벤트 텍스트
@총력전_보스_소환_텍스트_10
PRINTW 카이저 이사가 소대를 이끌고 나타났다.
PRINTW ...약탈 하기 좋은 기회인 거 같다.

; #region 보스 GUI
; 전체적으로 바꾸고 싶으면
; RETURN 1 = 기본 프레임 렌더 하지 않음
; @총력전_보스_UI_10
; RETURN 1

; 보스 프레임
@총력전_보스_UI_프레임_10(선택종류_적군 = 0)
#DIM DYNAMIC 선택종류_적군
#DIM CONST iSpace = 120
#DIM DYNAMIC iBlank
#DIMS DYNAMIC sTmp

; 14 - 1
iBlank = 17
IF 총력전_전투단계 == 총력전_전투단계_플레이어
	CALL 총력전_UI_프레임_3(1, iBlank, 6, 선택종류_적군)
ELSE
	CALL 총력전_UI_프레임_3(1, iBlank, 6, -1)
ENDIF
sTmp = |-|%TOSTR_REPEAT("-",iSpace - 3)%|-|
HTML_PRINT sTmp
iBlank = 10
CALL 총력전_UI_프레임_3(5, iBlank, 7, 선택종류_적군)

; #endregion

; #region 보스 초기 설정
; 총력전 최대 턴수
@총력전_보스_턴_종료_10
RETURN 30

; 기본 공격모드 설정, 필요하면 활성화
; 0 = 기본, 1 = 무작위
@총력전_보스_공격모드_설정_10
공격모드:0 = 0 ; 아군
공격모드:1 = 1 ; 보스

; 보스 스탯 설정
; 보스가 여럿 있을시 등등, 스탯 개별 설정 보다 이렇는게 더 유연(?)함
@총력전_보스_설정_10
#DIM 난이도계수, 4 ; 필요하면 다차원 배열
#DIM CONST 보스번호 = 10
#DIM DYNAMIC iTmp
; 상태
총력전_상태:보스번호 = 총력전_상태_보스
; ID?
; 총력전_ID:보스번호 = -1 ; 필요없을수도...
; 토벌 이름
CALL 총력전_보스_이름_10
총력전_보스_이름 = %RESULTS%
; 캐릭터 카드 이름
총력전_이름:보스번호 = %RESULTS%
; 위치, 10 -> 17, 뒤 중앙으로 이동
CALL 총력전_이동_번호(보스번호, 17)
; 팀
; 조준 불가 하게 팀 3번으로
총력전_팀:보스번호 = 3
; 이미지... 임시
총력전_이미지_초기:보스번호 = Boss_10_S
총력전_이미지:보스번호 = %총력전_이미지_초기:보스번호%

; 스탯
; 소환수 스탯 -> 체력뺀 보스 스탯
; 계속 계산 할 필요 없게
SELECTCASE 총력전_보스_난이도
	CASE 0
		난이도계수 = 36
		난이도계수:1 = 64
		난이도계수:2 = 45
		난이도계수:3 = 60
	CASE 1
		난이도계수 = 52
		난이도계수:1 = 73
		난이도계수:2 = 59
		난이도계수:3 = 70
	CASE 2
		난이도계수 = 68
		난이도계수:1 = 82
		난이도계수:2 = 72
		난이도계수:3 = 80
	CASE 3
		난이도계수 = 84
		난이도계수:1 = 91
		난이도계수:2 = 86
		난이도계수:3 = 90
	CASEELSE
		난이도계수 = 100
		난이도계수:1 = 100
		난이도계수:2 = 100
		난이도계수:3 = 100
ENDSELECT
; 체력
총력전_최대체력_최초:보스번호 = DIVIDE_ROUND(25000 * 난이도계수:1, 100)
; 공격력
총력전_공격력_최초:보스번호 = DIVIDE_ROUND(200 * 난이도계수:2, 100)
; 방어력
총력전_방어력_최초:보스번호 = 0
; 명중률
총력전_명중률_최초:보스번호 = DIVIDE_ROUND(250 * 난이도계수:3, 100)
; 회피율
총력전_회피율_최초:보스번호 = DIVIDE_ROUND(120 * 난이도계수, 100)
; 치유력
총력전_치유력_최초:보스번호 = 10
; 치명타
총력전_치명타_최초:보스번호 = DIVIDE_ROUND(100 * 난이도계수:3, 100)
; 치명타 저항
총력전_치명타_저항_최초:보스번호 = DIVIDE_ROUND(100 * 난이도계수:3, 100)
; 치명타 대미지
총력전_치명타_대미지_최초:보스번호 = DIVIDE_ROUND(200 * 난이도계수:2, 100)
; 치명타 대미지 저항
총력전_치명타_대미지_저항_최초:보스번호 = DIVIDE_ROUND(100 * 난이도계수:2, 100)
; 군중제어 한계
총력전_군중제어_한계_최초:보스번호 = DIVIDE_ROUND(4000 * 난이도계수, 100)
; 군중제어 강화
총력전_군중제어_강화_최초:보스번호 = 0
; 군중제어 저항
총력전_군중제어_저항_최초:보스번호 = 50

; 소환
; SMG
iTmp = FINDELEMENT(총력전_위치, 10)
CALL 총력전_보스_10_스킬_0(iTmp, 2, 0)
; AR
iTmp = FINDELEMENT(총력전_위치, 11)
CALL 총력전_보스_10_스킬_0(iTmp, 0, 0)
iTmp = FINDELEMENT(총력전_위치, 12)
CALL 총력전_보스_10_스킬_0(iTmp, 0, 0)
; RL
iTmp = FINDELEMENT(총력전_위치, 13)
CALL 총력전_보스_10_스킬_0(iTmp, 1, 0)
iTmp = FINDELEMENT(총력전_위치, 14)
CALL 총력전_보스_10_스킬_0(iTmp, 1, 0)

; #region == 페이즈 ==
@총력전_보스_페이즈_판단_10
#DIM DYNAMIC 보스번호
#DIM DYNAMIC 소환카운터, 3 ; 0:AR, 1:RL, 2:SMG
; #DIM DYNAMIC 소환회수
#DIM DYNAMIC iTmp, 2
; 소환수 화인
FOR iTmp, 0, 3
	; CALL 총력전_소환물_수(10, iTmp)
	소환카운터:iTmp = 총력전_소환물_수(10, iTmp)
	DEBUGPRINTFORML summon cnt:{iTmp} = {RESULT}
NEXT
IF 소환카운터:0 + 소환카운터:1 + 소환카운터:2 == 5
	GOTO SUMMONEND
ENDIF
; 부족하면 소환
; SMG 먼저
; 위치 10 확인
iTmp = FINDELEMENT(총력전_위치, 10)
IF 소환카운터:2 >= 2 && 총력전_상태:iTmp == 0
	; SMG 2명 이상이면 이동
	; 무작위 선택
	iTmp = 총력전_소환물_번호_무작위(10, 2)
	CALL 총력전_이동_위치(총력전_위치:iTmp, 10)
ELSEIF 소환카운터:2 == 1 && 총력전_상태:iTmp == 0
	; SMG 하나, 왼쪽 끝 위치 비어 있음
	; 왼쪽 끝 SMG 소환
	CALL 총력전_보스_10_스킬_0(iTmp, 2)
	소환카운터:2 += 1
ELSEIF 소환카운터:2 == 1
	; SMG 하나
	; SMG 이동
	iTmp = 총력전_소환물_번호(10, 2)
	CALL 총력전_이동_위치(총력전_위치:iTmp, 10)
ELSEIF 소환카운터:2 == 0
	; SMG 없음
	; 위치 10 -> 14 확인
	FOR iTmp:1, 10, 15
		iTmp = FINDELEMENT(총력전_위치, iTmp:1)
		IF 총력전_상태:iTmp == 0
			CALL 총력전_보스_10_스킬_0(iTmp, 2)
			소환카운터:2 += 1
			; 다음 턴에 이동?
			; CALL 총력전_이동_위치(iTmp:1, 10)
			BREAK
		ENDIF
	NEXT
ENDIF
; 소환수 재 확인
IF 소환카운터:0 + 소환카운터:1 + 소환카운터:2 == 5
	GOTO SUMMONEND
ENDIF
; 위치 10 -> 14 확인
FOR iTmp:1, 10, 15
	iTmp = FINDELEMENT(총력전_위치, iTmp:1)
	IF 총력전_상태:iTmp == 0
		; AR, RL 중 무작위 선택
		CALL 총력전_보스_10_스킬_0(iTmp, RAND:2)
	ENDIF
NEXT
$SUMMONEND

; RL 있으면 범위 공격
; AR 있으면 집중 공격
; SMG 있으면 보호막


; #endregion == 페이즈 ==

; #region == 스킬 ==
@총력전_보스_스킬_초기_10
; 총력전_보스_쿨다운:0 = 2
; 총력전_보스_쿨다운:1 = 2
; 총력전_보스_쿨다운:2 = 99
; 총력전_보스_쿨다운:3 = 99
; 난이도 3, 4 모래폭풍 시전
; IF 총력전_보스_난이도 >= 3
; 	CALL 총력전_보스_10_스킬_3
; ENDIF
; CALL 총력전_보스_보상_10

@총력전_보스_시퀀스_스킬_10
#DIM DYNAMIC 스킬수
#DIM DYNAMIC 시전가능스킬, 3
#DIM DYNAMIC 보스번호
#DIM DYNAMIC iTmp, 2

; 시전중인 스킬 있으면 마저 시전
IF 총력전_보스_시전스킬 >= 0
	GOTO CAST_SKILL
ENDIF

; 소환수 확인


$CAST_SKILL
; 비나 위치 바뀔거 같으면, 아니면 그냥 10 으로
; iTmp = 1
; CALL 총력전_목표(iTmp, 0, 총력전_캐릭터수)
; 보스번호 = RESULT
; 보스번호 = 10
; ; 상태효과 적용
; ; 비나는 혼자라서 for loop 불필요
; CALL 총력전_상태효과_스탯처리(보스번호, 총력전_방식_스킬)
; ; 카운터
; CALL 총력전_카운터_증가(보스번호, -1, 총력전_방식_스킬)
; CALL 총력전_카운터_소비(보스번호, 총력전_방식_스킬)
; ; 시전
; CALLFORM 총력전_보스_10_스킬_{총력전_보스_시전스킬}
; ; 스킬 상태효과 종료
; CALL 총력전_초기화_스탯_상효(보스번호)
; CALL 총력전_초기화_상태효과_적용(보스번호, 총력전_방식_스킬)
; ; 스킬 상태효과 소비
; CALL 총력전_상태효과_소비(보스번호, 총력전_방식_스킬)

; 소환
@총력전_보스_10_스킬_0(소환물번호, 병사종류, 텍스트 = 1)
#DIM 소환물번호 ; 소환 총력전 번호
#DIM 병사종류
#DIM DYNAMIC 텍스트 ; 소환 텍스트 추가
; PMC 병사(오토마톤)
#DIM iTmp
#DIMS sTmp

CALL 총력전_소환물_소환(소환물번호, 10)
총력전_상태:소환물번호 = 총력전_상태_소환 ; 스킬 에서 수정
; 총력전_ID:소환물번호 = 총력전_ID:iSummoner
총력전_팀:소환물번호 = 1
총력전_스킬_번호:소환물번호 = 10
병사종류 = LIMIT(병사종류, 0, 2)
SELECTCASE 병사종류
CASE 0 ; AR
	총력전_이름:소환물번호 = PMC(AR) 병사
	총력전_스킬_가변:소환물번호 = 0
	총력전_이미지_초기:소환물번호 = Boss_10_Summon_0
	총력전_이미지:소환물번호 = %총력전_이미지_초기:소환물번호%
	총력전_방어력_최초:소환물번호 = 10
CASE 1 ; RL
	총력전_이름:소환물번호 = PMC(RL) 병사
	총력전_스킬_가변:소환물번호 = 1
	총력전_이미지_초기:소환물번호 = Boss_10_Summon_1
	총력전_이미지:소환물번호 = %총력전_이미지_초기:소환물번호%
	; 스탯
	iTmp = DIVIDE_ROUND(총력전_최대체력_최초:소환물번호 * 80, 100)
	총력전_최대체력_최초:소환물번호 = iTmp
	iTmp = DIVIDE_ROUND(총력전_공격력_최초:소환물번호 * 150, 100)
	총력전_공격력_최초:소환물번호 = iTmp
	총력전_방어력_최초:소환물번호 = 10
CASEELSE ; SMG
	총력전_이름:소환물번호 = PMC(SMG) 병사
	총력전_스킬_가변:소환물번호 = 2
	총력전_이미지_초기:소환물번호 = Boss_10_Summon_2
	총력전_이미지:소환물번호 = %총력전_이미지_초기:소환물번호%
	; 스탯
	iTmp = DIVIDE_ROUND(총력전_최대체력_최초:소환물번호 * 120, 100)
	총력전_최대체력_최초:소환물번호 = iTmp
	iTmp = DIVIDE_ROUND(총력전_공격력_최초:소환물번호 * 50, 100)
	총력전_공격력_최초:소환물번호 = iTmp
	총력전_방어력_최초:소환물번호 = 100
ENDSELECT
; 전체적 체력 감소
iTmp = DIVIDE_ROUND(총력전_최대체력_최초:소환물번호 * 10, 100)
총력전_최대체력_최초:소환물번호 = iTmp
CALL 총력전_초기화_스탯(소환물번호, 1)
; 텍스트 추가
IF 텍스트
	sTmp = %총력전_이름:소환물번호%가 참전 했다
	CALL 총력전_UI_텍스트_추가(sTmp, 칼라_노랑)
	; UI 업데이트
	CALL 총력전_UI_Main(0)
	WAITANYKEY
ENDIF
; 카운터 추가

