@총력전_보스_체력_0(난이도)
#DIM 난이도

#DIM 난이도계수

SELECTCASE 난이도
	CASE 0
		난이도계수 = 8
	CASE 1
		난이도계수 = 10
	CASE 2
		난이도계수 = 12
	CASE 3
		난이도계수 = 15
	CASE 4
		난이도계수 = 20
ENDSELECT

RETURN 200000 * 난이도계수 / 10 ; 테스트 동안
; RETURN 20000 * 난이도계수 / 10

